            <circle cx="340" cy="55" r="6" fill="#ed4823"></circle>
          </g>
          <!-- Dot 2 -->
          <g class="connector-dot" data-step="2">
            <circle
              cx="340"
              cy="165"
              r="14"
              fill="white"
              stroke="#ed4823"
              stroke-width="4.5"></circle>
            <circle cx="340" cy="165" r="6" fill="#ed4823"></circle>
          </g>
          <!-- Dot 3 -->
          <g class="connector-dot" data-step="3">
            <circle
              cx="340"
              cy="275"
              r="14"
              fill="white"
              stroke="#ed4823"
              stroke-width="4.5"></circle>
            <circle cx="340" cy="275" r="6" fill="#ed4823"></circle>
          </g>
          <!-- Dot 4 -->
          <g class="connector-dot" data-step="4">
            <circle
              cx="340"
              cy="385"
              r="14"
