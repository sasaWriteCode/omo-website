<script>
  // Helper to update active states across all corresponding data-step elements
  const steps = ["1", "2", "3", "4"];

  function setActiveStep(stepNum: string) {
    document.querySelectorAll("[data-step]").forEach((el) => {
      const elStep = el.getAttribute("data-step");
      if (elStep === stepNum) {
        el.classList.add("active");
        el.classList.add("hovered"); // legacy support
      } else {
        el.classList.remove("active");
        el.classList.remove("hovered");
      }
    });
  }

  // Step 1 is active by default
  setActiveStep("1");

  // Attach hover and click listeners
  document.querySelectorAll("[data-step]").forEach((el) => {
    const step = el.getAttribute("data-step");
    if (!step) return;

    el.addEventListener("mouseenter", () => {
      setActiveStep(step);
    });

    el.addEventListener("click", () => {
      setActiveStep(step);
    });
  });

  // ── Mobile Card Expand & Collapse Behavior ──
  const mobileStepsCol = document.querySelector(".mobile-steps-col");
  const mobileCloseBtn = document.querySelector(".mobile-card-close");

  function expandMobileCard() {
    if (window.innerWidth < 768 && mobileStepsCol) {
      mobileStepsCol.classList.add("is-expanded");
    }
  }

  function collapseMobileCard() {
    if (mobileStepsCol) {
      mobileStepsCol.classList.remove("is-expanded");
    }
  }

  // Click step item on mobile to expand card
  document.querySelectorAll(".mobile-step-item").forEach((el) => {
    el.addEventListener("click", (e) => {
      e.stopPropagation();
      const step = el.getAttribute("data-step");
      if (step) {
        setActiveStep(step);
        expandMobileCard();
      }
    });
  });

  // Click SVG slice/dot on mobile to expand card
  document.querySelectorAll(".mobile-pyramid-col [data-step]").forEach((el) => {
    el.addEventListener("click", (e) => {
      e.stopPropagation();
      const step = el.getAttribute("data-step");
      if (step) {
        setActiveStep(step);
        expandMobileCard();
      }
    });
  });

  // Click close button inside card
  mobileCloseBtn?.addEventListener("click", (e) => {
    e.stopPropagation();
    collapseMobileCard();
  });

  // Click outside container to collapse
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    const pyramidLayout = document.querySelector(".mobile-pyramid-layout");
    if (pyramidLayout && !pyramidLayout.contains(target)) {
      collapseMobileCard();
    }
  });
</script>

<style>
  #how-we-work {
    background: #ffffff;
    /* Large top border-radius stretching across full screen width */
    border-top-left-radius: 40px;
    border-top-right-radius: 40px;
    padding: 5rem 1.5rem 6rem 1.5rem;
    position: relative;
    z-index: 10;
    margin-top: -5rem; /* Float upward over Seven Partners */
    box-shadow: 
      0 -20px 40px rgba(0, 0, 0, 0.04), /* Multi-layer top shadow acting as 3D separator */
      0 -2px 10px rgba(0, 0, 0, 0.02);
    overflow-x: hidden; /* clips pyramid left-overflow on mobile */
  }

  /* Normal centered container */
  #how-we-work .page-wrap {
    position: relative;
    max-width: var(--max-wide);
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    #how-we-work {
      border-top-left-radius: 56px;
      border-top-right-radius: 56px;
      padding: 7rem 2rem 8rem 2rem;
      margin-top: -7rem; /* Deeper overlap on desktop viewports */
    }
  }

  .www-title {
    font-family: var(--serif);
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    font-weight: 800;
    color: #111111;
    text-align: center;
    margin-top: 0;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .www-subtitle {
    font-family: var(--sans);
    font-size: clamp(1rem, 1.8vw, 1.25rem);
    font-weight: 600;
    color: #ed4823;
    text-align: center;
    margin-top: 0;
    margin-bottom: 1rem;
  }

  .www-supporting-desc {
    font-family: var(--sans);
    font-size: clamp(0.9rem, 1.5vw, 1.05rem);
    line-height: 1.6;
    color: #666666;
    text-align: center;
    max-width: 780px;
    margin: 0 auto 4rem auto;
  }

  /* Desktop grid: hidden on mobile, shown on tablet+ */
  .how-we-work-grid {
    display: none;
  }

  @media (min-width: 768px) {
    .how-we-work-grid {
      display: grid;
      grid-template-columns: 420px 1fr;
      gap: 1.5rem;
      max-width: 1000px;
      margin: 0 auto;
      align-items: center;
    }
  }

  /* ── Mobile-only pyramid + steps layout ── */
  .mobile-pyramid-layout {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 0.5rem;
    align-items: center;
    position: relative;
    /* Escape page-wrap left padding so half-pyramid is flush with viewport edge */
    margin-left: -1.5rem;
    width: calc(100% + 1.5rem);
    background: transparent;
  }

  @media (min-width: 768px) {
    .mobile-pyramid-layout {
      display: none;
    }
  }

  /* Left: Pyramid column with SVG */
  .mobile-pyramid-col {
    width: 100%;
    position: relative;
    height: 440px;
    display: flex;
    align-items: center;
  }

  .mobile-pyramid-svg {
    width: 100%;
    height: 440px;
    display: block;
    overflow: visible;
  }

  /* Right: steps column inside light grey rounded container */
  .mobile-steps-col {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-around;
    height: 440px;
    background: #f8f9fa;
    border-radius: 24px;
    padding: 0.75rem 0.85rem;
    box-sizing: border-box;
    align-items: stretch;
    transition:
      padding 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      background-color 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mobile-card-close {
    display: flex;
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: none;
    background: rgba(0, 0, 0, 0.07);
    color: #444444;
    font-size: 1.2rem;
    line-height: 1;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    z-index: 10;
    opacity: 0;
    transform: scale(0.5) rotate(-90deg);
    pointer-events: none;
    transition:
      opacity 0.3s ease,
      transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
      background 0.2s ease;
  }

  .mobile-card-close:hover {
    background: rgba(0, 0, 0, 0.14);
    transform: scale(1.1) rotate(0deg);
  }

  /* Expanded state styling: smoothly collapses inactive steps and expands active step */
  .mobile-steps-col.is-expanded {
    justify-content: flex-start;
    padding: 1.1rem 0.85rem;
    background: #f4f5f7;
  }

  .mobile-steps-col.is-expanded .mobile-card-close {
    opacity: 1;
    transform: scale(1) rotate(0deg);
    pointer-events: auto;
  }

  .mobile-steps-col.is-expanded .mobile-step-item:not(.active) {
