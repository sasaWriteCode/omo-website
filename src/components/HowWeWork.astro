  }

  #how-we-work.in .connector-dot {
    opacity: 1;
    transform: scale(1);
  }

  #how-we-work.in .connector-dot[data-step="1"] {
    transition-delay: 0.4s;
  }
  #how-we-work.in .connector-dot[data-step="2"] {
    transition-delay: 0.5s;
  }
  #how-we-work.in .connector-dot[data-step="3"] {
    transition-delay: 0.6s;
