        <div class="step-row" data-step="1">
          <div class="step-pill">
            <span class="step-label">Step 1</span>
            <div class="step-content">
              <h3 class="step-title">Understand — Discovery Call</h3>
              <p class="step-desc">
                We clarify your business stage, goals, market position,
                challenges, and growth priorities.
              </p>
            </div>
          </div>
        </div>

        <div class="step-row" data-step="2">
          <div class="step-pill">
            <span class="step-label">Step 2</span>
            <div class="step-content">
              <h3 class="step-title">Diagnose — Business Audit</h3>
              <p class="step-desc">
                We review your business model, operations, revenue flow, market
                positioning, and execution gaps.
              </p>
            </div>
          </div>
        </div>

        <div class="step-row" data-step="3">
          <div class="step-pill">
            <span class="step-label">Step 3</span>
            <div class="step-content">
              <h3 class="step-title">Prescribe — Growth Roadmap</h3>
              <p class="step-desc">
                We design a clear roadmap with recommended actions, priorities,
                timelines, and growth opportunities.
              </p>
            </div>
          </div>
        </div>

        <div class="step-row" data-step="4">
          <div class="step-pill">
            <span class="step-label">Step 4</span>
            <div class="step-content">
              <h3 class="step-title">Execution — Transform & Deliver</h3>
              <p class="step-desc">
                We support the transformation process through strategy,
                marketing, systems, AI, and ecosystem execution.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  // Helper to update active states across all corresponding data-step elements
  const steps = ["1", "2", "3", "4"];

  function setActiveStep(stepNum: string) {
    document.querySelectorAll("[data-step]").forEach((el) => {
      const elStep = el.getAttribute("data-step");
      if (elStep === stepNum) {
        el.classList.add("active");
        el.classList.add("hovered"); // legacy support
      } else {
        el.classList.remove("active");
        el.classList.remove("hovered");
      }
    });
  }

  // Step 1 is active by default
  setActiveStep("1");

  // Attach hover and click listeners
  document.querySelectorAll("[data-step]").forEach((el) => {
    const step = el.getAttribute("data-step");
    if (!step) return;

    el.addEventListener("mouseenter", () => {
      setActiveStep(step);
    });

    el.addEventListener("click", () => {
      setActiveStep(step);
    });
  });
</script>

<style>
  #how-we-work {
    background: #ffffff;
    /* Large top border-radius stretching across full screen width */
    border-top-left-radius: 40px;
    border-top-right-radius: 40px;
    padding: 5rem 1.5rem 6rem 1.5rem;
    position: relative;
    z-index: 10;
    margin-top: -5rem; /* Float upward over Seven Partners */
    box-shadow: 
      0 -20px 40px rgba(0, 0, 0, 0.04), /* Multi-layer top shadow acting as 3D separator */
      0 -2px 10px rgba(0, 0, 0, 0.02);
  }

  /* Normal centered container */
  #how-we-work .page-wrap {
    position: relative;
    max-width: var(--max-wide);
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    #how-we-work {
      border-top-left-radius: 56px;
      border-top-right-radius: 56px;
      padding: 7rem 2rem 8rem 2rem;
      margin-top: -7rem; /* Deeper overlap on desktop viewports */
    }
  }

  .www-title {
    font-family: var(--serif);
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    font-weight: 800;
    color: #111111;
    text-align: center;
    margin-top: 0;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .www-subtitle {
    font-family: var(--sans);
    font-size: clamp(1rem, 1.8vw, 1.25rem);
    font-weight: 600;
    color: #ed4823;
    text-align: center;
    margin-top: 0;
    margin-bottom: 1rem;
  }

  .www-supporting-desc {
    font-family: var(--sans);
    font-size: clamp(0.9rem, 1.5vw, 1.05rem);
    line-height: 1.6;
    color: #666666;
    text-align: center;
    max-width: 780px;
    margin: 0 auto 4rem auto;
  }

  .how-we-work-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    max-width: 1000px;
    margin: 0 auto;
    align-items: center;
  }

  @media (min-width: 768px) {
    .how-we-work-grid {
      grid-template-columns: 420px 1fr;
      gap: 1.5rem;
    }
  }

  .pyramid-wrapper {
    width: 100%;
    max-width: 420px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 440px;
  }

  .pyramid-svg {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .pyramid-slice {
    cursor: pointer;
    transition:
      fill 0.3s ease,
      filter 0.3s ease,
      opacity 0.3s ease;
    opacity: 0.7; /* Inactive opacity default */
  }

  .pyramid-slice.active,
  .pyramid-slice:hover {
    fill: #ed4823;
    opacity: 1;
    filter: drop-shadow(0 0 12px rgba(237, 72, 35, 0.4));
  }

  .connector-line {
    transition:
      stroke 0.3s ease,
      stroke-width 0.3s ease;
  }

  .connector-line.active {
    stroke: #ed4823;
    stroke-width: 2.2px;
  }

  .connector-dot {
    cursor: pointer;
  }

  .connector-dot circle:nth-child(1) {
    r: 14px;
    transition:
      r 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
      fill 0.3s ease,
      stroke 0.3s ease;
  }

  .connector-dot.active circle:nth-child(1) {
    r: 17px;
    stroke: #ed4823;
  }

  .connector-dot circle:nth-child(2) {
    r: 6px;
    transition:
      r 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
      fill 0.3s ease;
  }

  .connector-dot.active circle:nth-child(2) {
    r: 7.5px;
  }

  .steps-wrapper {
    display: grid;
    grid-template-rows: repeat(4, 110px);
    height: 440px;
    background: #f8f9fa;
    border-radius: 24px;
    padding: 0 1.75rem;
    box-sizing: border-box;
    align-items: center;
  }

  @media (max-width: 767px) {
    .steps-wrapper {
      grid-template-rows: auto;
      height: auto;
      gap: 1rem;
      padding: 1.5rem;
    }
    .connector-line,
    .connector-dot {
      display: none;
    }
    .pyramid-svg {
      transform: translateX(18px);
    }
  }

  .step-row {
    display: flex;
    align-items: center;
    height: 110px;
  }

  @media (max-width: 767px) {
    .step-row {
      height: auto;
    }
    .step-pill {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
  }

  .step-pill {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    background: transparent;
    border: 1px solid transparent;
    border-radius: 16px;
    padding: 1rem 1.5rem;
    width: 100%;
    max-width: 100%;
    transition:
      background-color 0.3s ease,
      transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.3s ease,
      border-color 0.3s ease;
    cursor: pointer;
    box-sizing: border-box;
  }

  .step-pill.active {
    background-color: #ffffff;
    border: 1px solid rgba(237, 72, 35, 0.12);
    border-left: 4px solid #ed4823;
    transform: translateX(8px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
  }

  .step-label {
    font-family: var(--sans);
    font-weight: 800;
    font-size: 0.8rem;
    color: #ed4823;
    background: rgba(237, 72, 35, 0.1);
    padding: 4px 12px;
    border-radius: 9999px;
    flex-shrink: 0;
    transition: all 0.3s ease;
  }

  .step-pill.active .step-label {
    color: #ffffff;
    background: #ed4823;
  }

  .step-content {
    display: flex;
    flex-direction: column;
  }

  .step-title {
    font-family: var(--sans);
    font-weight: 700;
    font-size: 1.05rem;
    color: #111111;
    margin: 0 0 0.35rem 0;
    transition: color 0.3s ease;
  }

  .step-pill.active .step-title {
    color: #111111;
  }

  .step-desc {
    font-family: var(--sans);
    font-weight: 400;
    font-size: 0.9rem;
    line-height: 1.5;
    color: #555555;
    margin: 0;
    transition: color 0.3s ease;
  }

  .step-pill.active .step-desc {
    color: #555555;
  }

  /* --- Scroll reveal CSS handles --- */
  .pyramid-slice {
    opacity: 0;
    transform: scaleY(0.85) translateY(20px);
    transform-origin: bottom center;
    transition:
      opacity 0.6s cubic-bezier(0.34, 1.56, 0.64, 1),
      transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  #how-we-work.in .pyramid-slice {
    opacity: 0.7; /* default opacity */
    transform: scaleY(1) translateY(0);
  }

  #how-we-work.in .pyramid-slice.active {
    opacity: 1;
  }

  #how-we-work.in .pyramid-slice[data-step="1"] {
    transition-delay: 0.1s;
  }
  #how-we-work.in .pyramid-slice[data-step="2"] {
    transition-delay: 0.2s;
  }
  #how-we-work.in .pyramid-slice[data-step="3"] {
    transition-delay: 0.3s;
  }
  #how-we-work.in .pyramid-slice[data-step="4"] {
    transition-delay: 0.4s;
  }

  .connector-line {
    stroke-dasharray: 150;
    stroke-dashoffset: 150;
    transition: stroke-dashoffset 0.6s ease-out;
  }

  #how-we-work.in .connector-line {
    stroke-dashoffset: 0;
  }

  #how-we-work.in .connector-line[data-step="1"] {
    transition-delay: 0.3s;
  }
  #how-we-work.in .connector-line[data-step="2"] {
    transition-delay: 0.4s;
  }
  #how-we-work.in .connector-line[data-step="3"] {
    transition-delay: 0.5s;
  }
  #how-we-work.in .connector-line[data-step="4"] {
    transition-delay: 0.6s;
  }

  .connector-dot {
    opacity: 0;
    transform: scale(0.5);
    transform-box: fill-box;
    transform-origin: center;
    transition:
      opacity 0.5s cubic-bezier(0.34, 1.56, 0.64, 1),
