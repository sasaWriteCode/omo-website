---
interface Stat {
  target: number;
  suffix?: string;
  label: string;
  icon: string;
}

const stats: Stat[] = [
  { target: 9,  suffix: '+', label: 'ASEAN Markets',       icon: '🌏' },
  { target: 7,  suffix: '',  label: 'Ecosystem Partners',  icon: '🤝' },
  { target: 20, suffix: '+', label: 'Global Portfolios',   icon: '📈' },
  { target: 3,  suffix: '',  label: 'Growth Stages',       icon: '🚀' },
];
---

<section id="stats-row" aria-label="Key statistics">
  <div class="stats-glow-top"></div>
  <div class="stats-inner">
    {stats.map(({ target, suffix = '', label, icon }, i) => (
      <div class="stat-card" style={`--delay: ${i * 0.12}s`}>
        {i > 0 && <div class="stat-divider" aria-hidden="true"></div>}
        <div class="stat-icon" aria-hidden="true">{icon}</div>
        <span
          class="stat-num countup"
          data-target={target}
          data-suffix={suffix}
        >
          0{suffix}
        </span>
        <span class="stat-label">{label}</span>
      </div>
    ))}
  </div>
</section>

<script>
  // ── Count-up on first intersection ──────────────────────
  function animateCountUp(el: Element) {
    const target  = parseInt((el as HTMLElement).dataset.target  ?? '0', 10);
    const suffix  =          (el as HTMLElement).dataset.suffix  ?? '';
    const duration = 1800;
    const start   = performance.now();
    const easeOut = (t: number) => (t === 1 ? 1 : 1 - Math.pow(2, -10 * t));

    function tick(now: number) {
      const p = Math.min((now - start) / duration, 1);
      el.textContent = Math.floor(easeOut(p) * target) + suffix;
      if (p < 1) requestAnimationFrame(tick);
      else el.textContent = target + suffix;
    }
    requestAnimationFrame(tick);
  }

  // ── Stagger card entrance ────────────────────────────────
  const cards = document.querySelectorAll<HTMLElement>('.stat-card');

  const entryObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          const el = e.target as HTMLElement;
          setTimeout(() => el.classList.add('visible'), parseFloat(el.style.getPropertyValue('--delay') || '0') * 1000);
          entryObs.unobserve(el);
        }
      });
    },
    { threshold: 0.3 }
  );

  cards.forEach((card) => entryObs.observe(card));

  // ── Count-up trigger ─────────────────────────────────────
  const countObs = new IntersectionObserver(
    (entries) =>
      entries.forEach((e) => {
        if (e.isIntersecting) { animateCountUp(e.target); countObs.unobserve(e.target); }
      }),
    { threshold: 0.4 }
  );

  document.querySelectorAll('.countup').forEach((el) => countObs.observe(el));
</script>

<style>
/* ── Dark Momentum Strip ───────────────────────────────── */
#stats-row {
  position: relative;
  background: #111111;
  border-top: 3px solid var(--orange);
  overflow: hidden;
}

/* Subtle radial orange glow behind the strip */
.stats-glow-top {
  position: absolute;
  top: -80px;
  left: 50%;
  transform: translateX(-50%);
  width: 700px;
  height: 260px;
  background: radial-gradient(ellipse at center, rgba(237, 72, 35, 0.12) 0%, transparent 70%);
  pointer-events: none;
}

/* Inner flex row */
.stats-inner {
  position: relative;
  max-width: var(--max-wide);
  margin: 0 auto;
  padding: 0 var(--gutter);
  display: flex;
  align-items: stretch;
  justify-content: space-around;
}

/* ── Single stat card ──────────────────────────────────── */
.stat-card {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 44px 40px;
  flex: 1;
  gap: 6px;
  text-align: center;
  cursor: default;

  /* Entrance animation state */
  opacity: 0;
  transform: translateY(18px);
  transition:
    opacity 0.55s cubic-bezier(0.22, 0.68, 0, 1.2),
    transform 0.55s cubic-bezier(0.22, 0.68, 0, 1.2),
    background 0.3s ease;
}

.stat-card.visible {
  opacity: 1;
  transform: translateY(0);
}

.stat-card:hover {
  background: rgba(237, 72, 35, 0.06);
}

/* Vertical divider between cards */
.stat-divider {
  position: absolute;
  left: 0;
  top: 20%;
  height: 60%;
  width: 1px;
  background: rgba(255, 255, 255, 0.08);
}

/* Icon */
.stat-icon {
  font-size: 1.4rem;
  line-height: 1;
  margin-bottom: 4px;
  filter: grayscale(0.1);
}

/* Big number */
.stat-num {
  font-family: var(--serif);
  font-size: clamp(2.4rem, 4vw, 3.8rem);
  font-weight: 400;
  color: var(--orange);
  line-height: 1;
  letter-spacing: -0.01em;
  /* Subtle text glow */
  text-shadow: 0 0 32px rgba(237, 72, 35, 0.4);
}

/* Label */
.stat-label {
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.42);
  line-height: 1.4;
  margin-top: 2px;
}

/* ── Responsive ────────────────────────────────────────── */
@media (max-width: 1023px) {
  .stats-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  .stat-card {
    padding: 36px 28px;
  }

  /* Re-draw dividers as borders on the grid */
  .stat-divider {
    display: none;
  }

  .stat-card:nth-child(odd) {
    border-right: 1px solid rgba(255, 255, 255, 0.07);
  }

  .stat-card:nth-child(-n+2) {
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }
}

@media (max-width: 599px) {
  .stats-inner {
    grid-template-columns: 1fr 1fr;
  }

  .stat-card {
    padding: 28px 16px;
  }

  .stat-num {
    font-size: 2.2rem;
  }

  .stat-label {
    font-size: 0.58rem;
    letter-spacing: 0.14em;
  }
}

/* Respect reduced motion */
@media (prefers-reduced-motion: reduce) {
  .stat-card {
    opacity: 1;
    transform: none;
    transition: none;
  }
}
</style>
