---
import { getImage } from "astro:assets";
import omoLogo from "../assets/omo_logo.png";

const omoLogoSrc = (await getImage({ src: omoLogo, format: "webp" })).src;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-brand">
    <img src={omoLogoSrc} alt="OMO Group" class="footer-mark-img" />
  </div>

  <div class="footer-contacts">
    <a href="mailto:advisory@omogroup.my" class="cta-contact">
      <div class="cta-contact-icon">
        <svg viewBox="0 0 24 24">
          <path
            d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
          ></path>
          <polyline points="22,6 12,13 2,6"></polyline>
        </svg>
      </div>
      <div class="cta-contact-text">
        <span class="cta-contact-label">Email</span>
        <span class="cta-contact-value">advisory@omogroup.my</span>
      </div>
    </a>

    <a
      href="https://wa.me/601165178808"
      class="cta-contact"
      target="_blank"
      rel="noopener"
    >
      <div class="cta-contact-icon">
        <svg viewBox="0 0 24 24">
          <path
            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.44 2 2 0 0 1 3.57 1.25h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.81a16 16 0 0 0 6.29 6.29l.87-.87a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"
          ></path>
        </svg>
      </div>
      <div class="cta-contact-text">
        <span class="cta-contact-label">WhatsApp</span>
        <span class="cta-contact-value">Chat with us</span>
      </div>
    </a>

    <a
      href="https://www.linkedin.com/company/omo-group"
      class="cta-contact"
      target="_blank"
      rel="noopener"
    >
      <div class="cta-contact-icon">
        <svg viewBox="0 0 24 24">
          <path
            d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
          ></path>
          <rect x="2" y="9" width="4" height="12"></rect>
          <circle cx="4" cy="4" r="2"></circle>
        </svg>
      </div>
      <div class="cta-contact-text">
        <span class="cta-contact-label">LinkedIn</span>
        <span class="cta-contact-value">OMO Group</span>
      </div>
    </a>
  </div>

  <span class="footer-copy">
    © {year} OMO Group Sdn. Bhd. · All rights reserved.
  </span>
</footer>

<style>
  .footer-contacts {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  @media (max-width: 1024px) {
    .site-footer {
      flex-direction: column;
      align-items: center;
      gap: 1.8rem;
      text-align: center;
      padding: 2.5rem 1.5rem;
    }
  }
</style>
