<section id="seven-partners" class="section reveal">
    <style>
      /* --- Custom CSS for Seven Partners Section --- */
      #seven-partners {
        background-color: #ffffff;
        padding: 5rem 1.5rem;
        overflow: hidden;
      }

      @media (min-width: 1024px) {
        #seven-partners {
          padding: 7rem 3rem;
        }
      }

      .seven-partners-container {
        max-width: 1400px;
        margin: 0 auto;
      }

      .seven-partners-header {
        text-align: center;
        margin-bottom: 4rem;
      }

      .seven-partners-title {
        font-family: 'DM Serif Display', Georgia, serif;
        font-size: clamp(1.875rem, 4vw, 3.375rem);
        /* 30px to 54px */
        font-weight: 800;
        line-height: 1.06;
        color: #111111;
        letter-spacing: -0.025em;
        margin-bottom: 1rem;
      }

      .seven-partners-desc {
        font-family: 'DM Sans', sans-serif;
        font-size: clamp(0.875rem, 1.5vw, 1rem);
        /* 14px to 16px */
        color: #6f6f6f;
        line-height: 1.75;
        max-width: 580px;
        margin: 0 auto;
      }

      .seven-partners-diagram-wrap {
        position: relative;
        width: 100%;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }

      @media (min-width: 1024px) {
        .seven-partners-diagram-wrap {
          overflow-x: visible;
        }
      }

      .seven-partners-diagram-inner {
        min-width: 1200px;
      }

      @media (min-width: 1024px) {
        .seven-partners-diagram-inner {
          min-width: 0;
        }
      }

      #seven-partners svg {
        width: 100%;
        height: auto;
        display: block;
      }

      #seven-partners text {
        font-family: 'DM Sans', sans-serif !important;
      }

      .seven-partners-caption-wrap {
        text-align: center;
        margin-top: 3rem;
      }

      .seven-partners-caption-text {
        font-family: 'DM Sans', sans-serif;
        font-size: clamp(0.875rem, 1.5vw, 0.9375rem);
        /* 14px to 15px */
        color: #6f6f6f;
        line-height: 1.75;
        max-width: 700px;
        margin: 0 auto;
      }

      /* --- Horizontal timeline draw animation --- */
      @keyframes draw-timeline {
        0% {
          stroke-dashoffset: 3000;
        }

        100% {
          stroke-dashoffset: 0;
        }
      }

      .timeline-path {
        stroke-dasharray: 3000;
        stroke-dashoffset: 3000;
      }

      /* Trigger path draw and continuous glow ONLY when scrolled into view */
      #seven-partners.visible .timeline-path,
      #seven-partners.in .timeline-path {
        animation:
          draw-timeline 3.8s linear forwards,
          timeline-glow 2.5s ease-in-out infinite 3.8s;
      }

      /* --- Card pop-in scale-up keyframe (Robust SVG Syntax) --- */
      @keyframes pop-card {
        0% {
          opacity: 0;
          transform: scale(0.85) translate(0, 18px);
        }

        100% {
          opacity: 1;
          transform: scale(1) translate(0, 0);
        }
      }

      .pop-card {
        opacity: 0;
        transform-box: fill-box;
        transform-origin: center;
      }

      /* Trigger node pop ONLY when scrolled into view */
      #seven-partners.visible .pop-card,
      #seven-partners.in .pop-card {
        animation: pop-card 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
      }

      /* --- Chronological Delays in sync with Timeline --- */
      .delay-p1 {
        animation-delay: 0.15s;
      }

      .delay-c1 {
        animation-delay: 0.3s;
      }

      .delay-p2 {
        animation-delay: 0.42s;
      }

      .delay-c2 {
        animation-delay: 0.65s;
      }

      .delay-p3 {
        animation-delay: 1.28s;
      }

      .delay-c3 {
        animation-delay: 1.6s;
      }

      .delay-p4 {
        animation-delay: 2.02s;
      }

      .delay-c4 {
        animation-delay: 2.3s;
      }

      .delay-p5 {
        animation-delay: 3.01s;
      }

      .delay-c5 {
        animation-delay: 3.15s;
      }

      .delay-p6 {
        animation-delay: 3.31s;
      }

      /* --- Ambience & Pulsing Chevron --- */
      @keyframes timeline-glow {

        0%,
        100% {
          filter: drop-shadow(0 0 3px rgba(239, 68, 68, 0.2)) drop-shadow(0 0 8px rgba(239, 68, 68, 0.2));
          opacity: 0.9;
        }

        50% {
          filter: drop-shadow(0 0 6px rgba(239, 68, 68, 0.45)) drop-shadow(0 0 15px rgba(239, 68, 68, 0.35));
          opacity: 1;
        }
      }

      @keyframes pop-chevron {
        0% {
          opacity: 0;
          transform: scale(0.5);
        }

        100% {
          opacity: 1;
          transform: scale(1);
        }
      }

      @keyframes chevron-pulse {

        0%,
        100% {
          opacity: 0.8;
          transform: scale(1);
        }

        50% {
          opacity: 1;
          transform: scale(1.18);
        }
      }

      .ebt {
        opacity: 0;
        transform-box: fill-box;
        transform-origin: center;
      }

      /* Trigger chevron pop and pulsing ONLY when scrolled into view */
      #seven-partners.visible .ebt,
      #seven-partners.in .ebt {
        animation: pop-chevron 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards,
          chevron-pulse 2.0s ease-in-out infinite 0.5s;
      }

      /* --- Vertical/Diagonal Connector Lines --- */
      .connector-line {
        opacity: 0;
        stroke-dasharray: 150;
        stroke-dashoffset: 150;
      }

      #seven-partners.visible .connector-line,
      #seven-partners.in .connector-line {
        opacity: 1;
        animation: draw-connector 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
      }

      @keyframes draw-connector {
        from {
          stroke-dashoffset: 150;
        }

        to {
          stroke-dashoffset: 0;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .timeline-path {
          animation: none;
          stroke-dashoffset: 0;
        }

        .pop-card {
          animation: none;
          opacity: 1;
          transform: none;
        }

        .ebt {
          animation: none;
          opacity: 1;
          transform: none;
        }
      }
    </style>

    <div class="seven-partners-container">
      <!-- Header -->
      <div class="reveal seven-partners-header">
        <h2 class="seven-partners-title">
          Six Partners. One Ecosystem.
        </h2>
        <p class="seven-partners-desc">
          A coordinated growth architecture connecting six specialised partners across incorporation, marketing,
          technology, operations, and business networks.
        </p>
      </div>

      <!-- Main Diagram Container -->
      <div class="reveal d1 seven-partners-diagram-wrap">
        <div class="seven-partners-diagram-inner">
          <svg class="w-full h-auto" viewBox="0 -10 1400 500" fill="none" xmlns="http://www.w3.org/2000/svg"
            aria-label="Six Partners Schedule Timeline">
            <defs>
              <!-- Ambient Red Glow Filter -->
              <filter id="rglow" x="-30%" y="-30%" width="160%" height="160%">
                <feGaussianBlur stdDeviation="7" result="blur" />
                <feFlood flood-color="#ef4444" flood-opacity="0.25" result="flood" />
                <feComposite in="flood" in2="blur" operator="in" result="glow" />
                <feMerge>
                  <feMergeNode in="glow" />
                  <feMergeNode in="SourceGraphic" />
                </feMerge>
              </filter>

              <!-- Node Shadow Filter -->
              <filter id="node-shadow" x="-20%" y="-20%" width="140%" height="140%">
                <feDropShadow dx="0" dy="6" stdDeviation="6" flood-color="#000000" flood-opacity="0.12" />
              </filter>
            </defs>

            <!-- ── BACKGROUND TIMELINE TRACK (Always Visible, Sleek & Semi-Transparent) ── -->
            <path
              d="M 0 380 H 420 C 540 380, 840 330, 840 210 C 840 -10, 520 -10, 520 210 C 520 330, 820 380, 940 380 H 1400"
              stroke="rgba(239, 68, 68, 0.12)" stroke-width="32" stroke-linecap="round" stroke-linejoin="round"
              fill="none" />

            <!-- ── ACTIVE PROGRESS PATH (Draws Left-to-Right on Scroll, Glowing) ── -->
            <path class="timeline-path"
              d="M 0 380 H 420 C 540 380, 840 330, 840 210 C 840 -10, 520 -10, 520 210 C 520 330, 820 380, 940 380 H 1400"
              stroke="#ef4444" stroke-width="6" stroke-linecap="round" fill="none" />

            <!-- ── VERTICAL/DIAGONAL CONNECTOR LINES (Color-Coded & Animating Upwards) ── -->
            <line class="connector-line delay-p1" x1="100" y1="352" x2="100" y2="270" stroke="#a855f7" stroke-width="2"
              stroke-linecap="round" stroke-dasharray="4 4" />
            <line class="connector-line delay-p2" x1="280" y1="352" x2="280" y2="285" stroke="#ec4899" stroke-width="2"
              stroke-linecap="round" stroke-dasharray="4 4" />
            <line class="connector-line delay-p3" x1="854" y1="160" x2="920" y2="155" stroke="#06b6d4" stroke-width="2"
              stroke-linecap="round" stroke-dasharray="4 4" />
            <line class="connector-line delay-p4" x1="506" y1="160" x2="440" y2="155" stroke="#3b82f6" stroke-width="2"
              stroke-linecap="round" stroke-dasharray="4 4" />
            <line class="connector-line delay-p5" x1="1080" y1="352" x2="1080" y2="270" stroke="#f97316"
              stroke-width="2" stroke-linecap="round" stroke-dasharray="4 4" />
            <line class="connector-line delay-p6" x1="1280" y1="352" x2="1280" y2="270" stroke="#eab308"
              stroke-width="2" stroke-linecap="round" stroke-dasharray="4 4" />

            <!-- ── TIMELINE HEX NODES (with White Border & Drop Shadow) ── -->
            <!-- Hex node 1 — Purple (OneKey Biz / Chess Knight) -->
            <g transform="translate(76,352)">
              <g class="pop-card delay-p1" filter="url(#node-shadow)">
                <polygon points="24,0 48,14 48,42 24,56 0,42 0,14" fill="#a855f7" stroke="#ffffff" stroke-width="3"
                  stroke-linejoin="round" />
                <!-- White Chess Knight Icon -->
                <g transform="translate(12, 12)" fill="white">
                  <path
                    d="M19.5,4.5 C18.5,3.2 16.5,2.1 14.5,1.5 C12.5,0.9 9.5,1.2 8.5,2.5 C7.5,3.8 7.2,5.5 6.5,6.5 C5.8,7.5 4.5,8.2 3.5,9.2 C2.5,10.2 1.5,11.5 1.1,13.2 C0.7,14.9 1.1,16.5 2.1,17.2 C3.1,17.9 4.8,17.2 5.5,16.2 C6.2,15.2 6.5,13.5 7.5,13.5 C8.5,13.5 9.5,15.2 10.5,16.2 C11.5,17.2 13.2,17.9 14.9,17.9 L 14.9,20.5 L 3.5,20.5 L 3.5,22.5 L 20.5,22.5 L 20.5,14.5 C20.5,11.5 20.5,6.5 19.5,4.5 Z" />
                </g>
              </g>
            </g>

            <!-- Hex node 2 — Pink (OMO / Gear) -->
            <g transform="translate(256,352)">
              <g class="pop-card delay-p2" filter="url(#node-shadow)">
                <polygon points="24,0 48,14 48,42 24,56 0,42 0,14" fill="#ec4899" stroke="#ffffff" stroke-width="3"
                  stroke-linejoin="round" />
                <!-- White Gear Icon -->
                <g transform="translate(12, 12)" fill="none" stroke="white" stroke-width="2.2">
                  <circle cx="12" cy="12" r="4.5" />
                  <path
                    d="M12,2 L12,5 M12,19 L12,22 M2,12 L5,12 M19,12 L22,12 M5,5 L7,7 M17,17 L19,19 M5,19 L7,17 M17,5 L19,7"
                    stroke-linecap="round" />
                </g>
              </g>
            </g>

            <!-- Hex node 3 — Cyan (TikStar / shopping bag) -->
            <g transform="translate(806,132)">
              <g class="pop-card delay-p3" filter="url(#node-shadow)">
                <polygon points="24,0 48,14 48,42 24,56 0,42 0,14" fill="#06b6d4" stroke="#ffffff" stroke-width="3"
                  stroke-linejoin="round" />
                <!-- White Shopping Bag Icon -->
                <g transform="translate(12, 12)" fill="none" stroke="white" stroke-width="2" stroke-linecap="round">
                  <rect x="5" y="8" width="14" height="13" rx="2" />
                  <path d="M9 8 C9 5 10 3 12 3 C14 3 15 5 15 8" />
                </g>
              </g>
            </g>

            <!-- Hex node 4 — Blue (Communication 21 / database chart) -->
            <g transform="translate(506,132)">
              <g class="pop-card delay-p4" filter="url(#node-shadow)">
                <polygon points="24,0 48,14 48,42 24,56 0,42 0,14" fill="#3b82f6" stroke="#ffffff" stroke-width="3"
                  stroke-linejoin="round" />
                <!-- White Database Icon -->
                <g transform="translate(12, 12)" fill="none" stroke="white" stroke-width="2" stroke-linecap="round">
                  <ellipse cx="12" cy="5" rx="7" ry="2.5" />
                  <path d="M5 5 V11 C5 12.4 8.1 13.5 12 13.5 C15.9 13.5 19 12.4 19 11 V5" />
                  <path d="M5 11 V17 C5 18.4 8.1 19.5 12 19.5 C15.9 19.5 19 18.4 19 17 V11" />
                </g>
              </g>
            </g>

            <!-- Hex node 5 — Orange (ct21 / rocket) -->
            <g transform="translate(1056,352)">
              <g class="pop-card delay-p5" filter="url(#node-shadow)">
                <polygon points="24,0 48,14 48,42 24,56 0,42 0,14" fill="#f97316" stroke="#ffffff" stroke-width="3"
                  stroke-linejoin="round" />
                <!-- White Rocket Icon -->
                <g transform="translate(12, 12)" fill="none" stroke="white" stroke-width="2" stroke-linecap="round">
                  <path d="M12 2 C15 5 17 9 17 14 L17 19 L7 19 L7 14 C7 9 9 5 12 2 Z" />
                  <path d="M9 19 L7 22 L11 20" />
                  <path d="M15 19 L17 22 L13 20" />
                </g>
              </g>
            </g>

            <!-- Hex node 6 — Yellow (YCM / star) -->
            <g transform="translate(1256,352)">
              <g class="pop-card delay-p6" filter="url(#node-shadow)">
                <polygon points="24,0 48,14 48,42 24,56 0,42 0,14" fill="#eab308" stroke="#ffffff" stroke-width="3"
                  stroke-linejoin="round" />
                <!-- White Star Icon -->
                <g transform="translate(12, 12)" fill="white">
                  <path d="M12 2 L14.8 8.5 L21.8 9.3 L16.5 14 L18.1 21 L12 17.3 L5.9 21 L7.5 14 L2.2 9.3 L9.2 8.5 Z" />
                </g>
              </g>
            </g>

            <!-- ── GIANT FLOW CHEVRONS (Overlaid on Timeline) ── -->
            <g class="ebt delay-c1">
              <path d="M 195 366 L 215 380 L 195 394" fill="none" stroke="#ef4444" stroke-width="8"
                stroke-linecap="round" stroke-linejoin="round" />
            </g>
            <g class="ebt delay-c2">
              <path d="M 472 365 L 490 376 L 476 392" fill="none" stroke="#ef4444" stroke-width="8"
                stroke-linecap="round" stroke-linejoin="round" />
            </g>
            <g class="ebt delay-c3">
              <path d="M 690 31 L 670 45 L 690 59" fill="none" stroke="#ef4444" stroke-width="8" stroke-linecap="round"
                stroke-linejoin="round" />
            </g>
            <g class="ebt delay-c4">
              <path d="M 870 364 L 890 378 L 868 389" fill="none" stroke="#ef4444" stroke-width="8"
                stroke-linecap="round" stroke-linejoin="round" />
            </g>
            <g class="ebt delay-c5">
              <path d="M 1170 366 L 1190 380 L 1170 394" fill="none" stroke="#ef4444" stroke-width="8"
                stroke-linecap="round" stroke-linejoin="round" />
            </g>


            <!-- ── BARE STANDALONE LOGOS (Top Half) ── -->
            <!-- ── PARTNER 1: ONEKEY BIZ ── -->
            <g class="pop-card delay-p1">
              <image class="card-logo" href="assets/ONEBiz_Logo.png" x="70" y="130" width="60" height="60"
                preserveAspectRatio="xMidYMid meet" />
              <text x="100" y="215" text-anchor="middle" font-size="13" font-weight="800" fill="#111111"
                letter-spacing="0.5">ONEKEY BIZ</text>
              <text x="100" y="235" text-anchor="middle" font-size="11.5" font-weight="500" fill="#111111">Company
                Incorporation &amp;</text>
              <text x="100" y="250" text-anchor="middle" font-size="11.5" font-weight="500" fill="#111111">Corporate
                Secretarial Services</text>
            </g>

            <!-- ── PARTNER 2: OMO DESIGN ── -->
            <g class="pop-card delay-p2">
              <image class="card-logo" href="assets/omo_logo.png" x="245" y="130" width="70" height="60"
                preserveAspectRatio="xMidYMid meet" />
              <text x="280" y="215" text-anchor="middle" font-size="13" font-weight="800" fill="#111111"
                letter-spacing="0.5">OMO</text>
              <text x="280" y="235" text-anchor="middle" font-size="11.5" font-weight="500" fill="#111111">Design &amp;
                Advertising</text>
              <text x="280" y="250" text-anchor="middle" font-size="11.5" font-weight="500" fill="#111111">Lead
                Generation, Marketing &amp;</text>
              <text x="280" y="265" text-anchor="middle" font-size="11.5" font-weight="500" fill="#111111">Brand
                Growth</text>
            </g>

            <!-- ── PARTNER 3: TIKSTAR ── -->
            <g class="pop-card delay-p3">
              <image class="card-logo" href="assets/tikstar_logo.png" x="890" y="50" width="60" height="60"
                preserveAspectRatio="xMidYMid meet" />
              <text x="920" y="135" text-anchor="middle" font-size="13" font-weight="800" fill="#111111"
                letter-spacing="0.5">TIKSTAR</text>
              <text x="920" y="155" text-anchor="middle" font-size="11.5" font-weight="500" fill="#111111">E-commerce
                Hub</text>
            </g>

            <!-- ── PARTNER 4: COMMUNICATION 21 ── -->
            <g class="pop-card delay-p4">
              <image class="card-logo" href="assets/Communication21-LOGO_ICON-RED.png" x="410" y="20"
                width="60" height="60" preserveAspectRatio="xMidYMid meet" />
              <text x="440" y="105" text-anchor="middle" font-size="13" font-weight="800" fill="#111111">Communication
                21</text>
              <text x="440" y="125" text-anchor="middle" font-size="11.5" font-weight="500" fill="#111111">AI Systems
                &amp; Solutions</text>
              <text x="440" y="140" text-anchor="middle" font-size="10.5" font-weight="500" fill="#6f6f6f">with 22
                Million ASEAN</text>
              <text x="440" y="153" text-anchor="middle" font-size="10.5" font-weight="500" fill="#6f6f6f">Database
                Resources</text>
            </g>

            <!-- ── PARTNER 5: ct21 ── -->
            <g class="pop-card delay-p5">
              <image class="card-logo" href="assets/OT21_Black.png" x="1050" y="130" width="60" height="60"
                preserveAspectRatio="xMidYMid meet" />
              <text x="1080" y="215" text-anchor="middle" font-size="14" font-weight="900" fill="#111111">ct21</text>
              <text x="1080" y="235" text-anchor="middle" font-size="11.5" font-weight="500" fill="#111111">SKM Digital
                Marketing</text>
              <text x="1080" y="250" text-anchor="middle" font-size="11.5" font-weight="500" fill="#111111">&amp; AI
                Academy</text>
            </g>

            <!-- ── PARTNER 6: YOUNG CORPORATE MALAYSIANS ── -->
            <g class="pop-card delay-p6">
              <image class="card-logo" href="assets/YCM_logo.png" x="1250" y="130" width="60" height="60"
                preserveAspectRatio="xMidYMid meet" />
              <text x="1280" y="215" text-anchor="middle" font-size="13" font-weight="800" fill="#111111">Young
                Corporate</text>
              <text x="1280" y="229" text-anchor="middle" font-size="13" font-weight="800"
                fill="#111111">Malaysians</text>
              <text x="1280" y="246" text-anchor="middle" font-size="11" font-weight="500" fill="#111111">Organisation
                &amp; Business</text>
              <text x="1280" y="259" text-anchor="middle" font-size="11" font-weight="500" fill="#111111">Network
                Resources</text>
            </g>
          </svg>
        </div>
      </div>

      <!-- Bottom caption -->
      <div class="reveal d2 seven-partners-caption-wrap">
        <p class="seven-partners-caption-text">
          Build an interconnected business ecosystem across ASEAN with hands-on support and design-led strategy for
          every stage of market expansion.
        </p>
      </div>
    </div>
  </section>

