<script define:vars={{ partners }}>
  (function () {
    const card = document.getElementById("partnerCard");
    const closeBtn = document.getElementById("cardClose");

    const mLogo = document.getElementById("cardLogo");
    const mLogoPlaceholder = document.getElementById("cardLogoPlaceholder");
    const mLogoWrap = document.getElementById("cardLogoWrap");
    const mNum = document.getElementById("cardNum");
    const mBrand = document.getElementById("cardBrand");
    const mName = document.getElementById("cardName");
    const mDesc = document.getElementById("cardDesc");
    const mLinkBtn = document.getElementById("cardLinkBtn");
    const mLinkText = document.getElementById("cardLinkText");

    const innerContainer = document.querySelector(
      ".seven-partners-diagram-inner",
    );
    const wrapContainer = document.querySelector(
      ".seven-partners-diagram-wrap",
    );

    const origins = {
      onebiz: { x: "6.25%", y: "76%" },
      omo: { x: "17.5%", y: "76%" },
      comm21: { x: "33.125%", y: "32%" },
      tikstar: { x: "51.875%", y: "32%" },
      ot21: { x: "67.5%", y: "76%" },
      gladiolus: { x: "80.0%", y: "76%" },
      ycm: { x: "92.5%", y: "76%" },
    };

    const cardPositions = {
      onebiz: { left: "12.8125%", top: "22%" },
      omo: { left: "24.375%", top: "22%" },
      comm21: { left: "33.4375%", top: "4%" },
      tikstar: { left: "35.9375%", top: "4%" },
      ot21: { left: "44.6875%", top: "22%" },
      gladiolus: { left: "56.25%", top: "22%" },
      ycm: { left: "69.0625%", top: "22%" },
    };

    if (!card || !closeBtn) return;

    const partnerData = {};
    partners.forEach((p) => {
      partnerData[p.id] = p;
    });

    let clickOutsideHandlerAttached = false;

    function openCard(id) {
      const data = partnerData[id];
      if (!data) return;

      // Reset state from previous opens
      card.classList.remove("active");
      const backdropEl = document.getElementById("partnerCardBackdrop");
      if (backdropEl) backdropEl.classList.remove("active");

      const isMobile = window.innerWidth <= 1023;

      // 1. Cinematic Zoom-in (desktop only)
      if (!isMobile) {
        const coords = origins[id];
        if (coords && innerContainer) {
          if (wrapContainer) wrapContainer.classList.add("zoomed-state");
          innerContainer.style.transformOrigin = `${coords.x} ${coords.y}`;
          innerContainer.classList.add("zoomed");
        }
      }

      // 2. Position the card relative to the clicked partner (desktop only)
      if (!isMobile) {
        const pos = cardPositions[id];
        if (pos) {
          card.style.left = pos.left;
          card.style.top = pos.top;
        }
      } else {
        card.style.left = "";
        card.style.top = "";
      }

      // 3. Load Card Data
      if (mLogo && mLogoPlaceholder) {
        if (data.logoSrc) {
          mLogo.src = data.logoSrc;
          mLogo.alt = data.brand;
          mLogo.style.display = "block";
          mLogoPlaceholder.style.display = "none";
        } else {
          mLogo.style.display = "none";
          mLogoPlaceholder.textContent = data.brand
            .split(" ")
            .map((w) => w[0])
            .join("")
            .substring(0, 2)
            .toUpperCase();
          mLogoPlaceholder.style.display = "block";
        }
      }
      if (mLogoWrap) {
        if (data.logoDark) {
          mLogoWrap.classList.add("logo-dark-bg");
        } else {
          mLogoWrap.classList.remove("logo-dark-bg");
        }
      }
      if (mNum) mNum.textContent = `Partner ${data.num}`;
      if (mBrand) mBrand.textContent = data.brand;
      if (mName) mName.textContent = data.name;
      if (mDesc) mDesc.textContent = data.desc;

      if (mLinkBtn && mLinkText) {
        if (data.url) {
          mLinkBtn.href = data.url;
          mLinkText.textContent = data.btnText || "Learn more";
          mLinkBtn.style.display = "inline-flex";
        } else {
          mLinkBtn.style.display = "none";
        }
      }

      if (data.accent) {
        card.style.setProperty("--card-accent", data.accent + "25");
        card.style.setProperty("--card-accent-label", data.accent);
      } else {
        card.style.setProperty("--card-accent", "rgba(239, 68, 68, 0.15)");
        card.style.setProperty("--card-accent-label", "#ef4444");
      }

      // 4. Open Card after Cinematic Zoom decelerates (or immediately on mobile)
      const delay = isMobile ? 50 : 700;
      setTimeout(() => {
        card.classList.add("active");
        card.setAttribute("aria-hidden", "false");
        if (isMobile && backdropEl) {
          backdropEl.classList.add("active");
          document.body.style.overflow = "hidden";
        }

        // Attach document listener on next tick to avoid capturing current click
        setTimeout(() => {
          if (!clickOutsideHandlerAttached) {
            document.addEventListener("click", outsideClickListener);
            clickOutsideHandlerAttached = true;
          }
        }, 50);
      }, delay);
    }

    function closeCard() {
      card.classList.remove("active");
      card.setAttribute("aria-hidden", "true");

      const backdropEl = document.getElementById("partnerCardBackdrop");
      if (backdropEl) backdropEl.classList.remove("active");
      document.body.style.overflow = "";

      // Remove click listener
      if (clickOutsideHandlerAttached) {
        document.removeEventListener("click", outsideClickListener);
        clickOutsideHandlerAttached = false;
      }

      // Cinematic Zoom-out
      if (innerContainer) {
        innerContainer.classList.remove("zoomed");
      }
      if (wrapContainer) {
        setTimeout(() => {
          wrapContainer.classList.remove("zoomed-state");
        }, 1400);
      }
    }

    function outsideClickListener(e) {
      const isCardClick = card.contains(e.target) || card === e.target;
      const isTriggerClick = e.target.closest(".partner-trigger");
      if (!isCardClick && !isTriggerClick) {
        closeCard();
      }
    }

    document.querySelectorAll(".partner-trigger").forEach((trigger) => {
      const id = trigger.getAttribute("data-partner-id");
      const data = partnerData[id];
      if (data && data.accent) {
        trigger.style.setProperty("--hover-accent", data.accent);
      }

      trigger.addEventListener("click", (e) => {
        e.preventDefault();
        openCard(id);
      });
    });

    closeBtn.addEventListener("click", closeCard);

    const backdropEl = document.getElementById("partnerCardBackdrop");
    if (backdropEl) {
      backdropEl.addEventListener("click", closeCard);
    }

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && card.classList.contains("active")) {
        closeCard();
      }
    });
  })();
</script>
