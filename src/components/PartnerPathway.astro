---
import { getImage } from "astro:assets";
import onebizLogo from "../assets/ONEBiz_Logo.png";
import omoLogo from "../assets/omo_logo.png";
import comm21Logo from "../assets/Communication21-LOGO_ICON-RED.png";
import tikstarLogo from "../assets/tikstar_logo.png";
import ot21Logo from "../assets/OT21_Black.png";
import ycmLogo from "../assets/YCM_logo.png";

/* Resolved to plain URL strings — logoSrc is serialized into the client
   script via define:vars and also used by SVG <image href>. */
const onebizLogoSrc = (await getImage({ src: onebizLogo, format: "webp" })).src;
const omoLogoSrc = (await getImage({ src: omoLogo, format: "webp" })).src;
const comm21LogoSrc = (await getImage({ src: comm21Logo, format: "webp" })).src;
const tikstarLogoSrc = (await getImage({ src: tikstarLogo, format: "webp" }))
  .src;
const ot21LogoSrc = (await getImage({ src: ot21Logo, format: "webp" })).src;
const ycmLogoSrc = (await getImage({ src: ycmLogo, format: "webp" })).src;

interface PartnerDetail {
  id: string;
  num: string;
  logoSrc: string;
  brand: string;
  name: string;
  desc: string;
  accent?: string;
  logoDark?: boolean;
  url?: string;
  btnText?: string;
}

const partners: PartnerDetail[] = [
  {
    id: "onebiz",
    num: "01",
    logoSrc: onebizLogoSrc,
    brand: "ONEBiz",
    name: "Business Formation, Compliance & Corporate Secretarial",
    desc: "Streamlined company incorporation, licensing, regulatory compliance, and corporate secretarial services. Provides the foundation for businesses entering ASEAN markets.",
    accent: "#a855f7",
    url: "https://onekeybiz.com",
    btnText: "Visit Website",
  },
  {
    id: "omo",
    num: "02",
    logoSrc: omoLogoSrc,
    brand: "OMO Group",
    name: "Corporate Advisory, Design & Strategy",
    desc: "The central hub of the OMO ecosystem — providing strategic advisory, market entry facilitation, and cross-border expansion support, design-led advertising, and brand growth solutions across ASEAN.",
    accent: "#ec4899",
    url: "https://omomarketingads.com/",
    btnText: "Visit Website",
  },
  {
    id: "comm21",
    num: "03",
    logoSrc: comm21LogoSrc,
    logoDark: true,
    brand: "Communication 21",
    name: "Media, PR & Brand Amplification",
    desc: "Integrated media relations, digital PR, and brand storytelling to build awareness and credibility across Southeast Asian markets. Leverages AI systems and solutions with 22 Million ASEAN database resources.",
    accent: "#3b82f6",
    url: "https://www.communication21.com",
    btnText: "Visit Website",
  },
  {
    id: "tikstar",
    num: "04",
    logoSrc: tikstarLogoSrc,
    brand: "TikStar",
    name: "Influencer, Social Commerce & E-commerce Hub",
    desc: "Performance-driven influencer marketing, social commerce strategy, and creator partnerships to fuel brand growth on TikTok and beyond. Operates as an integrated e-commerce hub.",
    accent: "#06b6d4",
    url: "https://www.facebook.com/share/v/187S5ozFuf/?mibextid=wwXIfr",
    btnText: "Watch Facebook Video",
  },
  {
    id: "ot21",
    num: "05",
    logoSrc: ot21LogoSrc,
    logoDark: true,
    brand: "OT21",
    name: "Technology, Digital Infrastructure & AI Academy",
    desc: "Enterprise technology solutions, AI integration, and digital transformation services to modernise operations and unlock scalable growth. Integrates SKM digital marketing and AI academy.",
    accent: "#f97316",
    url: "https://asiaoceanacademy.com.my",
    btnText: "Visit Website",
  },
  {
    id: "gladiolus",
    num: "06",
    logoSrc: "",
    brand: "Gladiolus Capital",
    name: "Funder & VC Ecosystem Collaboration",
    desc: "Venture capital access, investor relations, and fund structuring support to connect high-growth businesses with the right capital partners.",
    accent: "#cfa126",
    url: "https://gladioluscapital.com/",
    btnText: "Visit Website",
  },
  {
    id: "ycm",
    num: "07",
    logoSrc: ycmLogoSrc,
    brand: "YCM (Young Corporate Malaysians)",
    name: "Creative Production, Content & Network Resources",
    desc: "Full-service creative production — from photography and videography to brand content strategies that resonate with regional audiences. Connected with extensive organisation and business network resources.",
    accent: "#eab308",
    url: "https://www.facebook.com/share/1D2cU6uSfh/?mibextid=wwXIfr",
    btnText: "Visit Facebook Page",
  },
];
---

<section id="seven-partners" class="section reveal">
  <style>
    /* --- Custom CSS for Seven Partners Section --- */
    #seven-partners {
      background-color: #ffffff;
      padding: 5rem 1.5rem 9rem 1.5rem; /* Extra bottom padding for mobile overlap */
      overflow: hidden;
    }

    @media (min-width: 1024px) {
      #seven-partners {
        padding: 7rem 3rem 13rem 3rem; /* Extra bottom padding for desktop overlap */
      }
    }

    .seven-partners-container {
      max-width: 1400px;
      margin: 0 auto;
    }

    .seven-partners-header {
      text-align: center;
      margin-bottom: 4rem;
    }

    .seven-partners-title {
      font-family: "DM Serif Display", Georgia, serif;
      font-size: clamp(1.875rem, 4vw, 3.375rem);
      /* 30px to 54px */
      font-weight: 800;
      line-height: 1.06;
      color: #111111;
      letter-spacing: -0.025em;
      margin-bottom: 1rem;
    }

    .seven-partners-desc {
      font-family: "DM Sans", sans-serif;
      font-size: clamp(0.875rem, 1.5vw, 1rem);
      /* 14px to 16px */
      color: #6f6f6f;
      line-height: 1.75;
      max-width: 760px;
      margin: 0 auto;
    }

    .click-hint-wrapper {
      margin-top: 1.5rem;
      display: flex;
      justify-content: center;
    }

    .click-hint {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: "DM Sans", sans-serif;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #ed4823;
      background: rgba(237, 72, 35, 0.05);
      padding: 0.45rem 1.1rem;
      border-radius: 100px;
      border: 1px solid rgba(237, 72, 35, 0.15);
      margin: 0;
      position: relative;
      animation: pillPulse 2s infinite ease-in-out;
    }

    @keyframes pillPulse {
      0%,
      100% {
        box-shadow: 0 0 0 0 rgba(237, 72, 35, 0);
      }
      50% {
        box-shadow: 0 0 10px 2px rgba(237, 72, 35, 0.12);
      }
    }

    .mouse-icon {
      width: 14px !important;
      height: 14px !important;
      color: #ed4823;
      display: inline-block;
      flex-shrink: 0;
      animation: mouseFloat 1.8s infinite ease-in-out;
    }

    .mouse-icon .wheel {
      animation: mouseWheelMove 1.6s infinite ease-in-out;
    }

    @keyframes mouseFloat {
      0%,
      100% {
        transform: translateY(0);
      }
      50% {
        transform: translateY(-2px);
      }
    }

    @keyframes mouseWheelMove {
      0% {
        transform: translateY(-2px);
        opacity: 0;
      }
      20% {
        transform: translateY(0);
        opacity: 1;
      }
      80% {
        transform: translateY(4px);
        opacity: 1;
      }
      100% {
        transform: translateY(6px);
        opacity: 0;
      }
    }

    .seven-partners-diagram-wrap {
      position: relative;
      width: 100%;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      transition: overflow 0.3s ease;
    }

    .seven-partners-diagram-wrap.zoomed-state {
      overflow: visible !important;
    }

    @media (min-width: 1024px) {
      .seven-partners-diagram-wrap {
        overflow-x: visible;
      }
    }

    .seven-partners-diagram-inner {
      position: relative;
      min-width: 1500px;
      transition:
        transform 1.3s cubic-bezier(0.16, 1, 0.3, 1),
        transform-origin 1.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @media (min-width: 1024px) {
      .seven-partners-diagram-inner {
        min-width: 0;
      }
    }

    .seven-partners-diagram-inner.zoomed {
      transform: scale(1.6);
    }

    #seven-partners svg {
      width: 100%;
      height: auto;
      display: block;
    }

    #seven-partners text {
      font-family: "DM Sans", sans-serif !important;
    }

    .seven-partners-caption-wrap {
      text-align: center;
      margin-top: 3rem;
    }

    .seven-partners-caption-text {
      font-family: "DM Sans", sans-serif;
      font-size: clamp(0.875rem, 1.5vw, 0.9375rem);
      /* 14px to 15px */
      color: #6f6f6f;
      line-height: 1.75;
      max-width: 700px;
      margin: 0 auto;
    }

    /* --- Horizontal timeline draw animation --- */
    @keyframes draw-timeline {
      0% {
        stroke-dashoffset: 3000;
      }

      100% {
        stroke-dashoffset: 0;
      }
    }

    .timeline-path {
      stroke-dasharray: 3000;
      stroke-dashoffset: 3000;
    }

    /* Trigger path draw and continuous glow ONLY when scrolled into view */
    #seven-partners.visible .timeline-path,
    #seven-partners.in .timeline-path {
      animation:
        draw-timeline 3.8s linear forwards,
        timeline-glow 2.5s ease-in-out infinite 3.8s;
    }

    /* --- Card pop-in scale-up keyframe (Robust SVG Syntax) --- */
    @keyframes pop-card {
      0% {
        opacity: 0;
        transform: scale(0.85) translate(0, 18px);
      }

      100% {
        opacity: 1;
        transform: scale(1) translate(0, 0);
      }
    }

    .pop-card {
      opacity: 0;
      transform-box: fill-box;
      transform-origin: center;
    }

    /* Trigger node pop ONLY when scrolled into view */
    #seven-partners.visible .pop-card,
    #seven-partners.in .pop-card {
      animation: pop-card 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }

    /* --- Chronological Delays in sync with Timeline --- */
    .delay-p1 {
      animation-delay: 0.15s;
    }

    .delay-c1 {
      animation-delay: 0.3s;
    }

    .delay-p2 {
      animation-delay: 0.42s;
    }

    .delay-c2 {
      animation-delay: 0.65s;
    }

    .delay-p3 {
      animation-delay: 1.28s;
    }

    .delay-c3 {
      animation-delay: 1.6s;
    }

    .delay-p4 {
      animation-delay: 2.02s;
    }

    .delay-c4 {
      animation-delay: 2.3s;
    }

    .delay-p5 {
      animation-delay: 3.01s;
    }

    .delay-c5 {
      animation-delay: 3.15s;
    }

    .delay-p6 {
      animation-delay: 3.31s;
    }

    .delay-c6 {
      animation-delay: 3.45s;
    }

    .delay-p7 {
      animation-delay: 3.61s;
    }

    /* --- Ambience & Pulsing Chevron --- */
    @keyframes timeline-glow {
      0%,
      100% {
        filter: drop-shadow(0 0 3px rgba(239, 68, 68, 0.2))
          drop-shadow(0 0 8px rgba(239, 68, 68, 0.2));
        opacity: 0.9;
      }

      50% {
        filter: drop-shadow(0 0 6px rgba(239, 68, 68, 0.45))
          drop-shadow(0 0 15px rgba(239, 68, 68, 0.35));
        opacity: 1;
      }
    }

    @keyframes pop-chevron {
      0% {
        opacity: 0;
        transform: scale(0.5);
      }

      100% {
        opacity: 1;
        transform: scale(1);
      }
    }

    @keyframes chevron-pulse {
      0%,
      100% {
        opacity: 0.8;
        transform: scale(1);
      }

      50% {
        opacity: 1;
        transform: scale(1.18);
      }
    }

    .ebt {
      opacity: 0;
      transform-box: fill-box;
      transform-origin: center;
    }

    /* Trigger chevron pop and pulsing ONLY when scrolled into view */
    #seven-partners.visible .ebt,
    #seven-partners.in .ebt {
      animation:
        pop-chevron 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards,
        chevron-pulse 2s ease-in-out infinite 0.5s;
    }

    /* --- Vertical/Diagonal Connector Lines --- */
    .connector-line {
      opacity: 0;
      stroke-dasharray: 150;
      stroke-dashoffset: 150;
    }

    #seven-partners.visible .connector-line,
    #seven-partners.in .connector-line {
      opacity: 1;
      animation: draw-connector 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94)
        forwards;
    }

    @keyframes draw-connector {
      from {
        stroke-dashoffset: 150;
      }

      to {
        stroke-dashoffset: 0;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .timeline-path {
        animation: none;
        stroke-dashoffset: 0;
      }

      .pop-card {
        animation: none;
        opacity: 1;
        transform: none;
      }

      .ebt {
        animation: none;
        opacity: 1;
        transform: none;
      }
    }

    /* --- Interactive Partner Pathway CSS --- */
    .partner-trigger {
      cursor: pointer;
    }
    /* On hover, style elements */
    .partner-trigger:hover polygon {
      stroke-width: 4.5px !important;
      filter: drop-shadow(0 0 10px rgba(0, 0, 0, 0.3));
      transition:
        stroke-width 0.25s ease,
        filter 0.25s ease;
    }
    .partner-trigger:hover image {
      filter: drop-shadow(0 0 8px rgba(0, 0, 0, 0.3));
      transition: filter 0.25s ease;
    }
    /* Subtle highlight on the corresponding text as well */
    .partner-trigger:hover text {
      fill: #ef4444 !important;
      transition: fill 0.25s ease;
    }

    /* Partner Card Styles (Placed beside the clicked logo inside SVG coordinate space) */
    .partner-card {
      position: absolute;
      z-index: 50;
      width: 270px;
      box-sizing: border-box;
      background: rgba(18, 18, 18, 0.95);
      border: 1px solid rgba(255, 255, 255, 0.12);
      box-shadow:
        0 15px 35px rgba(0, 0, 0, 0.4),
        0 0 20px var(--card-accent, rgba(239, 68, 68, 0.15));
      border-radius: 18px;
      padding: 1.25rem;
      color: #ffffff;
      opacity: 0;
      transform: scale(0.9) translateY(10px);
      transition:
        opacity 0.3s ease,
        transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
      pointer-events: none;
    }
    .partner-card.active {
      opacity: 1;
      transform: scale(1) translateY(0);
      pointer-events: auto;
    }

    /* Close button */
    .partner-card-close {
      position: absolute;
      top: 0.75rem;
      right: 0.75rem;
      background: rgba(255, 255, 255, 0.06);
      border: none;
      border-radius: 50%;
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: rgba(255, 255, 255, 0.6);
      transition: all 0.25s ease;
    }
    .partner-card-close:hover {
      background: rgba(239, 68, 68, 0.25);
      color: #ffffff;
      transform: rotate(90deg);
    }

    /* Layout details */
    .partner-card-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      padding-bottom: 0.75rem;
    }
    .partner-card-logo-wrap {
      width: 50px;
      height: 50px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 12px;
      padding: 6px;
      flex-shrink: 0;
      transition: all 0.3s ease;
    }
    .partner-card-logo-wrap.logo-dark-bg {
      background: #ffffff !important;
    }
    .partner-card-logo {
      max-width: 100%;
      max-height: 100%;
      object-fit: contain;
    }
    .partner-card-logo-placeholder {
      font-family: "DM Serif Display", Georgia, serif;
      font-size: 1.4rem;
      font-weight: 800;
      color: #ffffff;
      display: none;
      line-height: 1;
    }

    .partner-card-title-wrap {
      flex-grow: 1;
    }
    .partner-card-num {
      font-family: "DM Sans", sans-serif;
      font-weight: 800;
      color: var(--card-accent-label, #ef4444);
      font-size: 0.75rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 0.15rem;
      display: block;
    }
    .partner-card-brand {
      font-family: "DM Serif Display", Georgia, serif;
      font-size: 1.25rem;
      font-weight: 800;
      color: #ffffff;
      margin: 0;
      line-height: 1.2;
    }
    .partner-card-name {
      font-family: "DM Sans", sans-serif;
      font-size: 0.85rem;
      font-weight: 600;
      color: rgba(255, 255, 255, 0.7);
      margin: 0 0 0.75rem 0;
      line-height: 1.35;
    }
    .partner-card-desc {
      font-family: "DM Sans", sans-serif;
      font-size: 0.9rem;
      line-height: 1.5;
      color: rgba(255, 255, 255, 0.85);
      margin: 0;
    }

    /* Link Style (Italic Text Link) */
    .partner-card-link-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      margin-top: 1.25rem;
      color: var(--card-accent-label, #ed4823);
      font-family: "DM Sans", sans-serif;
      font-size: 0.92rem;
      text-decoration: none;
      transition: color 0.25s ease;
    }
    .partner-card-link-btn em {
      font-style: italic;
      font-weight: 500;
    }
    .partner-card-link-btn .arrow-symbol {
      font-family:
        system-ui,
        -apple-system,
        sans-serif;
      font-style: normal;
      font-size: 0.95rem;
      transition: transform 0.25s ease;
      display: inline-block;
    }
    .partner-card-link-btn:hover {
      color: #ffffff;
    }
    .partner-card-link-btn:hover .arrow-symbol {
      transform: translateX(4px);
    }

    /* --- Rolling Sphere Animation --- */
    .rolling-sphere-group {
      offset-path: path(
        "M 0 380 H 420 C 540 380, 840 330, 840 210 C 840 -10, 520 -10, 520 210 C 520 330, 820 380, 940 380 H 1600"
      );
      animation: roll-along 10s linear infinite;
      transform-box: fill-box;
      transform-origin: center;
    }

    @keyframes roll-along {
      0% {
        offset-distance: 0%;
      }
      100% {
        offset-distance: 100%;
      }
    }

    .rolling-sphere-glow {
      filter: drop-shadow(0 0 10px rgba(239, 68, 68, 0.95))
        drop-shadow(0 0 20px rgba(239, 68, 68, 0.6));
    }

    @media (max-width: 1023px) {
      .partner-card-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(10, 10, 10, 0.45);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        z-index: 10000;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
      }

      .partner-card-backdrop.active {
        opacity: 1;
        pointer-events: auto;
      }

      .partner-card {
        position: fixed !important;
        top: 50% !important;
        left: 50% !important;
        transform: translate(-50%, -50%) scale(0.9) !important;
        width: 90% !important;
        max-width: 440px !important;
        z-index: 10001 !important;
        opacity: 0 !important;
        pointer-events: none !important;
        margin: 0 !important;
        padding: 2rem !important; /* more padding for layout breathing space */
        box-shadow:
          0 20px 50px rgba(0, 0, 0, 0.5),
          0 0 30px var(--card-accent, rgba(239, 68, 68, 0.25)) !important;
        transition:
          opacity 0.3s ease,
          transform 0.3s cubic-bezier(0.16, 1, 0.3, 1) !important;
      }

      .partner-card.active {
        opacity: 1 !important;
        transform: translate(-50%, -50%) scale(1) !important;
        pointer-events: auto !important;
      }

      /* Optimize font sizing and ratios for mobile modal readability */
      .partner-card-close {
        width: 38px !important;
        height: 38px !important;
        top: 1.1rem !important;
        right: 1.1rem !important;
      }

      .partner-card-logo-wrap {
        width: 60px !important;
        height: 60px !important;
        border-radius: 14px !important;
        padding: 8px !important;
      }

      .partner-card-num {
        font-size: 0.95rem !important;
      }

      .partner-card-brand {
        font-size: 1.75rem !important;
      }

      .partner-card-name {
        font-size: 1.18rem !important;
        line-height: 1.45 !important;
        margin: 0 0 1.1rem 0 !important;
      }

      .partner-card-desc {
        font-size: 1.18rem !important;
        line-height: 1.65 !important;
      }

      .partner-card-link-btn {
        font-size: 1.15rem !important;
        margin-top: 1.65rem !important;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .rolling-sphere-group {
        animation: none;
        display: none;
      }
    }
  </style>

  <div class="seven-partners-container">
    <!-- Header -->
    <div class="reveal seven-partners-header">
      <h2 class="seven-partners-title">Seven Partners. One Ecosystem.</h2>
      <p class="seven-partners-desc">
        A coordinated growth architecture connecting seven specialised partners
        across incorporation, marketing, technology, capital funding,
        operations, and business networks.
      </p>
      <div class="click-hint-wrapper">
        <p class="click-hint">
          <svg
            class="mouse-icon"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="6" y="3" width="12" height="18" rx="6"></rect>
            <path d="M12 7v4" class="wheel"></path>
          </svg>
          Click the logo
        </p>
      </div>
    </div>

    <!-- Main Diagram Container -->
    <div class="reveal d1 seven-partners-diagram-wrap">
      <div class="seven-partners-diagram-inner">
        <svg
          class="w-full h-auto"
          viewBox="0 -10 1600 500"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-label="Seven Partners Schedule Timeline"
        >
          <defs>
            <!-- Ambient Red Glow Filter -->
            <filter id="rglow" x="-30%" y="-30%" width="160%" height="160%">
              <feGaussianBlur stdDeviation="7" result="blur"></feGaussianBlur>
              <feFlood flood-color="#ef4444" flood-opacity="0.25" result="flood"
              ></feFlood>
              <feComposite in="flood" in2="blur" operator="in" result="glow"
              ></feComposite>
              <feMerge>
                <feMergeNode in="glow"></feMergeNode>
                <feMergeNode in="SourceGraphic"></feMergeNode>
              </feMerge>
            </filter>

            <!-- Node Shadow Filter -->
            <filter
              id="node-shadow"
              x="-20%"
