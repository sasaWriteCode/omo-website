                paint-order="stroke"
                stroke="#fff"
                stroke-width="3"
                stroke-linejoin="round"
              >
                {c.name}
              </text>
            ))
          }
        </svg>
      </div>

      <!-- RIGHT: Control panel -->
      <div class="rf-panel">
        <div class="rf-panel-top">
          <h3 class="rf-panel-title">Regional Market View</h3>
        </div>

        <!-- Selected country card -->
        <div class="rf-card" id="rfCard">
          <p id="rfCardRole" class="rf-card-role">
            Central APAC operations hub
