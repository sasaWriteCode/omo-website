<script>
  const cardFlag = document.getElementById("rfCardFlag") as HTMLImageElement;
  const cardName = document.getElementById("rfCardName");
  const cardRole = document.getElementById("rfCardRole");
  const tourBtn = document.getElementById("rfTourBtn");
  const tourBtnMobile = document.getElementById("rfTourBtnMobile");

  const allPins = document.querySelectorAll<SVGGElement>(".rf-pin");
  const allLabels = document.querySelectorAll<SVGTextElement>(".rf-lbl");
  const allLands = document.querySelectorAll<SVGPathElement>(".rf-land");
  const allConns = document.querySelectorAll<SVGPathElement>(".rf-conn");
  const allDirBtns = document.querySelectorAll<HTMLElement>(".rf-dir-btn");

  // Modal elements
  const modal = document.getElementById("rfModal");
  const modalTabs = document.getElementById("rfModalTabs");
  const tabBtns = document.querySelectorAll<HTMLButtonElement>(".rf-modal-tab");
  const panes = document.querySelectorAll<HTMLElement>(".rf-modal-pane");
  const closeBtn = document.querySelector(".rf-modal-close");
  const backdrop = document.querySelector(".rf-modal-backdrop");

  function selectCountry(id: string) {
    // Directory list active states
    allDirBtns.forEach((b) =>
      b.classList.toggle("active", b.dataset.id === id),
    );

    // Map pin active states
    allPins.forEach((pin) =>
      pin.classList.toggle("active", pin.dataset.id === id),
    );

    // Map label active states
    allLabels.forEach((lbl) =>
      lbl.classList.toggle("active", lbl.dataset.id === id),
    );

    // Map connection line active states
    allConns.forEach((conn) => {
      const isMatch = conn.dataset.id === id;
      conn.classList.toggle("active", isMatch);
      if (isMatch) {
        conn.style.opacity = "0.95";
      } else {
        conn.style.opacity = "0";
      }
    });

    // Map land highlight states
    allLands.forEach((land) => {
      const landId = land.dataset.id;
      let isMatch = landId === id;
      if (id === "malaysia" && (landId === "malaysia" || landId === "borneo"))
        isMatch = true;
      if (id === "brunei" && landId === "borneo") isMatch = true;
      if (
        id === "indonesia" &&
        (landId === "borneo" ||
          landId === "sumatra" ||
          landId === "java" ||
          landId === "sulawesi" ||
          landId === "new-guinea")
      )
        isMatch = true;
      if (
        ["thailand", "myanmar", "laos", "vietnam", "cambodia"].includes(id) &&
        landId === "indochina"
      )
        isMatch = true;
      land.classList.toggle("active", isMatch);
    });
  }

  function openOfficeModal() {
    if (!modal) return;

    if (modalTabs) modalTabs.style.display = "flex";
    activatePane("kl");

    modal.classList.add("open");
    modal.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
    if ((window as any).lenis) {
      (window as any).lenis.stop();
    }
  }

  function closeOfficeModal() {
    if (!modal) return;
    modal.classList.remove("open");
    modal.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
    if ((window as any).lenis) {
      (window as any).lenis.start();
    }
  }

  function activatePane(paneId: string) {
    panes.forEach((pane) => {
      pane.classList.toggle("active", pane.dataset.pane === paneId);
    });
    tabBtns.forEach((btn) => {
      btn.classList.toggle("active", btn.dataset.tab === paneId);
    });
  }

  // Bind pins: mouseenter selects, click selects & opens modal
  allPins.forEach((pin) => {
    pin.addEventListener("mouseenter", () => selectCountry(pin.dataset.id!));
    pin.addEventListener("mouseleave", () => selectCountry("malaysia"));
    pin.addEventListener("click", () => {
      const id = pin.dataset.id!;
      if (id === "malaysia") openOfficeModal();
    });
  });

  // Bind labels: style pointer, click selects & opens modal
  allLabels.forEach((lbl) => {
    lbl.style.cursor = "pointer";
    lbl.addEventListener("mouseenter", () => selectCountry(lbl.dataset.id!));
    lbl.addEventListener("mouseleave", () => selectCountry("malaysia"));
    lbl.addEventListener("click", () => {
      const id = lbl.dataset.id!;
      if (id === "malaysia") openOfficeModal();
    });
  });

  // Bind lands: click selects & opens modal
  allLands.forEach((land) => {
    const id = land.dataset.id;
    if (!id) return;

    let targetId = id;
    if (["sumatra", "java", "sulawesi"].includes(id)) {
      targetId = "indonesia";
    } else if (id === "borneo") {
      targetId = "malaysia";
    }

    land.addEventListener("mouseenter", () => selectCountry(targetId));
    land.addEventListener("mouseleave", () => selectCountry("malaysia"));
    land.addEventListener("click", () => {
      if (targetId === "malaysia") openOfficeModal();
    });
  });

  // Bind directory buttons
  allDirBtns.forEach((btn) => {
    btn.addEventListener("mouseenter", () => selectCountry(btn.dataset.id!));
    btn.addEventListener("mouseleave", () => selectCountry("malaysia"));
    btn.addEventListener("click", () => {
      const id = btn.dataset.id!;
      if (id === "malaysia") openOfficeModal();
    });
  });

  // Bind modal tabs and close buttons
  tabBtns.forEach((btn) => {
    btn.addEventListener("click", () => activatePane(btn.dataset.tab!));
  });
  if (closeBtn) closeBtn.addEventListener("click", closeOfficeModal);
  if (backdrop) backdrop.addEventListener("click", closeOfficeModal);
  window.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeOfficeModal();
  });

  // Bind tour button click events
  if (tourBtn) {
    tourBtn.addEventListener("click", openOfficeModal);
  }
  if (tourBtnMobile) {
    tourBtnMobile.addEventListener("click", openOfficeModal);
  }

  // Set default selection
  selectCountry("malaysia");
</script>

<style>
  /* ── Section ── */
  .rf-section {
    --col-hub: #ed4823;
    --col-asean: #2e5b88;
    --col-east-asia: #5c3db3;
    --col-oceania: #2d7a57;

    --glow-hub: rgba(237, 72, 35, 0.22);
    --glow-asean: rgba(46, 91, 136, 0.22);
    --glow-east-asia: rgba(92, 61, 179, 0.22);
    --glow-oceania: rgba(45, 122, 87, 0.22);

    background: #f8f6f1;
    padding: 96px 2rem;
    overflow: hidden;
  }
  @media (max-width: 900px) {
    .rf-section {
      padding: 64px 1.5rem;
    }
  }
  @media (max-width: 600px) {
    .rf-section {
      padding: 48px 1.25rem;
    }
  }

  .rf-wrap {
    max-width: 1280px;
    margin: 0 auto;
  }

  /* ── Header ── */
  .rf-header {
    margin-bottom: 2.75rem;
    max-width: 700px;
  }

  .rf-eyebrow {
    display: inline-block;
    font-family: var(--sans);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--col-hub);
    margin-bottom: 0.85rem;
  }

  .rf-title {
    font-family: var(--serif);
    font-size: clamp(2.5rem, 4vw, 3.2rem);
    line-height: 1.1;
    font-weight: 400;
    color: #111;
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
  }

  .rf-desc {
    font-size: 1.05rem;
    line-height: 1.7;
    color: #555;
    max-width: 600px;
    margin: 0;
  }

  /* ── Two-column ── */
  .rf-content {
    display: grid;
    grid-template-columns: 58% 1fr;
    gap: 36px;
    align-items: start;
  }
  @media (max-width: 1024px) {
    .rf-content {
      grid-template-columns: 1fr;
    }
  }

  /* ── Map card ── */
  .rf-map-card {
    background: #eef2f6;
    border: 1px solid rgba(17, 17, 17, 0.06);
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 800 / 550;
    height: auto;
    box-shadow: 0 6px 28px rgba(0, 0, 0, 0.05);
    position: relative;
  }

  .rf-svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Land + element transitions */
  .rf-land,
  .rf-pin,
  .rf-lbl,
  .rf-conn {
    transition:
      opacity 0.35s ease,
      fill-opacity 0.35s ease,
      fill 0.35s ease,
      stroke 0.35s ease,
      stroke-width 0.35s ease;
  }

  /* Land styling */
  .rf-land {
    cursor: pointer;
  }
  .rf-land:hover {
    fill-opacity: 0.75;
  }
  .rf-land.active {
    fill-opacity: 0.9 !important;
    stroke: #fff !important;
    stroke-width: 1.8px !important;
  }

  /* Dynamic connections path animation */
  .rf-conn {
    pointer-events: none;
  }
  .rf-conn.active {
    opacity: 0.95 !important;
    stroke-width: 2.2px;
    stroke: var(--col-hub) !important;
    stroke-dasharray: 6 4;
    animation: rfDash 1.5s linear infinite;
  }
  @keyframes rfDash {
    to {
      stroke-dashoffset: -20;
    }
  }

  /* Pins styling */
  .rf-pin-dot {
    transition:
      r 0.25s cubic-bezier(0.2, 0.8, 0.2, 1),
      stroke-width 0.25s ease,
      fill 0.25s ease;
  }
  .rf-pin:hover .rf-pin-dot,
  .rf-pin.active .rf-pin-dot {
    r: 7px;
    stroke-width: 2.5px;
    stroke: #fff;
    filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.25));
  }
  .rf-pin[data-region="hub"]:hover .rf-pin-dot,
  .rf-pin[data-region="hub"].active .rf-pin-dot {
    r: 10px;
    stroke-width: 3px;
  }

  /* Hub pulse rings */
  .rf-hub-p1 {
    animation: rfHubP 3s ease-out infinite;
    transform-box: fill-box;
    transform-origin: center;
  }
  .rf-hub-p2 {
    animation: rfHubP 3s ease-out infinite 1.2s;
    transform-box: fill-box;
    transform-origin: center;
  }

  @keyframes rfHubP {
    0% {
      transform: scale(0.6);
      opacity: 0.7;
    }
    100% {
      transform: scale(1.8);
      opacity: 0;
    }
  }

  /* Labels */
  .rf-lbl {
    font-family: var(--sans);
    transition:
      opacity 0.3s ease,
      font-size 0.25s ease,
      fill 0.25s ease,
      font-weight 0.25s ease;
    user-select: none;
    pointer-events: none;
  }
  .rf-lbl.active {
    font-size: 13.5px !important;
    font-weight: 800 !important;
    fill: #000 !important;
  }

  /* ── Right panel ── */
  .rf-panel {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .rf-panel-top {
    border-bottom: 1.5px solid rgba(17, 17, 17, 0.09);
    padding-bottom: 0.75rem;
  }

  .rf-panel-title {
    font-family: var(--sans);
    font-size: 1.35rem;
    font-weight: 800;
    color: #111;
    margin: 0;
    letter-spacing: -0.01em;
  }

  /* Filters */
  .rf-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .rf-filter {
    font-family: var(--sans);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    color: #555;
    background: #fff;
    border: 1.5px solid rgba(17, 17, 17, 0.13);
    border-radius: 4px;
    padding: 7px 13px;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
    --rc: var(--col-hub);
