---

<section id="regional-footprint" class="rf-section">
  <div class="rf-wrap">
    <!-- Section header -->
    <div class="rf-header">
      <span class="rf-eyebrow">APAC Regional Footprint</span>
      <h2 class="rf-title">
        Malaysia as the hub.<br />APAC as the growth field.
      </h2>
      <p class="rf-desc">
        Malaysia serves as the central hub for OMO's APAC operations, radiating
        strategic connections across the region.
      </p>
    </div>

    <!-- Desktop: two-column -->
    <div class="rf-content">
      <!-- LEFT: Geographic map card -->
      <div class="rf-map-card">
        <svg
          id="rfMap"
          viewBox="0 0 800 550"
          class="rf-svg"
          xmlns="http://www.w3.org/2000/svg"
          aria-label="APAC Regional Footprint Map"
        >
          <defs>
            <!-- Ocean background gradient -->
            <linearGradient
              id="rf-ocean-grad"
              x1="0%"
              y1="0%"
              x2="100%"
              y2="100%"
            >
              <stop offset="0%" stop-color="#f2f5f9"></stop>
              <stop offset="100%" stop-color="#e1e8f0"></stop>
            </linearGradient>

            <!-- Hub glow -->
            <filter
              id="rf-hub-glow"
              x="-50%"
              y="-50%"
              width="200%"
              height="200%"
            >
              <feGaussianBlur stdDeviation="5" result="blur"></feGaussianBlur>
              <feMerge
                ><feMergeNode in="blur"></feMergeNode><feMergeNode
                  in="SourceGraphic"></feMergeNode></feMerge
              >
            </filter>
            <!-- Subtle drop shadow for land shapes -->
            <filter
              id="rf-land-shadow"
              x="-5%"
              y="-5%"
              width="110%"
              height="110%"
            >
              <feDropShadow
                dx="0"
                dy="1.5"
                stdDeviation="2"
                flood-color="rgba(0,0,0,0.07)"></feDropShadow>
            </filter>
          </defs>

          <!-- Ocean background with gradient -->
          <rect width="800" height="550" fill="url(#rf-ocean-grad)" rx="0"
          ></rect>

          <!-- Subtle lat/lon graticule -->
          <g
            class="rf-graticule"
            stroke="#9bbdd4"
            stroke-width="0.4"
            opacity="0.4"
          >
            <!-- Longitude lines every 10° -->
            {
              [90, 100, 110, 120, 130, 140, 150, 160, 170].map((lon) => (
                <line
                  x1={gx(lon)}
                  y1="0"
                  x2={gx(lon)}
                  y2="550"
                  stroke-dasharray="3 4"
                />
              ))
            }
            <!-- Latitude lines every 10° -->
            {
              [50, 40, 30, 20, 10, 0, -10, -20, -30, -40].map((lat) => (
                <line
                  x1="0"
                  y1={gy(lat)}
                  x2="800"
                  y2={gy(lat)}
                  stroke-dasharray="3 4"
                />
              ))
            }
          </g>

          <!-- Country land shapes, colored by region -->
          {
            lands.map((land) => (
              <path
                class="rf-land"
                data-land={land.region}
                data-id={land.id}
                d={land.path}
                fill={REGION_COLORS[land.region]}
                fill-opacity={land.region === "hub" ? 0.78 : 0.45}
                stroke="#fff"
                stroke-width="1.2"
                stroke-linejoin="round"
                filter="url(#rf-land-shadow)"
              />
            ))
          }

          <!-- Connection lines from Malaysia hub (hidden by default, shown on filter or active country hover) -->
          {
            countries
              .filter((c) => c.id !== "malaysia")
              .map((c) => (
                <path
                  class="rf-conn"
                  data-id={c.id}
                  data-region={c.region}
                  d={`M ${MY.pinX} ${MY.pinY} Q ${(MY.pinX + c.pinX) / 2} ${Math.min(MY.pinY, c.pinY) - 35} ${c.pinX} ${c.pinY}`}
                  fill="none"
                  stroke={REGION_COLORS.hub}
                  stroke-width="1.5"
                  stroke-dasharray="6 4"
