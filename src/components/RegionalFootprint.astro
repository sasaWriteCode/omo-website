import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";

// ── Office gallery images (optimized to WebP at build time) ────────────
const officeGlob = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/{kuala-lumpur,puchong,china}/*.png",
  { eager: true },
);
const officeImg = Object.fromEntries(
  await Promise.all(
    Object.entries(officeGlob).map(async ([path, mod]) => [
      path.replace("../assets/", ""),
      (await getImage({ src: mod.default, format: "webp" })).src,
    ]),
  ),
) as Record<string, string>;

// ── Geographic projection helpers ──────────────────────────────────────
// Bounds: lon 88–180, lat –50–55. ViewBox 0 0 800 550
// x(lon) = (lon - 88) / 92 * 800
// y(lat) = (55 - lat) / 105 * 550
function gx(lon: number) {
  return Math.round(((lon - 88) / 92) * 800);
}
function gy(lat: number) {
  return Math.round(((55 - lat) / 105) * 550);
}

// ── Country/region data ────────────────────────────────────────────────
