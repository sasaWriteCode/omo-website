        </div>
        <p class="rf-card-role">Central APAC operations hub</p>
        <button id="rfTourBtnMobile" class="rf-tour-btn">
          <svg
            class="rf-tour-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
          </svg>
          <span>Tour Office Locations</span>
