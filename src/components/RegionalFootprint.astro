// ── Geographic land shapes (equirectangular projection) ────────────────
// Helper to build SVG path from [lon,lat] point pairs
function makePath(pts: [number, number][]) {
  return (
    pts
      .map(([lon, lat], i) => `${i === 0 ? "M" : "L"} ${gx(lon)},${gy(lat)}`)
      .join(" ") + " Z"
  );
}

