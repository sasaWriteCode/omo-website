  <!-- Office Tour Modal -->
  <div id="rfModal" class="rf-modal" aria-hidden="true">
    <div class="rf-modal-backdrop"></div>
    <div class="rf-modal-content" data-lenis-prevent>
      <button class="rf-modal-close" aria-label="Close modal">&times;</button>

      <div id="rfModalTabs" class="rf-modal-tabs">
        <button class="rf-modal-tab active" data-tab="kl">KL Office</button>
        <button class="rf-modal-tab" data-tab="puchong">Puchong Office</button>
        <button class="rf-modal-tab" data-tab="china">China Office</button>
      </div>

      <div class="rf-modal-body" data-lenis-prevent>
        <!-- Malaysia - KL Office -->
        <div class="rf-modal-pane active" data-pane="kl">
          <div class="rf-modal-address">
            <svg class="rf-address-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <a href="https://www.google.com/maps/search/?api=1&query=15-04%2C+Menara+Tan+%26+Tan%2C+207%2C+Jln+Tun+Razak%2C+50400+Kuala+Lumpur" target="_blank" rel="noopener" class="rf-address-link">
              15-04, Menara Tan & Tan, 207, Jln Tun Razak, 50400 Kuala Lumpur, Wilayah Persekutuan Kuala Lumpur
            </a>
          </div>
          <div class="rf-gallery-masonry">
            <div class="rf-gallery-item">
              <img src={officeImg["kuala-lumpur/kl-office-building-exterior.png"]} alt="Building Exterior - Menara Tan & Tan" />
            </div>
            <div class="rf-gallery-item">
              <img src={officeImg["kuala-lumpur/kl-office-lobby.png"]} alt="Office Lobby" />
            </div>
            <div class="rf-gallery-item">
              <img src={officeImg["kuala-lumpur/kl-office-workspace.png"]} alt="Main Workspace" />
            </div>
            <div class="rf-gallery-item">
              <img src={officeImg["kuala-lumpur/kl-office-workspace2.png"]} alt="Workspace Area" />
