---
import HeroVisual from "./HeroVisual.astro";
import "../styles/hero.css";
---

<section id="hero-premium">
  <!-- Atmospheric background layers -->
  <div class="hero-premium-bg">
    <div class="hero-premium-grid"></div>
    <div class="hero-premium-glow"></div>
  </div>

  <div class="hero-premium-container">
    <!-- LEFT — Strong copywriting and trust stats -->
    <div class="hero-premium-content">
      <h1 class="hero-premium-title">
        <div class="hero-line-container" style="overflow: hidden;">
          <span class="hero-line-inner" style="display: inline-block;"
            >We transform businesses</span
          >
        </div>
        <div class="hero-line-container" style="overflow: hidden;">
          <span class="hero-line-inner" style="display: inline-block;">
            into <span class="orange-highlight">profitable growth engines.</span
            >
          </span>
        </div>
      </h1>

      <h2 class="hero-premium-subtitle">
        We incubate, grow, and scale businesses across Malaysia &amp; APAC.
      </h2>

      <p class="hero-premium-desc">
        From early-stage incubation to scale and exit readiness, we diagnose,
        strategise, and transform businesses through strategic marketing, AI,
        and scalable operating systems.
      </p>

      <div class="hero-premium-ctas">
        <div class="hero-premium-buttons">
          <a href="#cta" class="btn-premium-fill">Book Diagnose Consultation</a>
          <a href="#growth-framework" class="btn-premium-outline"
            >Explore OMO Framework</a
          >
        </div>
        <span class="hero-premium-cta-note"
          >30-minute complimentary strategy session</span
        >
      </div>

      <!-- Mobile layout labels list (Flex container styled in CSS) -->
      <div class="hero-premium-mobile-pills">
        <a href="#services" class="mobile-pill">Business Incubator</a>
        <a href="#services" class="mobile-pill">Company Doctor</a>
        <a href="#services" class="mobile-pill">Growth Accelerator</a>
      </div>
    </div>

    <!-- RIGHT — Interactive 2.5D visual area -->
    <div class="hero-premium-visual">
      <HeroVisual />
    </div>
  </div>
</section>

<!-- Client-side script for premium reveal & interactive floating motion -->
<script>
  import { gsap } from "gsap";

  // Check user preferences for animations
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  if (prefersReducedMotion) {
    // If user prefers reduced motion, set final layout values instantly
    gsap.set(".hero-line-inner", { y: 0, opacity: 1 });
    gsap.set(
      ".hero-premium-subtitle, .hero-premium-desc, .hero-premium-buttons, .hero-premium-cta-note",
      { opacity: 1, y: 0 },
    );
    gsap.set(".iso-container", { opacity: 1 });
    gsap.set(".hero-pill-label", { opacity: 1, scale: 1 });
  } else {
    // Set initial states for animations
    gsap.set(".hero-line-inner", { y: "110%", opacity: 0 });
    gsap.set(
      [
        ".hero-premium-subtitle",
        ".hero-premium-desc",
        ".hero-premium-buttons",
        ".hero-premium-cta-note",
      ],
      { opacity: 0, y: 24 },
    );
    gsap.set(".iso-container", { opacity: 0, y: 40 });
    gsap.set(".hero-pill-label", { opacity: 0, scale: 0.8, y: 15 });

    // GSAP Reveal Timeline
    const tl = gsap.timeline({
      defaults: { ease: "power4.out", duration: 1.0 },
    });

    tl.to(".hero-line-inner", { y: "0%", opacity: 1, stagger: 0.15 })
      .to(
        [".hero-premium-subtitle", ".hero-premium-desc"],
        { opacity: 1, y: 0, stagger: 0.1 },
        "-=0.5",
      )
      .to(
        [".hero-premium-buttons", ".hero-premium-cta-note"],
        { opacity: 1, y: 0, stagger: 0.1 },
        "-=0.6",
      )
      .to(".iso-container", { opacity: 1, y: 0, duration: 1.2 }, "-=1.0");

    // Fade in floating badges/labels around the model
    tl.to(
      ".hero-pill-label",
      { opacity: 1, scale: 1, y: 0, stagger: 0.08, duration: 0.6 },
      "-=0.8",
    );

    // ─────────────────────────────────────────────
    // Continuous Idle Floating & Hover Effects
    // ─────────────────────────────────────────────

    // Slow float for accent spheres
    gsap.to("#sphere1", {
      y: -15,
      duration: 3.5,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut",
    });
    gsap.to("#sphere2", {
      y: 12,
      duration: 4.2,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut",
    });

    // Slow float for the Strategy Dashboard Card
    gsap.to("#dashboardPanel", {
      y: -6,
      z: 46,
      duration: 3.8,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut",
    });

    // Slow float and rotation for the AI Data Cube
    gsap.to("#aiCube", {
      y: 6,
      z: 32,
      rotationY: 360,
      duration: 8.0,
      repeat: -1,
      ease: "linear",
    });

    // Staggered plate hovering for the Growth Tower
    gsap.to("#towerPlate2", {
      z: 36,
      duration: 3.2,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut",
      delay: 0.1,
    });
    gsap.to("#towerPlate3", {
      z: 58,
      duration: 2.8,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut",
      delay: 0.2,
    });

    // ─────────────────────────────────────────────
    // Mouse Parallax Interaction on 2.5D City Map
    // ─────────────────────────────────────────────
    const visualArea = document.querySelector(".hero-premium-visual");
    const isoContainer = document.getElementById("isoContainer");

    if (visualArea && isoContainer) {
      visualArea.addEventListener("mousemove", (e: any) => {
        const rect = visualArea.getBoundingClientRect();
        // Mouse coordinate scale: -0.5 to 0.5
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;

        // Tilt the isometric container slightly based on mouse
        gsap.to(isoContainer, {
          rotationX: 60 - y * 12,
          rotationZ: -45 + x * 15,
          duration: 0.8,
          ease: "power2.out",
        });
      });

      visualArea.addEventListener("mouseleave", () => {
        // Reset to default isometric angles smoothly
        gsap.to(isoContainer, {
          rotationX: 60,
          rotationZ: -45,
          duration: 1.2,
          ease: "power2.out",
        });
      });
    }
  }
</script>
