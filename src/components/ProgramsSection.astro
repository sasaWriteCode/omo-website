<script>
  // Modal toggle selectors
  const advBtn = document.getElementById("openAdvisoryBtn");
  const incBtn = document.getElementById("openIncubationBtn");
  const advModal = document.getElementById("advisoryModal");
  const incModal = document.getElementById("incubationModal");
  const closeBtns = document.querySelectorAll(".prog-modal-close");
  const backdrops = document.querySelectorAll(".prog-modal-backdrop");

  // Open Advisory Plans Modal
  advBtn?.addEventListener("click", () => {
    if (advModal) {
      advModal.classList.add("open");
      advModal.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
      if ((window as any).lenis) {
        (window as any).lenis.stop();
      }
    }
  });

  // Open Incubation Program Modal
  incBtn?.addEventListener("click", () => {
    if (incModal) {
      incModal.classList.add("open");
      incModal.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
      if ((window as any).lenis) {
        (window as any).lenis.stop();
      }
      // Reset segment tabs to first one
      const servicesTab = incModal.querySelector(
        '[data-inc-tab="services"]',
      ) as HTMLElement;
      servicesTab?.click();
    }
  });

  // Close modals
  const closeModal = (modalEl: HTMLElement) => {
    modalEl.classList.remove("open");
    modalEl.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
    if ((window as any).lenis) {
      (window as any).lenis.start();
    }
  };

  closeBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const activeModal = btn.closest(".prog-modal") as HTMLElement;
      if (activeModal) closeModal(activeModal);
    });
  });

  backdrops.forEach((backdrop) => {
    backdrop.addEventListener("click", () => {
      const activeModal = backdrop.closest(".prog-modal") as HTMLElement;
      if (activeModal) closeModal(activeModal);
    });
  });

  window.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      const openModal = document.querySelector(
        ".prog-modal.open",
      ) as HTMLElement;
      if (openModal) closeModal(openModal);
    }
  });

  // Incubation Modal tabs switching
  const incTabs = document.querySelectorAll<HTMLElement>("[data-inc-tab]");
  const incPanes = document.querySelectorAll<HTMLElement>("[data-inc-pane]");

  incTabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const targetId = tab.dataset.incTab;
      incTabs.forEach((t) => t.classList.remove("active"));
      tab.classList.add("active");

      incPanes.forEach((pane) => {
        pane.classList.toggle("active", pane.dataset.incPane === targetId);
      });
    });
  });

  // Accordion triggers
  const accHeaders = document.querySelectorAll(".phase-acc-header");
  accHeaders.forEach((header) => {
    // Open phase 1 by default, toggle others
    const accordion = header.parentElement;
    header.addEventListener("click", () => {
      const isOpen = accordion?.classList.contains("open");
      // Close all accordions inside the active track pane
      const pane = header.closest(".inc-tab-pane");
      pane
        ?.querySelectorAll(".phase-accordion")
        .forEach((acc) => acc.classList.remove("open"));
      // Toggle
      if (!isOpen) {
        accordion?.classList.add("open");
      }
    });
  });

  // Automatically trigger phase 1 click inside active panes on tab switch or initialization
  document.querySelectorAll(".inc-tab-pane").forEach((pane) => {
    const firstAcc = pane.querySelector(".phase-accordion");
    firstAcc?.classList.add("open");
  });

  // Listen to cross-component drawer CTA open requests
  window.addEventListener("open-incubation-modal-request", () => {
    incBtn?.click();
  });

  window.addEventListener("open-advisory-modal-request", () => {
    advBtn?.click();
  });
</script>

