---
/* ═══════════════════════════════════════════════
   CLIENTELE GALLERY — Immersive "O" Kaleidoscope
   Replaces the old CaseStudies section.
═══════════════════════════════════════════════ */

const malaysiaLogos = [
  { src: "/assets/Clientele/Toyota.png", alt: "Toyota" },
  { src: "/assets/Clientele/Yamaha.png", alt: "Yamaha" },
  { src: "/assets/Clientele/Maxis.png", alt: "Maxis" },
  { src: "/assets/Clientele/FarmFresh.png", alt: "Farm Fresh" },
  { src: "/assets/Clientele/Li-Ning.png", alt: "Li-Ning" },
  { src: "/assets/Clientele/UTAR.png", alt: "UTAR" },
  { src: "/assets/Clientele/TARUMT.png", alt: "TARUMT" },
  {
    src: "/assets/Clientele/OUM_OpenUniversityMalaysia.png",
    alt: "Open University Malaysia",
  },
  { src: "/assets/Clientele/redONE.png", alt: "redONE" },
  { src: "/assets/Clientele/BzuBzu.png", alt: "BzuBzu" },
  { src: "/assets/Clientele/JambanKing.png", alt: "Jamban King" },
  { src: "/assets/Clientele/RekaSetia.png", alt: "Reka Setia" },
];

const apacLogos = [
  { src: "/assets/APAC_Clientele/joy_group.png", alt: "Joy Group" },
  { src: "/assets/APAC_Clientele/JinxinTechnology.png", alt: "Jinxin Technology" },
  { src: "/assets/APAC_Clientele/KeerKeji.png", alt: "Keer Keji" },
  { src: "/assets/APAC_Clientele/HuakangClean.png", alt: "Huakang Clean" },
  { src: "/assets/APAC_Clientele/HubeiKingballLawFirm.png", alt: "Hubei Kingball Law Firm" },
  { src: "/assets/APAC_Clientele/JCEX.png", alt: "JCEX" },
  { src: "/assets/APAC_Clientele/SANY.png", alt: "SANY" },
  { src: "/assets/APAC_Clientele/ChenxinShipping.png", alt: "Chenxin Shipping" },
  { src: "/assets/APAC_Clientele/FigtonMedical.png", alt: "Figton Medical" },
  { src: "/assets/APAC_Clientele/QingtianTech.png", alt: "Qingtian Tech" },
  { src: "/assets/APAC_Clientele/RUIXUE.png", alt: "RUIXUE" },
  { src: "/assets/APAC_Clientele/ShengjieLogistics.png", alt: "Shengjie Logistics" },
  { src: "/assets/APAC_Clientele/SuperConstruction.png", alt: "Super Construction" },
  { src: "/assets/APAC_Clientele/xjt.png", alt: "XJT" },
  { src: "/assets/APAC_Clientele/YIHAI.png", alt: "YIHAI" },
  { src: "/assets/APAC_Clientele/ZhentianJianshe_ZCIGC.png", alt: "ZCIGC" },
  { src: "/assets/APAC_Clientele/ZCretechModularHouse.png", alt: "ZCretech Modular House" },
  { src: "/assets/APAC_Clientele/ZhengqiyanBuildingMaterials.png", alt: "Zhengqiyan Building Materials" },
  { src: "/assets/APAC_Clientele/ZhentianConstruction.png", alt: "Zhentian Construction" },
  { src: "/assets/APAC_Clientele/ZhongshunJierou.png", alt: "Zhongshun Jierou" },
  { src: "/assets/APAC_Clientele/ChengEtech.png", alt: "ChengE tech" },
  { src: "/assets/APAC_Clientele/QiCaiYing.png", alt: "QiCaiYing" },
  { src: "/assets/APAC_Clientele/LingdongZhimenxin.png", alt: "Lingdong Zhimenxin" },
];

const allLogos = [...malaysiaLogos, ...apacLogos];
---

<!-- Tall scroll container drives the animation -->
<section id="clients" class="cl-section" aria-labelledby="cl-heading">
  <div class="cl-scroll-spacer">
    <!-- Sticky viewport — stays pinned while user scrolls -->
    <div class="cl-sticky">
      <!-- Background overlay (darkens during zoom) -->
      <div class="cl-bg-overlay"></div>

      <!-- Header -->
      <div class="cl-header">
        <p class="cl-eyebrow">Our Clientele</p>
        <h2 class="cl-title" id="cl-heading">
          Trusted by <span class="cl-accent">35+</span> brands across APAC
        </h2>
      </div>

      <!-- The O ring -->
      <div class="cl-o-ring">
        <div class="cl-o-inner"></div>
      </div>

      <!-- Kaleidoscope container (inside the O) -->
      <div class="cl-kaleidoscope">
        <!-- Black-hole vortex overlay -->
        <div class="cl-bh-vortex"></div>
        <div class="cl-k-disc">
          <div class="cl-k-rotor">
            {
              allLogos.map((logo, i) => (
                <div
                  class="cl-k-item"
                  style={`--k-i: ${i}; --k-total: ${allLogos.length};`}
                >
                  <img src={logo.src} alt={logo.alt} loading="lazy" />
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Final settled logo grid (scrolls in naturally after spacer) -->
  <div class="cl-grid-container">
    <div class="cl-grid-header">
      <p class="cl-eyebrow">Our Clientele</p>
      <h2 class="cl-grid-title">
        Trusted by <span class="cl-accent">35+</span> brands across APAC
      </h2>
    </div>

    <div class="cl-grid-group">
      <h3 class="cl-grid-label">Malaysia Clientele</h3>
      <div class="cl-grid">
        {
          malaysiaLogos.map((logo) => (
            <div class="cl-grid-item">
              <img src={logo.src} alt={logo.alt} loading="lazy" />
            </div>
          ))
        }
      </div>
    </div>
    <div class="cl-grid-group">
      <h3 class="cl-grid-label">APAC Clientele</h3>
      <div class="cl-grid cl-grid-apac">
        {
          apacLogos.map((logo) => (
            <div class="cl-grid-item">
              <img src={logo.src} alt={logo.alt} loading="lazy" />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Section & scroll spacer ────────────────── */
  .cl-section {
    position: relative;
    overflow: clip;
  }
  .cl-scroll-spacer {
    height: 220vh;
    position: relative;
  }

  /* ── Sticky viewport ────────────────────────── */
  .cl-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--light, #f7f7f5);
    transition: background 0.5s ease;
  }
  .cl-section.phase-zoom .cl-sticky,
  .cl-section.phase-kaleidoscope .cl-sticky,
  .cl-section.phase-blackhole .cl-sticky,
  .cl-section.phase-grid .cl-sticky {
    background: #0a0a0a;
  }

  /* ── Background overlay ─────────────────────── */
  .cl-bg-overlay {
    position: absolute;
    inset: 0;
    background: #0a0a0a;
    opacity: 0;
    transition: opacity 0.6s ease;
    z-index: 1;
    pointer-events: none;
  }
  .cl-section.phase-zoom .cl-bg-overlay,
  .cl-section.phase-kaleidoscope .cl-bg-overlay,
  .cl-section.phase-blackhole .cl-bg-overlay {
    opacity: 1;
  }

  /* ── Header ─────────────────────────────────── */
  .cl-header {
    position: absolute;
    top: 12vh;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    z-index: 10;
    transition:
      opacity 0.5s ease,
      transform 0.5s ease;
  }
  .cl-section.phase-zoom .cl-header,
  .cl-section.phase-kaleidoscope .cl-header,
  .cl-section.phase-blackhole .cl-header,
  .cl-section.phase-grid .cl-header {
    opacity: 0;
    transform: translateX(-50%) translateY(-30px);
    pointer-events: none;
  }

  .cl-eyebrow {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: #ed4823;
    margin-bottom: 16px;
    position: relative;
    padding: 0 20px;
  }
  .cl-eyebrow::before,
  .cl-eyebrow::after {
    content: "";
    position: absolute;
    top: 50%;
    width: 14px;
    height: 1.5px;
    background: #ed4823;
    transform: translateY(-50%);
  }
  .cl-eyebrow::before {
    right: 100%;
    margin-right: -18px;
  }
  .cl-eyebrow::after {
    left: 100%;
    margin-left: -18px;
  }

  .cl-title {
    font-family: var(--serif, "DM Serif Display", Georgia, serif);
    font-size: clamp(1.6rem, 3vw, 2.8rem);
    font-weight: 400;
    line-height: 1.2;
    color: #111;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }
  .cl-accent {
    color: #ed4823;
  }

  /* ── O Ring ─────────────────────────────────── */
  .cl-o-ring {
    position: absolute;
    top: calc(50% - 120px);
    left: calc(50% - 120px);
    width: 240px;
    height: 240px;
    border-radius: 50%;
    border: 28px solid #ed4823;
    z-index: 5;
    /* No will-change here: the ring scales up to 26x, and pinning it to a
       cached GPU layer leaves a giant stale raster that breaks (jagged /
       partial circle) when scrolling back after the kaleidoscope starts.
       Letting the browser re-rasterize keeps the circle crisp. */
    transition:
      opacity 0.4s ease,
      visibility 0.4s;
    box-shadow:
      0 0 40px rgba(237, 72, 35, 0.2),
      inset 0 0 30px rgba(237, 72, 35, 0.1);
  }
  .cl-o-inner {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: transparent;
  }
  .cl-section.phase-kaleidoscope .cl-o-ring,
  .cl-section.phase-blackhole .cl-o-ring,
  .cl-section.phase-grid .cl-o-ring {
    opacity: 0;
    /* visibility:hidden releases the huge scaled raster from GPU memory */
    visibility: hidden;
    pointer-events: none;
  }

  /* ── Kaleidoscope ───────────────────────────── */
  .cl-kaleidoscope {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 6;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    /* Fade IN handled by JS adding phase-kaleidoscope */
    transition:
      opacity 0.8s ease,
      visibility 0.8s;
  }
  .cl-section.phase-kaleidoscope .cl-kaleidoscope,
  .cl-section.phase-blackhole .cl-kaleidoscope {
    opacity: 1;
    visibility: visible;
    pointer-events: none;
  }

  /* Black-hole vortex radial overlay — grows from centre */
  .cl-bh-vortex {
    position: absolute;
    inset: 0;
    z-index: 10;
    /* radial dark gradient, size driven by --bh CSS var (0 → 1) */
    background: radial-gradient(
      circle at center,
      #000 calc(var(--bh, 0) * 30%),
      transparent calc(var(--bh, 0) * 30% + 4px)
    );
    pointer-events: none;
  }

  .cl-k-disc {
    position: relative;
    width: 90vmin;
    height: 90vmin;
    max-width: 700px;
    max-height: 700px;
    /* Scroll-driven black-hole collapse (scale + spiral spin).
       The infinite autoplay rotation lives on .cl-k-rotor below so the
       CSS animation never overrides this scrubbed inline transform. */
    transform: scale(var(--bh-scale, 1)) rotate(var(--bh-spin, 0deg));
    will-change: transform;
  }

  /* Autoplay rotation layer — separate from the scrubbed disc transform */
  .cl-k-rotor {
    position: absolute;
    inset: 0;
    animation: k-rotate 30s linear infinite;
    animation-play-state: paused;
    will-change: transform;
  }
  .cl-section.phase-kaleidoscope .cl-k-rotor,
  .cl-section.phase-blackhole .cl-k-rotor {
    animation-play-state: running;
  }

  @keyframes k-rotate {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  .cl-k-item {
    position: absolute;
    width: 60px;
    height: 60px;
    top: 50%;
    left: 50%;
    transform-origin: center center;
    /* Place each item in a circle using polar coordinates */
    transform: translate(-50%, -50%)
      rotate(calc(360deg / var(--k-total) * var(--k-i)))
      translateY(calc(-1 * clamp(120px, 30vmin, 260px)))
      rotate(calc(-360deg / var(--k-total) * var(--k-i)));
  }
  .cl-k-item img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: 0.85;
  }

  /* Mirror layer — reflected copies for kaleidoscope symmetry */
  .cl-k-item:nth-child(even) {
    transform: translate(-50%, -50%)
      rotate(calc(360deg / var(--k-total) * var(--k-i) + 9deg))
      translateY(calc(-1 * clamp(80px, 20vmin, 180px)))
      rotate(calc(-360deg / var(--k-total) * var(--k-i) - 9deg)) scaleX(-1);
    opacity: 0.5;
  }

  /* ── Final Grid ─────────────────────────────── */
  .cl-grid-container {
    position: relative;
    z-index: 8;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3.5rem;
    padding: 6rem var(--gutter, 2rem) 8rem;
    background: #0a0a0a;
    width: 100%;
  }

  .cl-grid-header {
    text-align: center;
    margin-bottom: 1rem;
  }
  .cl-grid-title {
    font-family: var(--serif, "DM Serif Display", Georgia, serif);
    font-size: clamp(1.8rem, 3.2vw, 3rem);
    font-weight: 400;
    line-height: 1.2;
    color: #ffffff;
    letter-spacing: -0.01em;
  }

  .cl-grid-group {
    text-align: center;
    max-width: 1100px;
    width: 100%;
  }
  .cl-grid-label {
    font-family: var(--sans, "DM Sans", system-ui, sans-serif);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #ed4823;
    margin-bottom: 1.2rem;
  }

  .cl-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1rem;
    justify-items: center;
    align-items: center;
  }
  .cl-grid-apac {
    grid-template-columns: repeat(6, 1fr);
  }

  .cl-grid-item {
    background: #fff;
    border: 1px solid rgba(17, 17, 17, 0.06);
    border-radius: 10px;
    padding: 0.8rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    aspect-ratio: 3 / 2;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }
  .cl-grid-item:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
  }
  .cl-grid-item img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  /* ── Mobile ─────────────────────────────────── */
  @media (max-width: 767px) {
    .cl-scroll-spacer {
      height: 180vh;
    }
    .cl-o-ring {
      width: 160px;
      height: 160px;
      border-width: 20px;
      top: calc(50% - 80px);
      left: calc(50% - 80px);
    }
    .cl-header {
      top: 8vh;
    }
    .cl-title {
      white-space: normal;
      padding: 0 1rem;
    }
    .cl-k-item {
      width: 40px;
      height: 40px;
    }
    .cl-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 0.6rem;
    }
    .cl-grid-apac {
      grid-template-columns: repeat(3, 1fr);
    }
    .cl-grid-item {
      padding: 0.5rem;
    }
    .cl-grid-container {
      gap: 2rem;
      padding: 4rem 1rem 6rem;
    }
  }

  @media (max-width: 480px) {
    .cl-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .cl-grid-apac {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

<script>
  const section = document.getElementById("clients");
  if (section) {
    const spacer = section.querySelector(".cl-scroll-spacer") as HTMLElement;
    const oRing = section.querySelector(".cl-o-ring") as HTMLElement;

    let ticking = false;
    let currentPhase = "";

    const kDisc = section.querySelector(".cl-k-disc") as HTMLElement;
    const bhVortex = section.querySelector(".cl-bh-vortex") as HTMLElement;

    // Ease function: cubic ease-in for the black-hole collapse
    function easeInCubic(t: number) {
      return t * t * t;
    }

    function updatePhase() {
      const rect = spacer.getBoundingClientRect();
      const spacerHeight = rect.height;
      const viewportHeight = window.innerHeight;

      const scrolled = -rect.top;
      const totalScroll = spacerHeight - viewportHeight;

      if (totalScroll <= 0) {
        ticking = false;
        return;
      }

      const progress = Math.max(0, Math.min(1, scrolled / totalScroll));

      // Determine new phase
      let newPhase = "";
      if (progress < 0.05) {
        newPhase = "initial";
      } else if (progress < 0.45) {
        newPhase = "zoom";
      } else if (progress < 0.67) {
        newPhase = "kaleidoscope";
      } else if (progress < 0.87) {
        newPhase = "blackhole";
      } else {
        newPhase = "grid";
      }

      // Update DOM classes ONLY when the phase shifts
      if (newPhase !== currentPhase) {
        section.classList.remove(
          "phase-zoom",
          "phase-kaleidoscope",
          "phase-blackhole",
          "phase-grid",
        );

        if (newPhase === "zoom") {
          section.classList.add("phase-zoom");
        } else if (newPhase === "kaleidoscope") {
          section.classList.add("phase-kaleidoscope");
        } else if (newPhase === "blackhole") {
          section.classList.add("phase-blackhole");
        } else if (newPhase === "grid") {
          section.classList.add("phase-grid");
        }

        currentPhase = newPhase;
      }

      // Apply scroll-driven animations based on current phase
      if (newPhase === "initial") {
        // ── Initial: O ring at rest ──────────────────
        oRing.style.transform = "scale(1)";
        section.style.setProperty("--bh", "0");
        kDisc.style.setProperty("--bh-scale", "1");
        kDisc.style.setProperty("--bh-spin", "0deg");
        kDisc.style.opacity = "1";
        bhVortex.style.background = "transparent";

      } else if (newPhase === "zoom") {
        // ── Phase: O zoom in ─────────────────────────
        const zp = (progress - 0.05) / 0.4;
        oRing.style.transform = `scale(${1 + zp * 25})`;
        section.style.setProperty("--bh", "0");
        kDisc.style.setProperty("--bh-scale", "1");
        kDisc.style.setProperty("--bh-spin", "0deg");
        kDisc.style.opacity = "1";
        bhVortex.style.background = "transparent";

      } else if (newPhase === "kaleidoscope") {
        // ── Phase: Kaleidoscope idle ─────────────────
        oRing.style.transform = "scale(26)";
        section.style.setProperty("--bh", "0");
        kDisc.style.setProperty("--bh-scale", "1");
        kDisc.style.setProperty("--bh-spin", "0deg");
        kDisc.style.opacity = "1";
        bhVortex.style.background = "transparent";

      } else if (newPhase === "blackhole") {
        // ── Phase: Black-hole fly-through ───────────
        const bhP = easeInCubic((progress - 0.67) / 0.2);
        oRing.style.transform = "scale(26)";

        // Disc scales UP to fly past the viewer: scale 1 → 9, spin 0 → 180deg
        const bhScale = 1 + bhP * 8;
        const bhSpin = bhP * 180;
        kDisc.style.setProperty("--bh-scale", String(bhScale));
        kDisc.style.setProperty("--bh-spin", `${bhSpin}deg`);

        // Disc fades out as it zooms past the camera POV
        kDisc.style.opacity = String(Math.max(0, 1 - bhP * 1.3));

        // Background fades to pure solid black
        bhVortex.style.background = `rgba(10, 10, 10, ${bhP})`;

      } else {
        // ── Phase: Grid ──────────────────────────────
        oRing.style.transform = "scale(26)";
        kDisc.style.setProperty("--bh-scale", "0");
        kDisc.style.opacity = "0";
        bhVortex.style.background = "#000";
      }

      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        window.requestAnimationFrame(updatePhase);
        ticking = true;
      }
    }

    // Use IntersectionObserver to only track when visible
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            window.addEventListener("scroll", onScroll, { passive: true });
            onScroll();
          } else {
            window.removeEventListener("scroll", onScroll);
            // Reset everything when section leaves viewport
            section.classList.remove(
              "phase-zoom",
              "phase-kaleidoscope",
              "phase-blackhole",
              "phase-grid",
            );
            oRing.style.transform = "scale(1)";
            kDisc.style.setProperty("--bh-scale", "1");
            kDisc.style.setProperty("--bh-spin", "0deg");
            kDisc.style.opacity = "1";
            bhVortex.style.background = "transparent";
            currentPhase = "";
          }
        });
      },
      { threshold: 0 },
    );
    observer.observe(section);

    // Initial call
    onScroll();
  }
</script>
