  .cl-grid-title {
    font-family: var(--serif, "DM Serif Display", Georgia, serif);
    font-size: clamp(1.8rem, 3.2vw, 3rem);
    font-weight: 400;
    line-height: 1.2;
    color: #ffffff;
    letter-spacing: -0.01em;
  }

  .cl-grid-group {
    text-align: center;
    max-width: 1100px;
