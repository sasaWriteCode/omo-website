---
/* ═══════════════════════════════════════════════
   CLIENTELE GALLERY — Immersive "O" Kaleidoscope
   Replaces the old CaseStudies section.
═══════════════════════════════════════════════ */
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import omoLogo from "../assets/omo_logo.png";

const omoLogoSrc = (await getImage({ src: omoLogo, format: "webp" })).src;

const clienteleGlob = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/Clientele/*.png",
  { eager: true },
);
const apacGlob = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/APAC_Clientele/*.png",
  { eager: true },
);

const clientele = (file: string) =>
  clienteleGlob[`../assets/Clientele/${file}`].default;
const apac = (file: string) =>
  apacGlob[`../assets/APAC_Clientele/${file}`].default;

/* Optimize to hashed WebP at build time; keeps plain <img> tags in the
   template so the scoped styles (.cl-k-item img, .cl-grid-item img) still apply. */
const optimize = (logos: { src: ImageMetadata; alt: string }[]) =>
  Promise.all(
    logos.map(async ({ src, alt }) => ({
      src: (await getImage({ src, format: "webp" })).src,
      alt,
    })),
  );

const malaysiaSources = [
  { src: clientele("Toyota.png"), alt: "Toyota" },
  { src: clientele("Yamaha.png"), alt: "Yamaha" },
  { src: clientele("Maxis.png"), alt: "Maxis" },
  { src: clientele("FarmFresh.png"), alt: "Farm Fresh" },
  { src: clientele("Li-Ning.png"), alt: "Li-Ning" },
  { src: clientele("UTAR.png"), alt: "UTAR" },
  { src: clientele("TARUMT.png"), alt: "TARUMT" },
  {
    src: clientele("OUM_OpenUniversityMalaysia.png"),
    alt: "Open University Malaysia",
  },
  { src: clientele("redONE.png"), alt: "redONE" },
  { src: clientele("BzuBzu.png"), alt: "BzuBzu" },
  { src: clientele("JambanKing.png"), alt: "Jamban King" },
  { src: clientele("RekaSetia.png"), alt: "Reka Setia" },
];

const apacSources = [
  { src: apac("joy_group.png"), alt: "Joy Group" },
  { src: apac("JinxinTechnology.png"), alt: "Jinxin Technology" },
  { src: apac("KeerKeji.png"), alt: "Keer Keji" },
  { src: apac("HuakangClean.png"), alt: "Huakang Clean" },
  { src: apac("HubeiKingballLawFirm.png"), alt: "Hubei Kingball Law Firm" },
  { src: apac("JCEX.png"), alt: "JCEX" },
  { src: apac("SANY.png"), alt: "SANY" },
  { src: apac("ChenxinShipping.png"), alt: "Chenxin Shipping" },
  { src: apac("FigtonMedical.png"), alt: "Figton Medical" },
  { src: apac("QingtianTech.png"), alt: "Qingtian Tech" },
  { src: apac("RUIXUE.png"), alt: "RUIXUE" },
  { src: apac("ShengjieLogistics.png"), alt: "Shengjie Logistics" },
  { src: apac("SuperConstruction.png"), alt: "Super Construction" },
  { src: apac("xjt.png"), alt: "XJT" },
  { src: apac("YIHAI.png"), alt: "YIHAI" },
  { src: apac("ZhentianJianshe_ZCIGC.png"), alt: "ZCIGC" },
  { src: apac("ZCretechModularHouse.png"), alt: "ZCretech Modular House" },
  {
    src: apac("ZhengqiyanBuildingMaterials.png"),
    alt: "Zhengqiyan Building Materials",
  },
  { src: apac("ZhentianConstruction.png"), alt: "Zhentian Construction" },
  { src: apac("ZhongshunJierou.png"), alt: "Zhongshun Jierou" },
  { src: apac("ChengEtech.png"), alt: "ChengE tech" },
  { src: apac("QiCaiYing.png"), alt: "QiCaiYing" },
  { src: apac("LingdongZhimenxin.png"), alt: "Lingdong Zhimenxin" },
];

const malaysiaLogos = await optimize(malaysiaSources);
const apacLogos = await optimize(apacSources);
const allLogos = [...malaysiaLogos, ...apacLogos];

/* ── Advisory board — shown inside the immersive phase ──────────────── */
const advisorGlob = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/advisor/*.png",
  { eager: true },
);
const advisorPhoto = async (file: string) =>
  (
    await getImage({
      src: advisorGlob[`../assets/advisor/${file}`].default,
      format: "webp",
      width: 720,
    })
  ).src;

/* Chapter order: Rachel (founder) leads the board. */
const advisors = [
  {
    src: await advisorPhoto("Founder_Managing_Partner.png"),
    name: "Rachel Gui",
    role: "Founder & Managing Partner",
    tag: "Entrepreneur. Business Strategist. Growth Architect.",
    founder: true,
    points: [
      "Advises SMEs and growth companies on strategy, operational excellence, governance and AI adoption, with branding and lead generation systems designed to drive measurable sales and revenue growth",
      "Works closely with founders, investors and strategic buyers on fundraising, mergers & acquisitions (M&A), succession planning and regional expansion, supported by an active network of qualified buyers and consistent deal flow",
      "Supports cross-border business expansion across APAC, with experience helping Chinese, Japanese and Taiwanese companies establish and scale their operations in Malaysia",
      "Founder of ventures spanning corporate advisory, strategic marketing, AI & technology, professional education, healthcare and consumer businesses, bringing hands-on entrepreneurial experience across diverse industries",
      "President of Young Corporate Malaysians (YCM), leading a national platform dedicated to developing the next generation of business leaders and professionals",
      "Holds an LL.B (Hons), Executive MBA (EMBA) and VTO certification, and is a licensed Traditional Chinese Medicine (TCM) Therapist, bringing together legal, commercial and operational expertise with a multidisciplinary perspective",
    ],
  },
  {
    src: await advisorPhoto("Legal_Advisor_Esther.png"),
    name: "Esther Ong",
    role: "Legal Advisor",
    tag: "Three decades of courtroom authority and commercial legal insight.",
    founder: false,
    points: [
      "Founder of Messrs Esther Ong Tengku Saiful & Sree (est. 1999), a firm built around strategic legal advisory for SMEs and SMIs",
      "Appears regularly before all levels of the Malaysian courts, including the Federal Court, in complex commercial, employment and intellectual property disputes",
      "Finalist, ALB Malaysia Woman Lawyer of the Year — four consecutive years (2021–2025)",
      "Registered Patent, Trademark and Industrial Design Agent; certified mediator, arbitrator and ESG assessor",
      "Legal Counsel to the Federation of Malaysian Businesses' Association (FMBA)",
      "Founder of the Wholistic Family Foundation (WFF), reflecting a lifelong commitment to community leadership",
    ],
  },
  {
    src: await advisorPhoto("Academy_Advisor_Alex.png"),
    name: "Alex Hoo Chek Kuan 符庆源",
    role: "Academy Advisor",
    tag: "Connecting academia, industry and international partners.",
    founder: false,
    points: [
      "Business executive with 30+ years of leadership across business management, international education, strategic partnerships and organisational development",
      "International Executive MBA, with expertise in business strategy, cross-border collaboration, university partnerships and workforce transformation",
      "A proven bridge between universities, industry and international partners driving education, innovation and growth across Asia-Pacific",
      "Leads the development of professional training and executive education programmes in AI, Blockchain, Future Banking and Digital Transformation for future-ready organisations",
    ],
  },
  {
    src: await advisorPhoto("Regional_Advisor_Tonie.png"),
    name: "Tonie Natnawat",
    role: "Regional Advisor — Thailand & RCEP Markets",
    tag: "Opening doors across Thailand and the wider RCEP bloc.",
    founder: false,
    points: [
      "Chief Executive Officer, MagicSeed Asia Co., Ltd.",
      "Business leader with 25 years of experience in education development, science and technology, professional training and international collaboration",
      "MBA in Marketing, George Washington University (USA), with expertise in education partnerships, strategic business development and cross-border collaboration",
      "Extensive network across schools, universities, government agencies and private organisations throughout Asia-Pacific",
      "President of OBORSEANA Thailand, connecting businesses, investors and institutions across the 15 RCEP member countries to advance education, investment and regional economic cooperation",
    ],
  },
  {
    src: await advisorPhoto("Financial_Advisor_John.png"),
    name: "John Hew",
    role: "Finance Advisor",
    tag: "Bringing institutional financial discipline to a growing business.",
    founder: false,
    points: [
      "ACCA-qualified finance professional with 11 years of experience spanning FMCG, logistics, trading, audit and taxation",
      "Deep expertise in accounting, FP&A, business analysis and performance management",
      "Career built across leading names including Assa Abloy, CMA CGM, PappaRich and Beacon Hospital",
      "Currently supports the Greater China & Southeast Asia (GCSEA) region in FP&A, partnering with business leaders to drive strategic decisions and sustainable growth",
    ],
  },
];

---

<!-- Tall scroll container drives the animation -->
<section id="clients" class="cl-section" aria-labelledby="cl-heading">
  <div class="cl-scroll-spacer">
    <!-- Sticky viewport — stays pinned while user scrolls -->
    <div class="cl-sticky">
      <!-- Background overlay (darkens during zoom) -->
      <div class="cl-bg-overlay"></div>

      <!-- Header -->
      <div class="cl-header">
        <p class="cl-eyebrow">Our Clientele</p>
        <h2 class="cl-title" id="cl-heading">
          Trusted by <span class="cl-accent">35+</span> brands across APAC
        </h2>
      </div>

      <!-- OMO logo — the scroll zoom flies through the outlined last "O" -->
      <div class="cl-o-ring" aria-hidden="true">
        <img class="cl-o-logo" src={omoLogoSrc} alt="" />
      </div>

      <!-- Advisory Board — editorial chapters, panned by the scroll scrub -->
      <div class="cl-kaleidoscope">
        <div class="cl-k-disc">
          <div class="cl-adv-track">
            <!-- Chapter 00 — the board -->
            <section class="cl-adv-panel cl-adv-panel-intro" style="--pi: 0">
              <div class="cl-adv-intro-inner">
                <p class="cl-adv-eyebrow">Advisory Board</p>
                <h3 class="cl-adv-intro-title">
                  The minds behind<br /><em>the trust.</em>
                </h3>
                <p class="cl-adv-quote">
                  "A board of senior advisors drawn from across industries and
                  markets — decades of practical experience, brought to bear on
                  how we build, govern and grow."
                </p>
                <p class="cl-adv-hint">Keep scrolling <span>→</span></p>
              </div>
            </section>

            {
              advisors.map((a, i) => (
                <section
                  class={`cl-adv-panel${i % 2 === 0 ? " cl-adv-panel-flip" : ""}`}
                  style={`--pi: ${i + 1}`}
                >
                  <span class="cl-adv-num" aria-hidden="true">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <div class="cl-adv-panel-inner">
                    <div class="cl-adv-copy">
                      <p class="cl-adv-eyebrow">
                        Advisory Board — {String(i + 1).padStart(2, "0")} / 05
                      </p>
                      <h3 class="cl-adv-name">{a.name}</h3>
                      <p class="cl-adv-role">{a.role}</p>
                      <p class="cl-adv-tagline">{a.tag}</p>
                      <button class="cl-adv-view" type="button" data-adv={i}>
                        View profile <span>+</span>
                      </button>
                    </div>
                    <div class="cl-adv-portrait">
                      <img src={a.src} alt={a.name} loading="lazy" />
                    </div>
                  </div>
                </section>
              ))
            }
          </div>

          <!-- Progress rail — jump to any advisor -->
          <div class="cl-adv-rail">
            <div class="cl-adv-rail-bar"><span></span></div>
            <div class="cl-adv-rail-names">
              {
                advisors.map((a, i) => (
                  <button
                    type="button"
                    class="cl-adv-rail-tick"
                    data-tick={i}
                    aria-label={`Go to ${a.name}`}
                  >
                    {String(i + 1).padStart(2, "0")}
                    <em>{a.name.split(" ")[0]}</em>
                  </button>
                ))
              }
            </div>
          </div>

          <!-- Film grain -->
          <div class="cl-adv-grain" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Final settled logo grid (scrolls in naturally after spacer) -->
  <div class="cl-grid-container">
    <div class="cl-grid-header">
      <p class="cl-eyebrow">Our Clientele</p>
      <h2 class="cl-grid-title">
        Trusted by <span class="cl-accent">35+</span> brands across APAC
      </h2>
    </div>

    <div class="cl-grid-group">
      <h3 class="cl-grid-label">Malaysia Clientele</h3>
      <div class="cl-grid">
        {
          malaysiaLogos.map((logo) => (
            <div class="cl-grid-item">
              <img src={logo.src} alt={logo.alt} loading="lazy" />
            </div>
          ))
        }
      </div>
    </div>
    <div class="cl-grid-group">
      <h3 class="cl-grid-label">APAC Clientele</h3>
      <div class="cl-grid cl-grid-apac">
        {
          apacLogos.map((logo) => (
            <div class="cl-grid-item">
              <img src={logo.src} alt={logo.alt} loading="lazy" />
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Advisor detail modal (fixed overlay; outside the transformed stage) -->
  <div class="cl-adv-modal" aria-hidden="true">
    <div class="cl-adv-modal-backdrop" data-adv-close></div>
    <div class="cl-adv-modal-panel" role="dialog" aria-modal="true">
      <button
        class="cl-adv-modal-close"
        type="button"
        data-adv-close
        aria-label="Close">&times;</button
      >
      {
        advisors.map((a, i) => (
          <article class="cl-adv-detail" data-detail={i} hidden>
            <div class="cl-adv-detail-media">
              <img src={a.src} alt={a.name} loading="lazy" />
            </div>
            <div class="cl-adv-detail-body">
              <h3>{a.name}</h3>
              <p class="cl-adv-detail-role">{a.role}</p>
              <p class="cl-adv-detail-tag">{a.tag}</p>
              <ul>
                {a.points.map((p) => (
                  <li>{p}</li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* ── Section & scroll spacer ────────────────── */
  .cl-section {
    position: relative;
    overflow: clip;
  }
  .cl-scroll-spacer {
    /* Tall spacer = heavy scroll: the pinned animation is spread over
       ~5 viewport-heights of scrolling for a slow, immersive scrub */
    height: 620vh;
    position: relative;
  }

  /* ── Sticky viewport ────────────────────────── */
  .cl-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--light, #f7f7f5);
    transition: background 0.5s ease;
  }
  .cl-section.phase-zoom .cl-sticky,
  .cl-section.phase-kaleidoscope .cl-sticky {
    background: #0a0a0a;
  }

  /* ── Background overlay ─────────────────────── */
  .cl-bg-overlay {
    position: absolute;
    inset: 0;
    background: #0a0a0a;
    opacity: 0;
    transition: opacity 0.6s ease;
    z-index: 1;
    pointer-events: none;
  }
  .cl-section.phase-zoom .cl-bg-overlay,
  .cl-section.phase-kaleidoscope .cl-bg-overlay {
    opacity: 1;
  }

  /* ── Header ─────────────────────────────────── */
  .cl-header {
    position: absolute;
    top: 12vh;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    z-index: 10;
    transition:
      opacity 0.5s ease,
      transform 0.5s ease;
  }
  .cl-section.phase-zoom .cl-header,
  .cl-section.phase-kaleidoscope .cl-header {
    opacity: 0;
    transform: translateX(-50%) translateY(-30px);
    pointer-events: none;
  }

  .cl-eyebrow {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: #ed4823;
    margin-bottom: 16px;
    position: relative;
    padding: 0 20px;
  }
  .cl-eyebrow::before,
  .cl-eyebrow::after {
    content: "";
    position: absolute;
    top: 50%;
    width: 14px;
    height: 1.5px;
    background: #ed4823;
    transform: translateY(-50%);
  }
  .cl-eyebrow::before {
    right: 100%;
    margin-right: -18px;
  }
  .cl-eyebrow::after {
    left: 100%;
    margin-left: -18px;
  }

  .cl-title {
    font-family: var(--serif, "DM Serif Display", Georgia, serif);
    font-size: clamp(1.6rem, 3vw, 2.8rem);
    font-weight: 400;
    line-height: 1.2;
    color: #111;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }
  .cl-accent {
    color: #ed4823;
  }

  /* ── OMO logo ───────────────────────────────── */
  .cl-o-ring {
    position: absolute;
    top: calc(50% - 89px);
    left: calc(50% - 210px);
    width: 420px;
    z-index: 5;
    /* Zoom pivots on the centre of the outlined last "O" in the logo
       (measured at 84% / 38% of the logo image) */
    transform-origin: 84% 38%;
    /* No will-change here: the logo scales up to 34x, and pinning it to a
       cached GPU layer leaves a giant stale raster that breaks (jagged /
       partial artwork) when scrolling back after the kaleidoscope starts.
       Letting the browser re-rasterize keeps the logo crisp. */
    transition:
      opacity 0.4s ease,
      visibility 0.4s;
  }
  .cl-o-logo {
    display: block;
    width: 100%;
    height: auto;
    user-select: none;
    pointer-events: none;
  }
  .cl-section.phase-kaleidoscope .cl-o-ring {
    opacity: 0;
    /* visibility:hidden releases the huge scaled raster from GPU memory */
    visibility: hidden;
    pointer-events: none;
  }

  /* ── Kaleidoscope ───────────────────────────── */
  .cl-kaleidoscope {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 6;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    /* Fade IN handled by JS adding phase-kaleidoscope */
    transition:
      opacity 0.8s ease,
      visibility 0.8s;
  }
  /* Clickable while the advisory phase holds */
  .cl-section.phase-kaleidoscope .cl-kaleidoscope {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  /* ── Advisory chapters — editorial horizontal storytelling ──────────
     JS sets --tx (0 → 5) on the stage; the track pans one full viewport
     per chapter while numerals and portraits drift at their own depths. */
  .cl-k-disc {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .cl-adv-track {
    position: absolute;
    inset: 0;
    display: flex;
    transform: translateX(calc(var(--tx, 0) * -100%));
    will-change: transform;
  }

  .cl-adv-panel {
    flex: 0 0 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 8vw;
  }

  /* Ghost chapter numeral — drifts slower than the pan (depth layer) */
  .cl-adv-num {
    position: absolute;
    top: 50%;
    right: 2vw;
    font-family: var(--serif, "DM Serif Display", Georgia, serif);
    font-size: 36vw;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(255, 255, 255, 0.08);
    pointer-events: none;
    user-select: none;
    transform: translateY(-50%)
      translateX(calc((var(--tx, 0) - var(--pi, 0)) * 16vw));
  }

  .cl-adv-panel-inner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(2rem, 6vw, 7rem);
    width: 100%;
    max-width: 1200px;
  }

  .cl-adv-copy {
    max-width: 580px;
    position: relative;
    z-index: 2;
    opacity: 0.2;
    transform: translateY(16px);
    transition:
      opacity 0.5s ease,
      transform 0.5s ease;
  }
  .cl-adv-panel.is-active .cl-adv-copy {
    opacity: 1;
    transform: none;
  }

  .cl-adv-eyebrow {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: #ed4823;
    margin-bottom: 1rem;
  }
  .cl-adv-name {
    font-family: var(--serif, "DM Serif Display", Georgia, serif);
    font-size: clamp(2.2rem, 4.8vw, 4.4rem);
    font-weight: 400;
    line-height: 1.04;
    color: #fff;
    letter-spacing: -0.01em;
    margin-bottom: 1rem;
  }
  .cl-adv-role {
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #ed4823;
    margin-bottom: 0.9rem;
  }
  .cl-adv-tagline {
    font-family: var(--serif, "DM Serif Display", Georgia, serif);
    font-style: italic;
    font-size: clamp(1rem, 1.4vw, 1.25rem);
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.65);
    max-width: 460px;
  }
  .cl-adv-view {
    margin-top: 1.7rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: none;
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 100px;
    padding: 0.75rem 1.5rem;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #fff;
    cursor: pointer;
    transition:
      background 0.3s ease,
      border-color 0.3s ease,
      transform 0.3s ease;
  }
  .cl-adv-view:hover,
  .cl-adv-view:focus-visible {
    background: #ed4823;
    border-color: #ed4823;
    transform: translateY(-2px);
  }
  .cl-adv-view span {
    font-size: 0.9rem;
    line-height: 1;
  }

  /* Portrait — free-standing cut-out figure, never cropped. The photos
     have transparent backgrounds, so the advisor stands at near-full
     height, grounded on the bottom edge, overlapping the ghost numeral. */
  .cl-adv-portrait {
    position: absolute;
    right: clamp(2vw, 7vw, 9vw);
    /* Figures sit dropped ~20vh below the viewport edge, so their lower
       body bleeds off-screen — editorial "rising into frame" look */
    bottom: -20vh;
    height: min(76vh, 860px);
    pointer-events: none;
    opacity: 0.45;
    transition: opacity 0.5s ease;
  }
  .cl-adv-panel.is-active .cl-adv-portrait {
    opacity: 1;
  }
  /* Alternating chapters — Rachel / Alex / John flip: figure stands on
     the left, copy (and ghost numeral) move to the right */
  .cl-adv-panel-flip .cl-adv-portrait {
    right: auto;
    left: clamp(2vw, 7vw, 9vw);
  }
  .cl-adv-panel-flip .cl-adv-num {
    right: auto;
    left: 2vw;
  }
  .cl-adv-panel-flip .cl-adv-panel-inner {
    justify-content: flex-end;
  }

  .cl-adv-portrait img {
    display: block;
    height: 100%;
    width: auto;
    max-width: none;
    object-fit: contain;
    object-position: bottom;
    /* Soft grounding shadow on the figure itself (follows the cut-out) */
    filter: drop-shadow(0 30px 45px rgba(0, 0, 0, 0.5));
    /* Horizontal parallax against the pan */
    transform: translateX(calc((var(--tx, 0) - var(--pi, 0)) * -4vw));
  }

  /* Intro chapter */
  .cl-adv-panel-intro {
    text-align: center;
  }
  .cl-adv-intro-inner {
    max-width: 760px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .cl-adv-intro-title {
