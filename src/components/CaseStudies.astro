---
/* ═══════════════════════════════════════════════
   ADVISORY BOARD — OMO logo fly-through intro,
   then a simple white-background showcase of the
   five advisors (click a card for the full bio).
═══════════════════════════════════════════════ */
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import omoLogo from "../assets/omo_logo.png";

const omoLogoSrc = (await getImage({ src: omoLogo, format: "webp" })).src;

const advisorGlob = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/advisor/*.png",
  { eager: true },
);
const advisorPhoto = async (file: string) =>
  (
    await getImage({
      src: advisorGlob[`../assets/advisor/${file}`].default,
      format: "webp",
      width: 720,
    })
  ).src;

/* Display order: Rachel (founder) leads the board. */
const advisors = [
  {
    src: await advisorPhoto("Founder_Managing_Partner.png"),
    name: "Rachel Gui",
    role: "Founder & Managing Partner",
    tag: "Entrepreneur. Business Strategist. Growth Architect.",
    points: [
      "Advises SMEs and growth companies on strategy, operational excellence, governance and AI adoption, with branding and lead generation systems designed to drive measurable sales and revenue growth",
      "Works closely with founders, investors and strategic buyers on fundraising, mergers & acquisitions (M&A), succession planning and regional expansion, supported by an active network of qualified buyers and consistent deal flow",
      "Supports cross-border business expansion across APAC, with experience helping Chinese, Japanese and Taiwanese companies establish and scale their operations in Malaysia",
      "Founder of ventures spanning corporate advisory, strategic marketing, AI & technology, professional education, healthcare and consumer businesses, bringing hands-on entrepreneurial experience across diverse industries",
      "President of Young Corporate Malaysians (YCM), leading a national platform dedicated to developing the next generation of business leaders and professionals",
      "Holds an LL.B (Hons), Executive MBA (EMBA) and VTO certification, and is a licensed Traditional Chinese Medicine (TCM) Therapist, bringing together legal, commercial and operational expertise with a multidisciplinary perspective",
    ],
  },
  {
    src: await advisorPhoto("Legal_Advisor_Esther.png"),
    name: "Esther Ong",
    role: "Legal Advisor",
    tag: "Three decades of courtroom authority and commercial legal insight.",
    points: [
      "Founder of Messrs Esther Ong Tengku Saiful & Sree (est. 1999), a firm built around strategic legal advisory for SMEs and SMIs",
      "Appears regularly before all levels of the Malaysian courts, including the Federal Court, in complex commercial, employment and intellectual property disputes",
      "Finalist, ALB Malaysia Woman Lawyer of the Year — four consecutive years (2021–2025)",
      "Registered Patent, Trademark and Industrial Design Agent; certified mediator, arbitrator and ESG assessor",
      "Legal Counsel to the Federation of Malaysian Businesses' Association (FMBA)",
      "Founder of the Wholistic Family Foundation (WFF), reflecting a lifelong commitment to community leadership",
    ],
  },
  {
    src: await advisorPhoto("Academy_Advisor_Alex.png"),
    name: "Alex Hoo Chek Kuan 符庆源",
    role: "Academy Advisor",
    tag: "Connecting academia, industry and international partners.",
    points: [
      "Business executive with 30+ years of leadership across business management, international education, strategic partnerships and organisational development",
      "International Executive MBA, with expertise in business strategy, cross-border collaboration, university partnerships and workforce transformation",
      "A proven bridge between universities, industry and international partners driving education, innovation and growth across Asia-Pacific",
      "Leads the development of professional training and executive education programmes in AI, Blockchain, Future Banking and Digital Transformation for future-ready organisations",
    ],
  },
  {
    src: await advisorPhoto("Regional_Advisor_Tonie.png"),
    name: "Tonie Natnawat",
    role: "Regional Advisor — Thailand & RCEP Markets",
    tag: "Opening doors across Thailand and the wider RCEP bloc.",
    points: [
      "Chief Executive Officer, MagicSeed Asia Co., Ltd.",
      "Business leader with 25 years of experience in education development, science and technology, professional training and international collaboration",
      "MBA in Marketing, George Washington University (USA), with expertise in education partnerships, strategic business development and cross-border collaboration",
      "Extensive network across schools, universities, government agencies and private organisations throughout Asia-Pacific",
      "President of OBORSEANA Thailand, connecting businesses, investors and institutions across the 15 RCEP member countries to advance education, investment and regional economic cooperation",
    ],
  },
  {
    src: await advisorPhoto("Financial_Advisor_John.png"),
    name: "John Hew",
    role: "Finance Advisor",
    tag: "Bringing institutional financial discipline to a growing business.",
    points: [
      "ACCA-qualified finance professional with 11 years of experience spanning FMCG, logistics, trading, audit and taxation",
      "Deep expertise in accounting, FP&A, business analysis and performance management",
      "Career built across leading names including Assa Abloy, CMA CGM, PappaRich and Beacon Hospital",
      "Currently supports the Greater China & Southeast Asia (GCSEA) region in FP&A, partnering with business leaders to drive strategic decisions and sustainable growth",
    ],
  },
];
---

<!-- Tall scroll container drives the animation -->
<section id="advisory-board" class="cl-section" aria-labelledby="cl-heading">
  <div class="cl-scroll-spacer">
    <!-- Sticky viewport — stays pinned while user scrolls -->
    <div class="cl-sticky">
      <!-- Header (initial phase) -->
      <div class="cl-header">
        <p class="cl-eyebrow">Advisory Board</p>
        <h2 class="cl-title" id="cl-heading">
          Senior advisors behind <span class="cl-accent">every growth decision</span>
        </h2>
      </div>

      <!-- OMO logo — the scroll zoom flies through the outlined last "O" -->
      <div class="cl-o-ring" aria-hidden="true">
        <img class="cl-o-logo" src={omoLogoSrc} alt="" />
      </div>

      <!-- Advisory showcase (revealed after the fly-through) -->
      <div class="cl-advisory">
        <div class="cl-adv-head">
          <p class="cl-eyebrow">Advisory Board</p>
          <p class="cl-adv-quote">
            "A board of senior advisors drawn from across industries and
            markets — decades of practical experience, brought to bear on how
            we build, govern and grow."
          </p>
        </div>
        <div class="cl-adv-row">
          {
            advisors.map((a, i) => (
              <button
                class="cl-adv-card"
                type="button"
                data-adv={i}
                style={`--d: ${i * 90}ms`}
                aria-label={`View profile: ${a.name}, ${a.role}`}
              >
                <span class="cl-adv-photo">
                  <img src={a.src} alt={a.name} loading="lazy" />
                </span>
                <strong class="cl-adv-name">{a.name}</strong>
                <em class="cl-adv-role">{a.role}</em>
                <span class="cl-adv-view">View profile +</span>
              </button>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <!-- Advisor detail modal (fixed overlay) -->
  <div class="cl-adv-modal" aria-hidden="true">
    <div class="cl-adv-modal-backdrop" data-adv-close></div>
    <div class="cl-adv-modal-panel" role="dialog" aria-modal="true">
      <button
        class="cl-adv-modal-close"
        type="button"
        data-adv-close
        aria-label="Close">&times;</button
      >
      {
        advisors.map((a, i) => (
          <article class="cl-adv-detail" data-detail={i} hidden>
            <div class="cl-adv-detail-media">
              <img src={a.src} alt={a.name} loading="lazy" />
            </div>
            <div class="cl-adv-detail-body">
              <h3>{a.name}</h3>
              <p class="cl-adv-detail-role">{a.role}</p>
              <p class="cl-adv-detail-tag">{a.tag}</p>
              <ul>
                {a.points.map((p) => (
                  <li>{p}</li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* ── Section & scroll spacer ────────────────── */
  .cl-section {
    position: relative;
    overflow: clip;
  }
  .cl-scroll-spacer {
    /* Spacer drives the pinned intro: logo at rest → zoom through the O
       → advisory showcase */
    height: 300vh;
    position: relative;
  }

  /* ── Sticky viewport — white throughout ─────── */
  .cl-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #ffffff;
  }

  /* ── Header ─────────────────────────────────── */
  .cl-header {
    position: absolute;
    top: 12vh;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    z-index: 10;
    transition:
      opacity 0.5s ease,
      transform 0.5s ease;
  }
  .cl-section.phase-zoom .cl-header,
  .cl-section.phase-advisory .cl-header {
    opacity: 0;
    transform: translateX(-50%) translateY(-30px);
    pointer-events: none;
  }

  .cl-eyebrow {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: #ed4823;
    margin-bottom: 16px;
    position: relative;
    padding: 0 20px;
  }
  .cl-eyebrow::before,
  .cl-eyebrow::after {
    content: "";
    position: absolute;
    top: 50%;
    width: 14px;
    height: 1.5px;
    background: #ed4823;
    transform: translateY(-50%);
  }
  .cl-eyebrow::before {
    right: 100%;
    margin-right: -18px;
  }
  .cl-eyebrow::after {
    left: 100%;
    margin-left: -18px;
  }

  .cl-title {
    font-family: var(--serif, "DM Serif Display", Georgia, serif);
    font-size: clamp(1.6rem, 3vw, 2.8rem);
    font-weight: 400;
    line-height: 1.2;
    color: #111;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }
  .cl-accent {
    color: #ed4823;
  }

  /* ── OMO logo ───────────────────────────────── */
  .cl-o-ring {
    position: absolute;
    top: calc(50% - 89px);
    left: calc(50% - 210px);
    width: 420px;
    z-index: 5;
    /* Zoom pivots on the centre of the outlined last "O" in the logo
       (measured at 84% / 38% of the logo image) */
    transform-origin: 84% 38%;
    /* No will-change here: the logo scales up to 34x, and pinning it to a
       cached GPU layer leaves a giant stale raster that breaks (jagged /
       partial artwork) when scrolling back after the reveal. Letting the
       browser re-rasterize keeps the logo crisp. */
    transition:
      opacity 0.4s ease,
      visibility 0.4s;
  }
  .cl-o-logo {
    display: block;
    width: 100%;
    height: auto;
    user-select: none;
    pointer-events: none;
  }
  .cl-section.phase-advisory .cl-o-ring {
    opacity: 0;
    /* visibility:hidden releases the huge scaled raster from GPU memory */
    visibility: hidden;
    pointer-events: none;
  }

  /* ── Advisory showcase — simple, white ──────── */
  .cl-advisory {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(1.5rem, 4vh, 2.8rem);
    padding: 0 5vw;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity 0.6s ease,
      visibility 0.6s;
    z-index: 6;
  }
  .cl-section.phase-advisory .cl-advisory {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .cl-adv-head {
    text-align: center;
    max-width: 720px;
  }
  .cl-adv-quote {
    font-family: var(--serif, "DM Serif Display", Georgia, serif);
    font-style: italic;
    font-size: clamp(0.98rem, 1.5vw, 1.25rem);
    line-height: 1.55;
    color: #555;
  }

  .cl-adv-row {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: clamp(1rem, 2.2vw, 2rem);
  }

  .cl-adv-card {
    background: none;
    border: 0;
    padding: 0;
    cursor: pointer;
    width: clamp(140px, 15vw, 200px);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    /* Staggered entrance when the phase reveals (per-card delay --d) */
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.5s ease var(--d, 0ms),
      transform 0.5s ease var(--d, 0ms);
  }
  .cl-section.phase-advisory .cl-adv-card {
    opacity: 1;
    transform: none;
  }

  .cl-adv-photo {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    width: 100%;
    aspect-ratio: 3 / 4;
    background: #f4f3f0;
    border-radius: 12px;
    overflow: hidden;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }
  .cl-adv-photo img {
    height: 96%;
    width: auto;
    max-width: 94%;
    object-fit: contain;
    object-position: bottom;
  }
  .cl-adv-card:hover .cl-adv-photo,
  .cl-adv-card:focus-visible .cl-adv-photo {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.12);
  }

  .cl-adv-name {
    margin-top: 0.85rem;
    font-family: var(--sans, "DM Sans", system-ui, sans-serif);
    font-size: 0.95rem;
    font-weight: 700;
    color: #111;
    line-height: 1.3;
  }
  .cl-adv-role {
    font-style: normal;
    margin-top: 0.2rem;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #ed4823;
    line-height: 1.4;
  }
  .cl-adv-view {
    margin-top: 0.5rem;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #999;
    transition: color 0.25s ease;
  }
  .cl-adv-card:hover .cl-adv-view,
  .cl-adv-card:focus-visible .cl-adv-view {
    color: #ed4823;
  }

  /* ── Advisor detail modal (light theme) ─────── */
  .cl-adv-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.3s ease,
      visibility 0.3s;
  }
  .cl-adv-modal.open {
    opacity: 1;
    visibility: visible;
  }
  .cl-adv-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(20, 20, 20, 0.45);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .cl-adv-modal-panel {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: min(880px, 92vw);
    max-height: 86vh;
    overflow-y: auto;
    /* Internal scrolling must not chain to the page behind */
    overscroll-behavior: contain;
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 16px;
    box-shadow: 0 40px 120px rgba(0, 0, 0, 0.3);
  }
  .cl-adv-modal-close {
    position: sticky;
    top: 0.8rem;
    margin-left: calc(100% - 3rem);
    margin-right: 0.8rem;
    width: 2.2rem;
    height: 2.2rem;
    border: 1px solid rgba(0, 0, 0, 0.15);
    border-radius: 50%;
    background: #fff;
    color: #111;
    font-size: 1.2rem;
    line-height: 1;
    cursor: pointer;
    z-index: 2;
  }
  .cl-adv-detail {
    display: flex;
    gap: 2rem;
    padding: 0 2.2rem 2.2rem;
  }
  /* Only the clicked advisor's article is shown — without this, the
     display:flex above would override the [hidden] attribute */
  .cl-adv-detail[hidden] {
    display: none;
  }
  .cl-adv-detail-media {
    flex: 0 0 240px;
  }
  .cl-adv-detail-media img {
    width: 100%;
    border-radius: 12px;
    display: block;
    background: #f4f3f0;
  }
  .cl-adv-detail-body h3 {
    font-family: var(--serif, "DM Serif Display", Georgia, serif);
    font-size: clamp(1.4rem, 2.2vw, 1.9rem);
    font-weight: 400;
    color: #111;
    margin-bottom: 0.3rem;
  }
  .cl-adv-detail-role {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #ed4823;
    margin-bottom: 0.7rem;
  }
  .cl-adv-detail-tag {
    font-family: var(--serif, "DM Serif Display", Georgia, serif);
    font-style: italic;
    font-size: 1rem;
    color: #555;
    margin-bottom: 1.1rem;
  }
  .cl-adv-detail-body ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 0;
  }
  .cl-adv-detail-body li {
    position: relative;
    padding-left: 1.1rem;
    font-size: 0.85rem;
    line-height: 1.65;
    color: #444;
  }
  .cl-adv-detail-body li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.62em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #ed4823;
  }

  /* ── Mobile ─────────────────────────────────── */
  @media (max-width: 767px) {
    .cl-scroll-spacer {
      height: 240vh;
    }
    .cl-o-ring {
      width: 280px;
      top: calc(50% - 59px);
      left: calc(50% - 140px);
    }
    .cl-header {
      top: 8vh;
    }
    .cl-title {
      white-space: normal;
      padding: 0 1rem;
    }
    .cl-advisory {
      gap: 1.2rem;
    }
    .cl-adv-quote {
      font-size: 0.9rem;
    }
    .cl-adv-row {
      gap: 0.9rem;
    }
    .cl-adv-card {
      width: 27vw;
    }
    .cl-adv-name {
      font-size: 0.78rem;
    }
    .cl-adv-role {
      font-size: 0.55rem;
    }
    .cl-adv-detail {
      flex-direction: column;
      padding: 0 1.2rem 1.4rem;
      gap: 1.2rem;
    }
    .cl-adv-detail-media {
      flex: none;
      width: 55%;
      margin: 0 auto;
    }
  }
</style>

<script>
  const clientsSection = document.getElementById("advisory-board");
  if (clientsSection) {
    const section = clientsSection;
    const spacer = section.querySelector(".cl-scroll-spacer") as HTMLElement;
    const oRing = section.querySelector(".cl-o-ring") as HTMLElement;

    let ticking = false;
    let currentPhase = "";

    // ── Advisor detail modal ─────────────────────────────────────────
    const advCards = Array.from(
      section.querySelectorAll(".cl-adv-card"),
    ) as HTMLElement[];
    const advModal = section.querySelector(".cl-adv-modal") as HTMLElement;
    const advDetails = Array.from(
      section.querySelectorAll(".cl-adv-detail"),
    ) as HTMLElement[];

    // Hard scroll lock: fixing the body freezes the page (wheel, touch
    // and momentum scrolling included) at its exact position.
    let lockedScrollY = 0;
    function lockScroll() {
      lockedScrollY = window.scrollY;
      document.body.style.position = "fixed";
      document.body.style.top = `-${lockedScrollY}px`;
      document.body.style.left = "0";
      document.body.style.right = "0";
      document.body.style.width = "100%";
    }
    function unlockScroll() {
      document.body.style.position = "";
      document.body.style.top = "";
      document.body.style.left = "";
      document.body.style.right = "";
      document.body.style.width = "";
      window.scrollTo(0, lockedScrollY);
    }

    function openAdvisor(i: number) {
      advDetails.forEach((d, j) => {
        d.hidden = j !== i;
      });
      advModal.classList.add("open");
      advModal.setAttribute("aria-hidden", "false");
      lockScroll();
    }
    function closeAdvisor() {
      if (!advModal.classList.contains("open")) return;
      advModal.classList.remove("open");
      advModal.setAttribute("aria-hidden", "true");
      unlockScroll();
    }

    advCards.forEach((card) => {
      card.addEventListener("click", () => {
        openAdvisor(Number(card.dataset.adv));
      });
    });
    advModal.querySelectorAll("[data-adv-close]").forEach((el) => {
      el.addEventListener("click", closeAdvisor);
    });
    window.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeAdvisor();
    });

    // ── Scroll-driven phases ─────────────────────────────────────────
    // Zoom transform for the OMO logo: scales about the outlined last "O"
    // (transform-origin 84% / 38%) while drifting it to the viewport
    // centre, so the fly-through passes through the middle of the screen.
    const O_X = 0.84;
    const O_Y = 0.38;
    function oZoomTransform(p: number) {
      const dx = (0.5 - O_X) * oRing.offsetWidth * p;
      const dy = (0.5 - O_Y) * oRing.offsetHeight * p;
      return `translate(${dx}px, ${dy}px) scale(${1 + p * 33})`;
    }

    function updatePhase() {
      const rect = spacer.getBoundingClientRect();
      const totalScroll = rect.height - window.innerHeight;
      if (totalScroll <= 0) {
        ticking = false;
        return;
      }
      const progress = Math.max(0, Math.min(1, -rect.top / totalScroll));

      // Phases: intro 6% / zoom 44% / advisory showcase 50%
      let newPhase = "";
      if (progress < 0.06) {
        newPhase = "initial";
      } else if (progress < 0.5) {
        newPhase = "zoom";
      } else {
        newPhase = "advisory";
      }

      if (newPhase !== currentPhase) {
        section.classList.remove("phase-zoom", "phase-advisory");
        if (newPhase === "zoom") {
          section.classList.add("phase-zoom");
        } else if (newPhase === "advisory") {
          section.classList.add("phase-advisory");
        }
        currentPhase = newPhase;
      }

      if (newPhase === "initial") {
        oRing.style.transform = "scale(1)";
      } else if (newPhase === "zoom") {
        const zp = (progress - 0.06) / 0.44;
        oRing.style.transform = oZoomTransform(zp);
      } else {
        oRing.style.transform = oZoomTransform(1);
      }

      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        window.requestAnimationFrame(updatePhase);
        ticking = true;
      }
    }

    // Only track scroll while the section is on screen
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            window.addEventListener("scroll", onScroll, { passive: true });
            onScroll();
          } else {
            window.removeEventListener("scroll", onScroll);
            section.classList.remove("phase-zoom", "phase-advisory");
            oRing.style.transform = "scale(1)";
            closeAdvisor();
            currentPhase = "";
          }
        });
      },
      { threshold: 0 },
    );
    observer.observe(section);

    // Initial call
    onScroll();
  }
</script>
