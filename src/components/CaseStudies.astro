<style>
/* ─────────────────────────────────────
   PORTFOLIO — VERTICAL STICKY
───────────────────────────────────── */
    #clients {
      background: var(--white);
      padding: 7rem 0;
      display: block
    }

    .pv-wrap {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 5%;
      display: grid;
      grid-template-columns: 260px 1fr;
      gap: 5rem;
      align-items: start
    }

    /* LEFT sticky */
    .pv-left {
      position: sticky;
      top: 8rem;
      z-index: 50
    }

    .pv-title {
      font-family: var(--serif);
      font-weight: 300;
      font-size: clamp(2rem, 3.5vw, 3rem);
      color: var(--dark2);
      line-height: 1.05;
      letter-spacing: -.02em;
      margin-bottom: .9rem
    }

    .pv-title em {
      font-style: italic;
      color: var(--orange)
    }

    .pv-desc {
      font-size: .85rem;
      color: var(--mid);
      line-height: 1.85;
      font-weight: 300;
      margin-bottom: 2rem;
      max-width: 240px
    }

    /* Filter pills */
    .pv-cats {
      display: flex;
      flex-direction: column;
      gap: .45rem;
      position: relative;
      z-index: 50
    }

    .pf {
      display: flex;
      align-items: center;
      gap: .6rem;
      font-family: var(--sans);
      font-size: .78rem;
      font-weight: 500;
      padding: .55rem 1rem;
      border-radius: 100px;
      border: 1.5px solid var(--border);
      background: var(--white);
      color: var(--mid);
      cursor: pointer;
      transition: all .2s;
      text-align: left;
      width: fit-content;
      position: relative;
      z-index: 50;
    }

    .pf em {
      font-style: normal;
      font-size: .68rem;
      font-weight: 400;
      background: rgba(0, 0, 0, .06);
      padding: .1rem .45rem;
      border-radius: 100px;
      margin-left: .3rem
    }

    .pf::before {
      content: '';
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--border);
      flex-shrink: 0;
      transition: background .2s
    }

    .pf:hover {
      border-color: var(--orange);
      color: var(--orange)
    }

    .pf:hover::before {
      background: var(--orange)
    }

    .pf.active {
      background: var(--orange);
      border-color: var(--orange);
      color: #fff
    }

    .pf.active::before {
      background: rgba(255, 255, 255, .7)
    }

    .pf.active em {
      background: rgba(255, 255, 255, .2);
      color: #fff
    }

    /* RIGHT cards grid */
    .pv-right {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.4rem;
      align-items: start
    }

    /* Card */
    .pvc {
      border-radius: 18px;
      position: relative
    }

    .pvc:nth-child(even) {
      margin-top: 2.5rem
    }

    .pvc.hide {
      display: none
    }

    /* The <a> IS the card — make it fully clickable */
    .pvc>a {
      display: block;
      text-decoration: none;
      color: inherit;
      border-radius: 18px;
      overflow: hidden;
      border: 1.5px solid var(--border);
      background: var(--white);
      box-shadow: 0 4px 20px rgba(0, 0, 0, .06);
      transition: transform .3s ease, box-shadow .3s ease;
      cursor: pointer;
      position: relative;
      z-index: 1;
    }

    .pvc>a:hover {
      transform: translateY(-6px) scale(1.01);
      box-shadow: 0 20px 56px rgba(0, 0, 0, .13);
    }

    /* Bar */
    .pvc-bar {
      background: var(--dark2);
      padding: .6rem .9rem;
      display: flex;
      align-items: center;
      gap: .5rem
    }

    .pvc-dots {
      display: flex;
      gap: 4px;
      flex-shrink: 0
    }

    .pvd {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      display: inline-block
    }

    .pvd.r {
      background: #FF5F57
    }

    .pvd.y {
      background: #FEBC2E
    }

    .pvd.g {
      background: #28C840
    }

    .pvc-handle {
      font-size: .62rem;
      color: rgba(255, 255, 255, .55);
      flex: 1;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap
    }

    .pvc-ico {
      width: 15px;
      height: 15px;
      border-radius: 4px;
      flex-shrink: 0
    }

    /* Image */
    .pvc-img {
      position: relative;
      overflow: hidden;
      height: 320px
    }

    .pvc-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top;
      display: block;
      transition: object-position 5s ease;
      pointer-events: none
    }

    .pvc>a:hover .pvc-img img {
      object-position: center 55%
    }

    /* Hover overlay — purely visual, no pointer blocking */
    .pvc-ov {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background .3s;
      pointer-events: none;
    }

    .pvc>a:hover .pvc-ov {
      background: rgba(0, 0, 0, .38)
    }

    .pvc-btn {
      display: inline-flex;
      align-items: center;
      gap: .4rem;
      color: #fff;
      font-size: .74rem;
      font-weight: 600;
      padding: .6rem 1.1rem;
      border-radius: 100px;
      opacity: 0;
      transform: translateY(10px);
      transition: opacity .22s, transform .22s;
      letter-spacing: .03em;
      box-shadow: 0 4px 16px rgba(0, 0, 0, .25);
      pointer-events: none;
    }

    .pvc>a:hover .pvc-btn {
      opacity: 1;
      transform: translateY(0)
    }

    /* Footer */
    .pvc-foot {
      padding: .85rem 1rem;
      background: var(--white);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: .5rem;
    }

    .pvc-brand {
      display: block;
      font-size: .85rem;
      font-weight: 700;
      color: var(--dark2);
      margin-bottom: .25rem
    }

    .pvc-tag {
      font-size: .58rem;
      font-weight: 700;
      letter-spacing: .1em;
      text-transform: uppercase;
      padding: .2rem .65rem;
      border-radius: 100px;
      display: inline-block
    }

    .pvc-arr {
      width: 28px;
      height: 28px;
      flex-shrink: 0;
      border-radius: 50%;
      background: var(--light);
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: .75rem;
      color: var(--mid);
      transition: background .2s, color .2s, transform .2s;
    }

    .pvc>a:hover .pvc-arr {
      background: var(--orange);
      border-color: var(--orange);
      color: #fff;
      transform: scale(1.1)
    }

    /* Responsive */
    @media(max-width:960px) {
      .pv-wrap {
        grid-template-columns: 1fr;
        gap: 2rem
      }

      .pv-left {
        position: static
      }

      .pv-cats {
        flex-direction: row;
        flex-wrap: wrap
      }

      .pv-right {
        grid-template-columns: 1fr 1fr
      }

      .pvc:nth-child(even) {
        margin-top: 0
      }
    }

    @media(max-width:600px) {
      #clients {
        padding: 5rem 0
      }

      .pv-right {
        grid-template-columns: 1fr
      }

      .pvc-img {
        height: 260px
      }
    }
</style>

<script>
// ── Portfolio Vertical ──
    (function () {
      const cats = document.getElementById('pvCats');
      const grid = document.getElementById('pvGrid');
      if (!grid) return;
      const all = Array.from(grid.querySelectorAll('.pvc'));

      // Scroll-reveal animation
      const sr = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.style.opacity = '1';
            e.target.style.transform = 'translateY(0)';
            sr.unobserve(e.target);
          }
        });
      }, { threshold: 0.08 });

      all.forEach((c, i) => {
        c.style.opacity = '0';
        c.style.transform = 'translateY(24px)';
        c.style.transition = 'opacity 0.5s ease ' + (i % 2 === 1 ? '0.12' : '0') + 's, transform 0.5s ease ' + (i % 2 === 1 ? '0.12' : '0') + 's';
        sr.observe(c);
      });

      // Category filter — direct onclick on each button
      document.querySelectorAll('.pf').forEach(btn => {
        btn.onclick = function (e) {
          e.stopPropagation();
          document.querySelectorAll('.pf').forEach(b => b.classList.remove('active'));
          this.classList.add('active');
          const cat = this.dataset.cat;
          all.forEach(c => {
            if (cat === 'All' || c.dataset.cat === cat) {
              c.classList.remove('hide');
              c.style.display = '';
            } else {
              c.classList.add('hide');
              c.style.display = 'none';
            }
          });
        };
      });
    })();
</script>
