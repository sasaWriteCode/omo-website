</style>

<script>
  const clientsSection = document.getElementById("clients");
  if (clientsSection) {
    const section = clientsSection;
    const spacer = section.querySelector(".cl-scroll-spacer") as HTMLElement;
    const oRing = section.querySelector(".cl-o-ring") as HTMLElement;

    let ticking = false;
    let currentPhase = "";

    const kDisc = section.querySelector(".cl-k-disc") as HTMLElement;

    // ── Advisory chapters: horizontal pan + detail modal ─────────────
    const advPanels = Array.from(
      section.querySelectorAll(".cl-adv-panel"),
    ) as HTMLElement[];
    const advTicks = Array.from(
      section.querySelectorAll(".cl-adv-rail-tick"),
    ) as HTMLElement[];
    const advViews = Array.from(
      section.querySelectorAll(".cl-adv-view"),
    ) as HTMLElement[];
    const advModal = section.querySelector(".cl-adv-modal") as HTMLElement;
    const advDetails = Array.from(
      section.querySelectorAll(".cl-adv-detail"),
    ) as HTMLElement[];

    // ── Magnetic chapter mapping ─────────────────────────────────────
    // Each chapter owns a dwell plateau (track sits EXACTLY on that
    // chapter — photo and copy always aligned) followed by a short eased
    // transition to the next. The intro dwells longest so the manifesto
    // can be read; resting between two chapters is impossible.
    const DWELLS = [1.7, 1, 1, 1, 1, 1.2]; // intro, 5 advisors
    const TRANSITION = 0.5;
    type Seg = { start: number; len: number; move: boolean; i: number };
    const segs: Seg[] = [];
    let segAcc = 0;
    DWELLS.forEach((d, i) => {
      segs.push({ start: segAcc, len: d, move: false, i });
      segAcc += d;
      if (i < DWELLS.length - 1) {
        segs.push({ start: segAcc, len: TRANSITION, move: true, i });
        segAcc += TRANSITION;
      }
    });
    const SEG_TOTAL = segAcc;

    function chapterTrack(kp: number) {
      const u = Math.max(0, Math.min(1, kp)) * SEG_TOTAL;
      for (const s of segs) {
        if (u <= s.start + s.len) {
          if (!s.move) return s.i;
          const t = (u - s.start) / s.len;
          return s.i + t * t * (3 - 2 * t); // smoothstep = magnetic snap
        }
      }
      return DWELLS.length - 1;
    }

    function setAdvProgress(kp: number) {
      const tx = chapterTrack(kp);
      kDisc.style.setProperty("--tx", String(tx));
      const active = Math.round(tx);
      advPanels.forEach((p, i) => {
        p.classList.toggle("is-active", i === active);
      });
      advTicks.forEach((t, i) => {
        t.classList.toggle("is-active", i + 1 === active);
      });
    }

    // Rail tick → scroll the page to the middle of that advisor's dwell
    function scrollToChapter(i: number) {
      const dwell = segs.find((s) => !s.move && s.i === i + 1);
      if (!dwell) return;
      const kp = (dwell.start + dwell.len / 2) / SEG_TOTAL;
      const spacerTop = spacer.getBoundingClientRect().top + window.scrollY;
      const total = spacer.offsetHeight - window.innerHeight;
      window.scrollTo({
        top: spacerTop + (0.36 + kp * 0.64) * total,
        behavior: "smooth",
      });
    }
    advTicks.forEach((tick) => {
      tick.addEventListener("click", () => {
        scrollToChapter(Number(tick.dataset.tick));
      });
    });

    // Hard scroll lock: fixing the body freezes the page (wheel, touch
    // and momentum scrolling included) at its exact position, so the
    // pinned phase can't shift while a bio is open.
    let lockedScrollY = 0;
    function lockScroll() {
      lockedScrollY = window.scrollY;
      document.body.style.position = "fixed";
      document.body.style.top = `-${lockedScrollY}px`;
      document.body.style.left = "0";
      document.body.style.right = "0";
      document.body.style.width = "100%";
    }
    function unlockScroll() {
      document.body.style.position = "";
      document.body.style.top = "";
      document.body.style.left = "";
      document.body.style.right = "";
      document.body.style.width = "";
      window.scrollTo(0, lockedScrollY);
    }

    function openAdvisor(i: number) {
      // Show only the clicked advisor's bio
      advDetails.forEach((d, j) => {
        d.hidden = j !== i;
      });
      advModal.classList.add("open");
      advModal.setAttribute("aria-hidden", "false");
      lockScroll();
    }
    function closeAdvisor() {
      if (!advModal.classList.contains("open")) return;
      advModal.classList.remove("open");
      advModal.setAttribute("aria-hidden", "true");
      unlockScroll();
    }

    advViews.forEach((btn) => {
      btn.addEventListener("click", () => {
        openAdvisor(Number(btn.dataset.adv));
      });
    });
    advModal.querySelectorAll("[data-adv-close]").forEach((el) => {
      el.addEventListener("click", closeAdvisor);
    });
    window.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeAdvisor();
    });

    // Zoom transform for the OMO logo: scales about the outlined last "O"
    // (transform-origin 84% / 38%) while drifting it to the viewport centre,
    // so the fly-through passes through the middle of the screen.
    const O_X = 0.84;
    const O_Y = 0.38;
    function oZoomTransform(p: number) {
      const dx = (0.5 - O_X) * oRing.offsetWidth * p;
      const dy = (0.5 - O_Y) * oRing.offsetHeight * p;
      return `translate(${dx}px, ${dy}px) scale(${1 + p * 33})`;
    }

    function updatePhase() {
      const rect = spacer.getBoundingClientRect();
      const spacerHeight = rect.height;
      const viewportHeight = window.innerHeight;

      const scrolled = -rect.top;
      const totalScroll = spacerHeight - viewportHeight;

      if (totalScroll <= 0) {
        ticking = false;
        return;
      }

      const progress = Math.max(0, Math.min(1, scrolled / totalScroll));

      // Determine new phase.
      // Dwell budget: intro 4% / zoom 32% / advisory board 64% — after the
      // advisory holds, the sticky simply unpins and normal scrolling
      // carries the visitor into the clientele grid below.
      let newPhase = "";
      if (progress < 0.04) {
        newPhase = "initial";
      } else if (progress < 0.36) {
        newPhase = "zoom";
      } else {
        newPhase = "kaleidoscope";
      }

      // Update DOM classes ONLY when the phase shifts
      if (newPhase !== currentPhase) {
        section.classList.remove("phase-zoom", "phase-kaleidoscope");

        if (newPhase === "zoom") {
          section.classList.add("phase-zoom");
        } else if (newPhase === "kaleidoscope") {
          section.classList.add("phase-kaleidoscope");
        }

        currentPhase = newPhase;
      }

      // Apply scroll-driven animations based on current phase
      if (newPhase === "initial") {
        // ── Initial: logo at rest ────────────────────
        oRing.style.transform = "scale(1)";
        setAdvProgress(0);

      } else if (newPhase === "zoom") {
        // ── Phase: O zoom in ─────────────────────────
        const zp = (progress - 0.04) / 0.32;
        oRing.style.transform = oZoomTransform(zp);
        setAdvProgress(0);

      } else {
        // ── Phase: Advisory chapters — scrub pans the editorial track ──
        const kp = (progress - 0.36) / 0.64;
        oRing.style.transform = oZoomTransform(1);
        setAdvProgress(kp);
      }

      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        window.requestAnimationFrame(updatePhase);
        ticking = true;
      }
    }

    // Use IntersectionObserver to only track when visible
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            window.addEventListener("scroll", onScroll, { passive: true });
            onScroll();
          } else {
            window.removeEventListener("scroll", onScroll);
            // Reset everything when section leaves viewport
            section.classList.remove("phase-zoom", "phase-kaleidoscope");
            oRing.style.transform = "scale(1)";
            setAdvProgress(0);
            closeAdvisor();
            currentPhase = "";
          }
        });
      },
      { threshold: 0 },
    );
    observer.observe(section);

    // Intercept clicks to #advisory-board and scroll to 38% of the spacer (allowing 2% progress for fade-in animation visibility)
    const advisoryLinks = document.querySelectorAll('a[href="#advisory-board"]');
    advisoryLinks.forEach((link) => {
      link.addEventListener("click", (e) => {
        e.preventDefault();
        const spacerTop = spacer.getBoundingClientRect().top + window.scrollY;
        const total = spacer.offsetHeight - window.innerHeight;
        const targetScroll = spacerTop + 0.38 * total;

        if ((window as any).lenis) {
          (window as any).lenis.scrollTo(targetScroll, {
            offset: 0,
            duration: 1.8,
            easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          });
        } else {
          window.scrollTo({
            top: targetScroll,
            behavior: "smooth",
          });
        }
      });
    });

    // Handle initial hash on page load
    if (window.location.hash === "#advisory-board") {
      setTimeout(() => {
        const spacerTop = spacer.getBoundingClientRect().top + window.scrollY;
        const total = spacer.offsetHeight - window.innerHeight;
        const targetScroll = spacerTop + 0.38 * total;
        if ((window as any).lenis) {
          (window as any).lenis.scrollTo(targetScroll, { immediate: true });
        } else {
          window.scrollTo(0, targetScroll);
        }
      }, 500);
    }

    // Initial call
    onScroll();
  }
</script>
