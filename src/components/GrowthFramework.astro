            <li>Channel &amp; Partner Development</li>
            <li>Revenue Growth Architecture</li>
          </ul>
        </div>
      </div>

      <div class="fw-stage">
        <div class="fw-stage-num">03</div>
        <div class="fw-stage-content">
          <span class="fw-stage-tag">Scale Stage</span>
