---
import FrameworkStepper from "./FrameworkStepper.astro";
---

<section id="growth-framework" class="gf-section">
  <div class="page-wrap">
    <FrameworkStepper />
  </div>
</section>

<style>
  .gf-section {
    background: #0b0b0b;
    padding: 120px 72px;
    position: relative;
    overflow: hidden;
    min-height: 980px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .page-wrap {
    width: 100%;
    max-width: var(--max-wide); /* Let's use wide to give the 3-column layout ample room on desktop */
  }

  /* Responsive styling */
  @media (max-width: 1024px) {
    .gf-section {
      padding: 80px 32px;
      min-height: auto;
    }
  }

  @media (max-width: 767px) {
    .gf-section {
      padding: 60px 16px;
    }
  }
</style>

