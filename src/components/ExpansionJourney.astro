---
---
<!-- ════════ JOURNEY ════════ -->
  <section id="journey" class="section">
    <div class="page-wrap">
      <div class="journey-header reveal">
        <hr class="accent" />
        <span class="label" style="color:rgba(237,72,35,.75)">The Expansion Journey</span>
        <h2 class="title" style="font-size:clamp(1.8rem,2.8vw,2.4rem);margin-top:.5rem;margin-bottom:.8rem;color:#fff">
          From First Step to <span class="orange">Full Scale</span>
        </h2>
        <p class="body" style="color:rgba(255,255,255,.4)">A clear, sequenced path — designed for international
          businesses entering and scaling across ASEAN.</p>
      </div>
      <div class="journey-steps reveal">
        <div class="j-step">
          <div class="j-roman">I</div>
          <div class="j-content">
            <div class="j-title">Market Entry</div>
            <p class="j-body">Feasibility analysis, market intelligence, regulatory mapping, and entry strategy design
              for your target ASEAN markets.</p>
          </div>
        </div>
        <div class="j-step">
          <div class="j-roman">II</div>
          <div class="j-content">
            <div class="j-title">Setup &amp; Structure</div>
            <p class="j-body">Company incorporation, licensing, banking, compliance, and corporate secretarial setup —
              executed end-to-end.</p>
          </div>
        </div>
        <div class="j-step">
          <div class="j-roman">III</div>
          <div class="j-content">
            <div class="j-title">Expansion &amp; Growth</div>
            <p class="j-body">Brand positioning, channel development, digital presence, and revenue architecture to
              accelerate in-market growth.</p>
          </div>
        </div>
        <div class="j-step">
          <div class="j-roman">IV</div>
          <div class="j-content">
            <div class="j-title">Scaling &amp; M&amp;A</div>
            <p class="j-body">AI-powered operations, cross-border acquisitions, and M&amp;A integration to build a
              lasting, scalable ASEAN enterprise.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

<style>
/* ─────────────────────────────────────
   JOURNEY STRIP
───────────────────────────────────── */
    #journey {
      background: var(--dark);
    }

    .journey-header {
      max-width: 560px;
      margin-bottom: 4rem;
    }

    .journey-header .title {
      color: #fff;
      font-size: clamp(1.8rem, 2.8vw, 2.4rem);
      margin-bottom: .8rem;
    }

    .journey-header .body {
      color: rgba(255, 255, 255, .4);
    }

    .journey-steps {
      display: flex;
      flex-direction: column;
    }

    .j-step {
      display: flex;
      gap: 2.5rem;
      align-items: flex-start;
      padding: 2rem 0;
      border-bottom: 1px solid rgba(255, 255, 255, .07);
      transition: padding-left .2s;
    }

    .j-step:first-child {
      border-top: 1px solid rgba(255, 255, 255, .07);
    }

    .j-step:hover {
      padding-left: .6rem;
    }

    .j-roman {
      font-family: var(--serif);
      font-size: 1.5rem;
      color: var(--orange);
      flex-shrink: 0;
      min-width: 2.5rem;
      line-height: 1.2;
    }

    .j-content {
      flex: 1;
    }

    .j-title {
      font-size: .8rem;
      font-weight: 700;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: #fff;
      margin-bottom: .35rem;
    }

    .j-body {
      font-size: .88rem;
      color: rgba(255, 255, 255, .4);
      line-height: 1.65;
    }
</style>

