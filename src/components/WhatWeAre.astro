<!-- ══════════════════════════════════════════════
     SCRIPTS — Drawer interaction
══════════════════════════════════════════════ -->
<script>
  const backdrop = document.getElementById('wwa-backdrop')!;
  let activeDrawer: HTMLElement | null = null;
  let triggerEl: HTMLElement | null = null;

  function openDrawer(id: string, trigger: HTMLElement) {
    const drawer = document.getElementById(`drawer-${id}`) as HTMLElement | null;
    if (!drawer) return;
    // Close any open drawer first
    if (activeDrawer) closeDrawer(false);

    activeDrawer = drawer;
    triggerEl = trigger;

    drawer.classList.add('is-open');
    backdrop.classList.add('is-visible');
    document.body.style.overflow = 'hidden';

    // Focus the drawer for accessibility
    drawer.focus();
  }

  function closeDrawer(returnFocus = true) {
    if (!activeDrawer) return;
    activeDrawer.classList.remove('is-open');
    backdrop.classList.remove('is-visible');
    document.body.style.overflow = '';

    if (returnFocus && triggerEl) triggerEl.focus();
    activeDrawer = null;
    triggerEl = null;
  }

  // Open buttons
  document.querySelectorAll<HTMLButtonElement>('[data-drawer]').forEach((btn) => {
    btn.addEventListener('click', () => openDrawer(btn.dataset.drawer!, btn));
  });

  // Close buttons (data-close attr)
  document.querySelectorAll<HTMLElement>('[data-close]').forEach((el) => {
    el.addEventListener('click', () => closeDrawer());
  });

  // Backdrop click
  backdrop.addEventListener('click', () => closeDrawer());

  // Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && activeDrawer) closeDrawer();
  });

  // Trap focus inside open drawer
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab' || !activeDrawer) return;
    const focusable = activeDrawer.querySelectorAll<HTMLElement>(
      'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
    );
    const first = focusable[0];
    const last  = focusable[focusable.length - 1];
    if (e.shiftKey ? document.activeElement === first : document.activeElement === last) {
      e.preventDefault();
      (e.shiftKey ? last : first).focus();
    }
  });
</script>

<style>
/* ══════════════════════════════════════════════
   WHAT WE ARE — Section
══════════════════════════════════════════════ */
#what-we-are {
  background: #fafaf8;
  padding: 120px var(--gutter) 80px;
  position: relative;
  overflow: hidden;
}

/* Subtle grid texture */
#what-we-are::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(237, 72, 35, 0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(237, 72, 35, 0.025) 1px, transparent 1px);
  background-size: 72px 72px;
  pointer-events: none;
}

/* ── Section header ──────────────────────────── */
.wwa-header {
  max-width: 680px;
  margin: 0 auto 72px;
  text-align: center;
}

.wwa-eyebrow {
  display: inline-block;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: #ed4823;
  margin-bottom: 16px;
  position: relative;
  padding: 0 20px;
}

.wwa-eyebrow::before,
.wwa-eyebrow::after {
  content: '';
  position: absolute;
  top: 50%;
  width: 14px;
  height: 1px;
  background: #ed4823;
}
.wwa-eyebrow::before { right: 100%; margin-right: -18px; }
.wwa-eyebrow::after  { left:  100%; margin-left:  -18px; }

.wwa-title {
  font-family: var(--serif);
  font-size: clamp(2rem, 3.6vw, 3.4rem);
  font-weight: 400;
  line-height: 1.18;
  color: #111;
  margin-bottom: 20px;
  letter-spacing: -0.01em;
}

.wwa-title-accent {
  color: #ed4823;
}

.wwa-sub {
  font-size: 0.98rem;
  line-height: 1.7;
  color: #555;
  max-width: 540px;
  margin: 0 auto;
}

.wwa-sub strong {
  color: #111;
  font-weight: 600;
}

/* ── Waterfall steps ─────────────────────────── */
.wwa-waterfall {
  max-width: var(--max-wide);
  margin: 0 auto;
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* Each step sits in a constrained block that is pushed L / C / R */
.wwa-step {
  position: relative;
  width: 60%;
  padding: 52px 0;
  border-bottom: 1px solid rgba(17, 17, 17, 0.07);

  /* Entrance animation */
  opacity: 0;
  transform: translateY(28px);
}

.wwa-step:last-child {
  border-bottom: none;
}

/* Step 1 — flush left */
.wwa-step:nth-child(1) {
  align-self: flex-start;
  margin-left: 0;
}

/* Step 2 — centre */
.wwa-step:nth-child(2) {
  align-self: center;
}

/* Step 3 — flush right */
.wwa-step:nth-child(3) {
  align-self: flex-end;
  margin-right: 0;
}

/* Reveal stagger utility */
.reveal-stagger.in {
  animation: fadeUp 0.65s cubic-bezier(0.22, 0.68, 0, 1.2) var(--delay, 0s) both;
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(28px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Vertical connector line — always aligned to icon centre (28px from inner left) */
.wwa-step-line {
  position: absolute;
  top: 0;
  left: 28px;
  width: 1px;
  height: 52px;
  background: linear-gradient(to bottom, rgba(237, 72, 35, 0.3), rgba(237, 72, 35, 0.05));
  transform: translateY(-100%);
}

/* Inner flex row: icon | content */
.wwa-step-inner {
  display: flex;
  align-items: flex-start;
  gap: 36px;
}

/* Icon wrap */
.wwa-step-icon-wrap {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  padding-top: 6px;
}

.wwa-step-icon {
  width: 56px;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(237, 72, 35, 0.06);
  border-radius: 50%;
  transition: background 0.3s ease;
}

.wwa-step:hover .wwa-step-icon {
  background: rgba(237, 72, 35, 0.12);
}

/* Override SVG size inside the icon circle */
.wwa-step-icon svg {
  width: 26px;
  height: 26px;
}

.wwa-step-num {
  font-size: 0.58rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  color: rgba(237, 72, 35, 0.7);
}

/* Content column */
.wwa-step-content {
  flex: 1;
}

.wwa-step-tag {
  display: inline-block;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: rgba(17, 17, 17, 0.38);
  margin-bottom: 10px;
}

.wwa-step-title {
  font-family: var(--serif);
  font-size: clamp(1.9rem, 3.2vw, 3rem);
  font-weight: 400;
  color: #111;
  line-height: 1.12;
  letter-spacing: -0.01em;
  margin-bottom: 16px;
}

.wwa-step-copy {
  font-size: 0.93rem;
  line-height: 1.72;
  color: #666;
  max-width: 480px;
  margin-bottom: 24px;
}

/* View Details button — OMO orange fill on hover */
.wwa-card-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.76rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #ed4823;
  background: none;
  border: 1.5px solid rgba(237, 72, 35, 0.4);
  border-radius: 4px;
  padding: 10px 20px;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  transition: color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
}

.wwa-card-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(110deg, #ed4823 0%, #f86240 45%, #ffd0b0 55%, #f86240 65%, #ed4823 100%);
  background-size: 200% auto;
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.32s cubic-bezier(0.22, 0.68, 0, 1.2);
  z-index: 0;
}

.wwa-card-btn:hover {
  color: #111;
  border-color: #ed4823;
  box-shadow: 0 6px 20px rgba(237, 72, 35, 0.3);
}

.wwa-card-btn:hover::before {
  transform: scaleX(1);
  animation: btn-shimmer 3s linear infinite;
}

.wwa-card-btn:hover::before {
  transform: scaleX(1);
}

.wwa-card-btn span,
.wwa-card-btn svg,
.wwa-btn-arrow {
  position: relative;
  z-index: 1;
}

.wwa-btn-arrow {
  transition: transform 0.25s ease;
}

.wwa-card-btn:hover .wwa-btn-arrow {
  transform: translateX(4px);
}

/* ── Why OMO integration bar ─────────────────── */
.wwa-why-bar {
  max-width: var(--max-wide);
  margin: 60px auto 0;
  background: #111;
  border-radius: 10px;
  padding: 28px 40px;
  position: relative;
  z-index: 1;
  overflow: hidden;
}

.wwa-why-bar::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 60% 50%, rgba(237, 72, 35, 0.1) 0%, transparent 65%);
  pointer-events: none;
}

.wwa-why-inner {
  display: flex;
  align-items: center;
  gap: 28px;
  flex-wrap: wrap;
  position: relative;
}

.wwa-why-label {
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.4);
  white-space: nowrap;
}

.wwa-why-steps {
  display: flex;
  align-items: center;
  gap: 12px;
  flex: 1;
  flex-wrap: wrap;
}

.wwa-why-step {
  font-size: 0.88rem;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 0.02em;
}

.wwa-why-arrow {
  flex-shrink: 0;
}

.wwa-why-link {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #ed4823;
  text-decoration: none;
  white-space: nowrap;
  transition: gap 0.2s ease;
  margin-left: auto;
}

.wwa-why-link:hover {
  gap: 11px;
}

/* ══════════════════════════════════════════════
   BACKDROP
══════════════════════════════════════════════ */
.wwa-backdrop {
  position: fixed;
  inset: 0;
  background: rgba(10, 10, 10, 0.55);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  z-index: 900;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.32s ease;
}

.wwa-backdrop.is-visible {
  opacity: 1;
  pointer-events: all;
}

/* ══════════════════════════════════════════════
   SIDE DRAWER
══════════════════════════════════════════════ */
.wwa-drawer {
  position: fixed;
  top: 0;
  right: 0;
  height: 100dvh;
  width: min(520px, 100vw);
  background: #ffffff;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform 0.38s cubic-bezier(0.22, 0.68, 0, 1.2);
