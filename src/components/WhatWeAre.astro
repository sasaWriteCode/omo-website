      We enable businesses to scale across<br/>
      <span class="wwa-title-accent">Malaysia and APAC.</span>
    </h2>
    <p class="wwa-sub">
      Why Us? We combine incubation, diagnosis, and acceleration into
      <strong> one integrated growth system.</strong>
    </p>
  </div>

  <!-- Waterfall cards -->
  <div class="wwa-waterfall">
    {cards.map(({ id, tag, tagNum, title, copy, icon }, i) => (
      <article
        class="wwa-step reveal-stagger"
        style={`--delay:${i * 0.18}s; --step:${i}`}
        data-card={id}
      >
        <!-- Connector line between steps -->
        {i > 0 && <div class="wwa-step-line" aria-hidden="true"></div>}

        <div class="wwa-step-inner">
          <!-- Left: icon block -->
          <div class="wwa-step-icon-wrap" aria-hidden="true">
            <div class="wwa-step-icon" set:html={icon} />
            <span class="wwa-step-num">{tagNum}</span>
