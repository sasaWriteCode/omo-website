---
interface Card {
  id: string;
  tag: string;
  tagNum: string;
  title: string;
  copy: string;
  accent: string;
  icon: string;
}

const cards: Card[] = [
  {
    id: 'incubator',
    tag: 'Foundation',
    tagNum: '01',
    title: 'Business Incubator',
    copy: 'We nurture early-stage and new-market ventures and build the foundations, frameworks, and positioning needed to grow with confidence.',
    accent: '#ed4823',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <circle cx="14" cy="14" r="12" stroke="#ed4823" stroke-width="1.5" fill="none"/>
      <path d="M9 14 L14 9 L19 14" stroke="#ed4823" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      <line x1="14" y1="9" x2="14" y2="19" stroke="#ed4823" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
  },
  {
    id: 'doctor',
    tag: 'Diagnosis',
    tagNum: '02',
    title: 'Company Doctor',
    copy: 'We diagnose what\'s holding your business back — inefficiencies, structural gaps, revenue leaks — and prescribe clear, actionable remedies.',
    accent: '#ed4823',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect x="3" y="7" width="22" height="16" rx="3" stroke="#ed4823" stroke-width="1.5" fill="none"/>
      <line x1="14" y1="11" x2="14" y2="19" stroke="#ed4823" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="10" y1="15" x2="18" y2="15" stroke="#ed4823" stroke-width="1.5" stroke-linecap="round"/>
      <path d="M10 7V5a2 2 0 0 1 4 0v2M14 7V5a2 2 0 0 1 4 0v2" stroke="#ed4823" stroke-width="1.5" stroke-linecap="round" fill="none"/>
    </svg>`,
  },
  {
    id: 'accelerator',
    tag: 'Scale',
    tagNum: '03',
    title: 'Growth Accelerator',
    copy: 'We compress timelines. Using AI, strategic marketing, and proven scaling systems, we accelerate growth toward investor-ready performance.',
    accent: '#ed4823',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M6 22 L14 6 L22 22" stroke="#ed4823" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      <path d="M9 18 L19 18" stroke="#ed4823" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
  },
];
---

<!-- ══════════════════════════════════════════════
     WHAT WE ARE + WHY OMO
══════════════════════════════════════════════ -->
<section id="what-we-are" aria-labelledby="wwa-heading">

  <!-- Section header -->
  <div class="wwa-header reveal">
    <p class="wwa-eyebrow">What We Are</p>
    <h2 class="wwa-title" id="wwa-heading">
      We enable businesses to scale across<br/>
      <span class="wwa-title-accent">Malaysia and APAC.</span>
    </h2>
    <p class="wwa-sub">
      Why Us? We combine incubation, diagnosis, and acceleration into
      <strong> one integrated growth system.</strong>
    </p>
  </div>

  <!-- Waterfall cards -->
  <div class="wwa-waterfall">
    {cards.map(({ id, tag, tagNum, title, copy, icon }, i) => (
      <article
        class="wwa-step reveal-stagger"
        style={`--delay:${i * 0.18}s; --step:${i}`}
        data-card={id}
      >
        <!-- Connector line between steps -->
        {i > 0 && <div class="wwa-step-line" aria-hidden="true"></div>}

        <div class="wwa-step-inner">
          <!-- Left: icon block -->
          <div class="wwa-step-icon-wrap" aria-hidden="true">
            <div class="wwa-step-icon" set:html={icon} />
            <span class="wwa-step-num">{tagNum}</span>
          </div>

          <!-- Right: content -->
          <div class="wwa-step-content">
            <span class="wwa-step-tag">{tag}</span>
            <h3 class="wwa-step-title">{title}</h3>
            <p class="wwa-step-copy">{copy}</p>
            <button
              class="wwa-card-btn"
              type="button"
              aria-haspopup="dialog"
              data-drawer={id}
            >
              <span>View Details</span>
              <svg class="wwa-btn-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </div>
      </article>
    ))}
  </div>

  <!-- Why OMO Integration bar -->
  <div class="wwa-why-bar reveal">
    <div class="wwa-why-inner">
      <span class="wwa-why-label">One integrated approach</span>
      <div class="wwa-why-steps">
        <span class="wwa-why-step">Incubation</span>
        <svg class="wwa-why-arrow" width="20" height="12" viewBox="0 0 20 12" fill="none" aria-hidden="true">
          <path d="M1 6h18M13 1l6 5-6 5" stroke="#ed4823" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="wwa-why-step">Diagnosis</span>
        <svg class="wwa-why-arrow" width="20" height="12" viewBox="0 0 20 12" fill="none" aria-hidden="true">
          <path d="M1 6h18M13 1l6 5-6 5" stroke="#ed4823" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="wwa-why-step">Acceleration</span>
      </div>
      <a href="#growth-framework" class="wwa-why-link">
        Explore the OMO Framework
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>

</section>

