<!-- ══════════════════════════════════════════════
     SCRIPTS — Drawer interaction
══════════════════════════════════════════════ -->
<script>
  const backdrop = document.getElementById('wwa-backdrop')!;
  let activeDrawer: HTMLElement | null = null;
  let triggerEl: HTMLElement | null = null;

  function openDrawer(id: string, trigger: HTMLElement) {
    const drawer = document.getElementById(`drawer-${id}`) as HTMLElement | null;
    if (!drawer) return;
    // Close any open drawer first
    if (activeDrawer) closeDrawer(false);

    activeDrawer = drawer;
    triggerEl = trigger;

    drawer.classList.add('is-open');
    backdrop.classList.add('is-visible');
    document.body.style.overflow = 'hidden';

    // Focus the drawer for accessibility
    drawer.focus();
  }

  function closeDrawer(returnFocus = true) {
    if (!activeDrawer) return;
    activeDrawer.classList.remove('is-open');
    backdrop.classList.remove('is-visible');
    document.body.style.overflow = '';

    if (returnFocus && triggerEl) triggerEl.focus();
    activeDrawer = null;
    triggerEl = null;
  }

  // Open buttons
  document.querySelectorAll<HTMLButtonElement>('[data-drawer]').forEach((btn) => {
    btn.addEventListener('click', () => openDrawer(btn.dataset.drawer!, btn));
  });

  // Close buttons (data-close attr)
  document.querySelectorAll<HTMLElement>('[data-close]').forEach((el) => {
    el.addEventListener('click', () => closeDrawer());
  });

  // Backdrop click
  backdrop.addEventListener('click', () => closeDrawer());

  // Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && activeDrawer) closeDrawer();
  });

  // Trap focus inside open drawer
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab' || !activeDrawer) return;
    const focusable = activeDrawer.querySelectorAll<HTMLElement>(
      'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
    );
    const first = focusable[0];
    const last  = focusable[focusable.length - 1];
    if (e.shiftKey ? document.activeElement === first : document.activeElement === last) {
      e.preventDefault();
      (e.shiftKey ? last : first).focus();
    }
  });
</script>

<!-- ══════════════════════════════════════════════
     3D SPHERE — Waterfall stair animation
     Path: drop → roll → drop → roll → drop → settle (no arcs)
══════════════════════════════════════════════ -->
<script>
  import * as THREE from 'three';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  /* ── Guards ─────────────────────────────────────────────────────────── */
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile             = window.innerWidth < 768;

  const section  = document.getElementById('what-we-are')            as HTMLElement | null;
  const canvas   = document.getElementById('wwa-sphere-canvas')      as HTMLCanvasElement | null;
  const card1El  = document.querySelector('[data-card="incubator"]')  as HTMLElement | null;
  const card2El  = document.querySelector('[data-card="doctor"]')     as HTMLElement | null;
  const card3El  = document.querySelector('[data-card="accelerator"]') as HTMLElement | null;

  if (!section || !canvas || !card1El || !card2El || !card3El ||
      prefersReducedMotion || isMobile) {
    /* Mobile / reduced-motion fallback: plain cards, no sphere */
  } else {

    /* ── Scroll phases ─────────────────────────────────────────────────
     * 0.00–0.16  DROP1   vertical drop above Card 1 → Card 1 platform
     * 0.16–0.36  ROLL1   horizontal roll across Card 1 left → right
     * 0.36–0.50  DROP2   vertical drop Card 1 level → Card 2 platform
     * 0.50–0.70  ROLL2   horizontal roll across Card 2
     * 0.70–0.86  DROP3   vertical drop Card 2 level → Card 3 platform
     * 0.86–1.00  SETTLE  small settle roll on Card 3
     * ──────────────────────────────────────────────────────────── */
    const PH = {
      DROP1:   [0.00, 0.16] as [number, number],
      ROLL1:   [0.16, 0.36] as [number, number],
      DROP2:   [0.36, 0.50] as [number, number],
      ROLL2:   [0.50, 0.70] as [number, number],
      DROP3:   [0.70, 0.86] as [number, number],
      SETTLE:  [0.86, 1.00] as [number, number],
    };

    /* Which card is active at each progress value */
    function getActiveCard(p: number): 0 | 1 | 2 {
      if (p < PH.DROP2[0]) return 0; // drop1 + roll1
      if (p < PH.DROP3[0]) return 1; // drop2 + roll2
      return 2;                        // drop3 + settle
    }

    /* Linear fraction of progress within a phase */
    const frac = (p: number, a: number, b: number) =>
      Math.max(0, Math.min(1, (p - a) / (b - a)));

    /* Ease-in-out for drops and rolls */
    const eio = (t: number) =>
      t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;

    /* ── Three.js scene ─────────────────────────────────────────────── */
    const scene = new THREE.Scene();
    let { width: W, height: H } = section.getBoundingClientRect();

    // 1 scene unit = 1 CSS pixel, origin at section centre
    let cam = new THREE.OrthographicCamera(-W/2, W/2, H/2, -H/2, 0.1, 600);
    cam.position.z = 300;

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
    renderer.setClearColor(0x000000, 0);
    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type    = THREE.PCFSoftShadowMap;
    renderer.setSize(W, H);

    /* ── Lighting ─────────────────────────────────────────────────── */
    scene.add(new THREE.AmbientLight(0xffffff, 0.6));

    const keyLight = new THREE.DirectionalLight(0xffffff, 1.2);
    keyLight.position.set(80, 160, 120);
    keyLight.castShadow = true;
    keyLight.shadow.mapSize.set(512, 512);
    scene.add(keyLight);

    const fillLight = new THREE.DirectionalLight(0xffd0c0, 0.3);
    fillLight.position.set(-80, -60, 80);
    scene.add(fillLight);

    const glowLight = new THREE.PointLight(0xed4823, 0, 150);
    scene.add(glowLight);

    /* ── Sphere (OMO orange, glossy, with visible rotation grooves) ────── */
    const R = 32; // radius in CSS pixels

    const sphereGeo = new THREE.SphereGeometry(R, 48, 48);
    const sphereMat = new THREE.MeshPhysicalMaterial({
      color:              0xed4823,
      roughness:          0.28,             // Let the diffuse orange color show clearly
      metalness:          0.0,              // Avoid metallic darkening
      clearcoat:          1.0,              // Premium glossy outer shell
      clearcoatRoughness: 0.05,
      emissive:           new THREE.Color(0xed4823),
      emissiveIntensity:  0.18,             // Maintain bright, vivid orange even in shaded areas
    });
    const sphere = new THREE.Mesh(sphereGeo, sphereMat);
    sphere.castShadow = true;
    scene.add(sphere);

    // Contact shadow
    const shadowMat = new THREE.MeshBasicMaterial({
      color: 0x111111, transparent: true, opacity: 0.18,
    });
    const contactShadow = new THREE.Mesh(
      new THREE.CircleGeometry(R * 0.7, 32),
      shadowMat
    );
    scene.add(contactShadow);

    /* ── Platform coordinates (recalculated on layout change) ──────────── */
    // All coordinates are section-relative pixels.
    // toW() converts (sx, sy) → Three.js world space (origin = section centre).
    const toW = (sx: number, sy: number) => ({ wx: sx - W/2, wy: H/2 - sy });

    interface Platform { xL: number; xR: number; surfaceY: number; }
    let P1: Platform, P2: Platform, P3: Platform;
    let startDropY: number;  // Y where sphere first appears (above Card 1)
    let dropX2: number;      // X where sphere falls onto Card 2 (from Card 1 right, clamped)
    let landX3: number;      // X where sphere lands on Card 3 (75% across)
    let settleX3: number;    // X where sphere settles on Card 3 (80% across)

    function buildPlatforms() {
      const sRect = section.getBoundingClientRect();
      const r1    = card1El.getBoundingClientRect();
      const r2    = card2El.getBoundingClientRect();
      const r3    = card3El.getBoundingClientRect();

      P1 = {
        xL:       r1.left  - sRect.left,
        xR:       r1.right - sRect.left,
        surfaceY: (r1.top  - sRect.top) - R, // sphere centre R px above platform top
      };
      P2 = {
        xL:       r2.left  - sRect.left,
        xR:       r2.right - sRect.left,
        surfaceY: (r2.top  - sRect.top) - R,
      };
      P3 = {
        xL:       r3.left  - sRect.left,
        xR:       r3.right - sRect.left,
        surfaceY: (r3.top  - sRect.top) - R,
      };

      // Drop-in start: 160 px above Card 1's platform, aligned to Card 1 left
      startDropY = P1.surfaceY - 160;

      // Sphere falls from Card 1's right edge; clamp inside Card 2 bounds
      dropX2 = Math.max(P2.xL + R, Math.min(P2.xR - R, P1.xR - R));

      // Card 3 landing / settle
      const w3 = P3.xR - P3.xL;
      landX3   = P3.xL + w3 * 0.75;
      settleX3 = P3.xL + w3 * 0.80;
    }

    buildPlatforms();

    /* ── Waterfall path sampler ──────────────────────────────────────────
     * Returns section-relative {x, y} for a given scroll progress p.
     * Only straight vertical drops and straight horizontal rolls.
     * ──────────────────────────────────────────────────────────── */
    function samplePos(p: number): { x: number; y: number } {
      // ── Phase DROP1: fall vertically onto Card 1 ──
      if (p <= PH.DROP1[1]) {
        const t = eio(frac(p, PH.DROP1[0], PH.DROP1[1]));
        return {
          x: P1.xL + R,
          y: startDropY + (P1.surfaceY - startDropY) * t,
        };
      }

      // ── Phase ROLL1: roll right across Card 1 ──
      if (p <= PH.ROLL1[1]) {
        const t = eio(frac(p, PH.ROLL1[0], PH.ROLL1[1]));
        return {
          x: (P1.xL + R) + ((P1.xR - R) - (P1.xL + R)) * t,
          y: P1.surfaceY,
        };
      }

      // ── Phase DROP2: fall vertically to Card 2 ──
      if (p <= PH.DROP2[1]) {
        const t = eio(frac(p, PH.DROP2[0], PH.DROP2[1]));
        return {
          x: dropX2,
          y: P1.surfaceY + (P2.surfaceY - P1.surfaceY) * t,
        };
      }

      // ── Phase ROLL2: roll right across Card 2 ──
      if (p <= PH.ROLL2[1]) {
        const t = eio(frac(p, PH.ROLL2[0], PH.ROLL2[1]));
        return {
          x: dropX2 + ((P2.xR - R) - dropX2) * t,
          y: P2.surfaceY,
        };
      }

      // ── Phase DROP3: fall vertically to Card 3 ──
      if (p <= PH.DROP3[1]) {
        const t = eio(frac(p, PH.DROP3[0], PH.DROP3[1]));
        return {
          x: landX3,
          y: P2.surfaceY + (P3.surfaceY - P2.surfaceY) * t,
        };
      }

      // ── Phase SETTLE: small roll on Card 3 ──
      const t = eio(frac(p, PH.SETTLE[0], PH.SETTLE[1]));
      return {
        x: landX3 + (settleX3 - landX3) * t,
        y: P3.surfaceY,
      };
    }

    /* ── Animation state ───────────────────────────────────────────────── */
    let progress = 0;
    let lastX    = P1.xL + R;  // starting X
    let rotZ     = 0;           // cumulative Z rotation (rolling)

    /* Is the sphere in a vertical drop phase? */
    const isDropPhase = (p: number) =>
      (p > PH.DROP1[0] && p < PH.DROP1[1]) ||
      (p > PH.DROP2[0] && p < PH.DROP2[1]) ||
      (p > PH.DROP3[0] && p < PH.DROP3[1]);

    function applyProgress(p: number) {
      progress = p;
      const { x, y } = samplePos(p);
      const card      = getActiveCard(p);
      const dropping  = isDropPhase(p);

      // Convert to Three.js world space
      const { wx, wy } = toW(x, y);

      // Rolling rotation: only accumulate during horizontal roll phases
      const dx = x - lastX;
      if (!dropping) rotZ -= dx / R; // rotate when rolling horizontally
      lastX = x;

      sphere.position.set(wx, wy, 0);
      sphere.rotation.z = rotZ;

      // Contact shadow — subtle during drops, full during rolls
      contactShadow.position.set(wx, wy - R - 2, -1);
      contactShadow.scale.setScalar(dropping ? 0.35 : 1);
      (contactShadow.material as THREE.MeshBasicMaterial).opacity =
        dropping ? 0.04 : 0.18;

      // Glow on platform, dimmed in the air
      glowLight.position.set(wx, wy, 40);
      glowLight.intensity = dropping ? 0 : 3.0;

      // Active card highlight
      document.querySelectorAll('.wwa-step').forEach((el, idx) => {
        el.classList.toggle('is-active', idx === card);
      });
    }

    /* ── Resize ─────────────────────────────────────────────────────────── */
    function resizeAll() {
      const r = section.getBoundingClientRect();
      W = r.width; H = r.height;
      renderer.setSize(W, H);
      cam.left = -W/2; cam.right = W/2;
      cam.top  =  H/2; cam.bottom = -H/2;
      cam.updateProjectionMatrix();
      buildPlatforms();
      lastX = P1.xL + R;
      rotZ  = 0;
      applyProgress(progress);
    }

    const ro = new ResizeObserver(resizeAll);
    ro.observe(section);
    window.addEventListener('orientationchange', resizeAll);

    /* ── Render loop ─────────────────────────────────────────────────────── */
    (function render() {
      requestAnimationFrame(render);
      renderer.render(scene, cam);
    })();

    /* ── ScrollTrigger (no pin — section scrolls normally) ───────────────
     * start: section top reaches 75% down the viewport
     * end:   section bottom reaches 25% from viewport top
     * This gives a generous scroll range across the full section height.
     * scrub: 1.4 adds pleasant lag so the sphere feels heavy/physical.     */
    ScrollTrigger.create({
      trigger: section,
      start:   'top 75%',
      end:     'bottom 25%',
      scrub:   1.4,
      onUpdate: (self) => applyProgress(self.progress),
    });

    applyProgress(0);
  }
</script>

