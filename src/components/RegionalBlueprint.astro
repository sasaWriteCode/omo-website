          <div class="fp-phase">
            <div class="fp-phase-dot"></div>
            <div>
              <div class="fp-phase-label">Phase 3 — East Asia</div>
              <div class="fp-phase-markets">🇨🇳 China · 🇯🇵 Japan · 🇹🇼 Taiwan · 🇰🇷 Korea</div>
            </div>
