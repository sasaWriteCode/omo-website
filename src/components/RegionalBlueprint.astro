<style>
/* ─────────────────────────────────────
   FOOTPRINT — INTERACTIVE MAP
───────────────────────────────────── */
    #footprint {
      background: var(--dark);
    }

    .fp-header {
      max-width: 560px;
      margin-bottom: 3rem;
    }

    .fp-header .title {
      color: #fff;
      font-size: clamp(2rem, 3.2vw, 2.7rem);
      margin-bottom: 1rem;
    }

    .fp-header .body {
      color: rgba(255, 255, 255, .45);
    }

    /* Map + legend layout */
    .fp-map-wrap {
      display: grid;
      grid-template-columns: 1fr 280px;
      gap: 3rem;
      align-items: start;
    }

    /* SVG wrapper */
    .fp-map-svg-wrap {
      background: rgba(255, 255, 255, .03);
      border: 1px solid rgba(255, 255, 255, .07);
      overflow: hidden;
      position: relative;
    }

    .fp-map-svg-wrap svg {
      display: block;
      width: 100%;
      height: auto;
    }

    /* Connection lines — draw animation */
    .fp-line {
      stroke-dashoffset: 1000;
      animation: drawLine 1.2s ease forwards;
      animation-delay: var(--delay, 0s);
    }

    @keyframes drawLine {
      to {
        stroke-dashoffset: 0;
      }
    }

    /* Pulse rings on Malaysia hub */
    .fp-pulse-ring {
      transform-origin: 400px 355px;
      animation: mapPulse 2.5s ease-out infinite;
    }

    .fp-pulse-ring:nth-child(2) {
      animation-delay: .8s;
    }

    @keyframes mapPulse {
      0% {
        transform: scale(1);
        opacity: .6;
      }

      100% {
        transform: scale(2.2);
        opacity: 0;
      }
    }

    /* Node hover */
    .fp-node {
      cursor: pointer;
    }

    .fp-node-ring {
      transition: fill .2s, stroke .2s, r .2s;
    }

    .fp-node:hover .fp-node-ring {
      fill: rgba(237, 72, 35, .25);
      stroke: rgba(237, 72, 35, .7);
    }

    /* Legend */
    .fp-legend {
      display: flex;
      flex-direction: column;
      gap: 0;
      padding: 2rem;
      background: rgba(255, 255, 255, .03);
      border: 1px solid rgba(255, 255, 255, .07);
      align-self: start;
    }

    .fp-legend-title {
      font-size: .6rem;
      font-weight: 700;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 1.4rem;
      padding-bottom: .8rem;
      border-bottom: 1px solid rgba(255, 255, 255, .07);
    }

    .fp-phase {
      display: flex;
      gap: .9rem;
      align-items: flex-start;
      padding: 1rem 0;
      border-bottom: 1px solid rgba(255, 255, 255, .06);
      opacity: .5;
      transition: opacity .2s;
    }

    .fp-phase:last-of-type {
      border-bottom: none;
    }

    .fp-phase:hover {
      opacity: 1;
    }

    .fp-phase-active {
      opacity: 1 !important;
    }

    .fp-phase-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--orange);
      flex-shrink: 0;
      margin-top: .2rem;
      box-shadow: 0 0 8px rgba(237, 72, 35, .6);
    }

    .fp-phase-dot-ai {
      background: transparent;
      border: 2px solid var(--orange);
      box-shadow: none;
    }

    .fp-phase-label {
      font-size: .72rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: .3rem;
      letter-spacing: .02em;
    }

    .fp-phase-markets {
      font-size: .72rem;
      color: rgba(255, 255, 255, .4);
      line-height: 1.6;
    }

    .fp-legend-note {
      font-size: .62rem;
      color: rgba(255, 255, 255, .2);
      margin-top: 1.2rem;
      font-style: italic;
      letter-spacing: .04em;
    }

    @media(max-width:900px) {
      .fp-map-wrap {
        grid-template-columns: 1fr;
      }

      .fp-legend {
        display: none;
      }
    }
</style>

<script>
// ── Map tooltip ──
    (function () {
      const nodes = document.querySelectorAll('.fp-node');
      const tooltip = document.getElementById('fpTooltip');
      const tooltipBg = document.getElementById('fpTooltipBg');
      const tooltipTitle = document.getElementById('fpTooltipTitle');
      const tooltipDesc = document.getElementById('fpTooltipDesc');
      const svg = document.getElementById('fpMap');
      if (!svg || !tooltip) return;

      nodes.forEach(node => {
        node.addEventListener('mouseenter', function (e) {
          const country = this.dataset.country;
          const desc = this.dataset.desc;
          const bbox = this.getBBox();
          const cx = bbox.x + bbox.width / 2;
          const cy = bbox.y;

          tooltipTitle.setAttribute('x', cx);
          tooltipTitle.setAttribute('y', cy - 28);
          tooltipTitle.setAttribute('text-anchor', 'middle');
          tooltipTitle.textContent = country;

          tooltipDesc.setAttribute('x', cx);
          tooltipDesc.setAttribute('y', cy - 14);
          tooltipDesc.setAttribute('text-anchor', 'middle');
          tooltipDesc.textContent = desc;

          const pad = 10;
          const tw = Math.max(tooltipTitle.getComputedTextLength?.() || 80, (tooltipDesc.getComputedTextLength?.() || 120)) + pad * 2;
          tooltipBg.setAttribute('x', cx - tw / 2);
          tooltipBg.setAttribute('y', cy - 44);
          tooltipBg.setAttribute('width', tw);
          tooltipBg.setAttribute('height', 36);

          tooltip.style.display = 'block';
        });
        node.addEventListener('mouseleave', function () {
          tooltip.style.display = 'none';
        });
      });
    })();
</script>
