---
---
<!-- ════════ FOOTPRINT ════════ -->
  <section id="footprint" class="section">
    <div class="page-wrap">

      <!-- Header -->
      <div class="fp-header reveal">
        <hr class="accent" />
        <span class="label" style="color:rgba(237,72,35,.75)">Regional Blueprint</span>
        <h2 class="title" style="font-size:clamp(2rem,3.2vw,2.7rem);margin-top:.5rem;margin-bottom:1rem;color:#fff">
          Malaysia-Centred.<br /><span class="orange">ASEAN-Scaled.</span>
        </h2>
        <p class="body" style="color:rgba(255,255,255,.45)">OMO uses Malaysia as its strategic hub — a gateway to eleven
          markets across Southeast Asia and East Asia.</p>
      </div>

      <!-- MAP + LEGEND split -->
      <div class="fp-map-wrap reveal">

        <!-- SVG MAP -->
        <div class="fp-map-svg-wrap">
          <svg id="fpMap" viewBox="0 0 800 600" xmlns="http://www.w3.org/2000/svg" aria-label="OMO ASEAN Regional Map">
            <defs>
              <!-- Glow filter -->
              <filter id="glow">
                <feGaussianBlur stdDeviation="3" result="blur" />
                <feMerge>
                  <feMergeNode in="blur" />
                  <feMergeNode in="SourceGraphic" />
                </feMerge>
              </filter>
              <filter id="glow-strong">
                <feGaussianBlur stdDeviation="6" result="blur" />
                <feMerge>
                  <feMergeNode in="blur" />
                  <feMergeNode in="SourceGraphic" />
                </feMerge>
              </filter>
              <!-- Animated dash -->
              <marker id="arrowhead" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="5" markerHeight="5"
                orient="auto-start-reverse">
                <path d="M0 0 L10 5 L0 10 z" fill="rgba(237,72,35,.7)" />
              </marker>
            </defs>

            <!-- ── BACKGROUND ── -->
            <rect width="800" height="600" fill="rgba(255,255,255,.02)" rx="4" />

            <!-- Subtle grid -->
            <g opacity=".08">
              <line x1="0" y1="100" x2="800" y2="100" stroke="#ed4823" stroke-width=".5" />
              <line x1="0" y1="200" x2="800" y2="200" stroke="#ed4823" stroke-width=".5" />
              <line x1="0" y1="300" x2="800" y2="300" stroke="#ed4823" stroke-width=".5" />
              <line x1="0" y1="400" x2="800" y2="400" stroke="#ed4823" stroke-width=".5" />
              <line x1="0" y1="500" x2="800" y2="500" stroke="#ed4823" stroke-width=".5" />
              <line x1="160" y1="0" x2="160" y2="600" stroke="#ed4823" stroke-width=".5" />
              <line x1="320" y1="0" x2="320" y2="600" stroke="#ed4823" stroke-width=".5" />
              <line x1="480" y1="0" x2="480" y2="600" stroke="#ed4823" stroke-width=".5" />
              <line x1="640" y1="0" x2="640" y2="600" stroke="#ed4823" stroke-width=".5" />
            </g>

            <!-- ── LAND SHAPES (simplified outlines) ── -->
            <!-- China mainland -->
            <path
              d="M290 40 L420 30 L500 60 L540 110 L520 160 L480 180 L460 220 L420 210 L380 230 L350 200 L310 190 L280 160 L260 130 L270 90 Z"
              fill="rgba(255,255,255,.04)" stroke="rgba(255,255,255,.1)" stroke-width="1" />
            <!-- Korea peninsula -->
            <path d="M560 120 L580 110 L590 150 L570 170 L555 155 Z" fill="rgba(255,255,255,.04)"
              stroke="rgba(255,255,255,.1)" stroke-width="1" />
            <!-- Japan -->
            <path d="M620 80 L640 70 L655 100 L645 130 L625 120 Z" fill="rgba(255,255,255,.04)"
              stroke="rgba(255,255,255,.1)" stroke-width="1" />
            <path d="M650 140 L670 130 L680 160 L660 170 Z" fill="rgba(255,255,255,.04)" stroke="rgba(255,255,255,.1)"
              stroke-width="1" />
            <!-- Taiwan -->
            <path d="M580 190 L590 180 L598 205 L585 215 Z" fill="rgba(255,255,255,.04)" stroke="rgba(255,255,255,.1)"
              stroke-width="1" />
            <!-- Vietnam -->
            <path d="M450 230 L470 220 L480 280 L470 330 L455 340 L445 310 L440 270 Z" fill="rgba(255,255,255,.04)"
              stroke="rgba(255,255,255,.1)" stroke-width="1" />
            <!-- Thailand -->
            <path d="M390 230 L420 220 L440 250 L430 290 L410 310 L390 290 L380 260 Z" fill="rgba(255,255,255,.04)"
              stroke="rgba(255,255,255,.1)" stroke-width="1" />
            <!-- Malaysia peninsula -->
            <path d="M390 310 L410 310 L418 360 L400 380 L385 360 L382 330 Z" fill="rgba(255,255,255,.06)"
              stroke="rgba(255,255,255,.15)" stroke-width="1" />
            <!-- Borneo (Malaysia/Brunei/Indonesia) -->
            <path d="M480 320 L540 310 L570 350 L560 400 L510 420 L470 390 L460 350 Z" fill="rgba(255,255,255,.04)"
              stroke="rgba(255,255,255,.1)" stroke-width="1" />
            <!-- Indonesia Java/Sumatra -->
            <path d="M350 390 L420 380 L450 400 L440 430 L380 440 L345 420 Z" fill="rgba(255,255,255,.04)"
