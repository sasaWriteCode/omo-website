---
---
<!-- ════════ PORTFOLIO ════════ -->
  <section id="portfolio" class="section">
    <div class="page-wrap">

      <div class="port-header reveal">
        <hr class="accent" />
        <span class="label">Proof of Execution</span>
        <h2 class="title" style="font-size:clamp(2rem,3.2vw,2.7rem);margin-top:.5rem;margin-bottom:1rem">
          Designed. Built. <span class="orange">Delivered.</span>
        </h2>
        <p class="body">Our portfolio demonstrates that design-led thinking and hands-on execution are proven
          methodologies — deployed across industries and geographies.</p>
      </div>

      <div class="port-cards-wrapper reveal">
        <div class="port-cards">

        <!-- Suzuran Japan -->
        <div class="port-card">
          <div class="port-card-img">
            <img
              src="data:image/png;base64,"
              alt="Suzuran Body Maintenance Japan" />
            <div class="port-card-flag">
              <img src="https://flagcdn.com/w40/jp.png" alt="Japan" />
              <span>Japan</span>
            </div>
            <div class="port-card-stat">Market-ready<br />in 90 days</div>
          </div>
          <div class="port-card-body">
            <div class="port-card-cat">Manufacturing Expansion</div>
            <div class="port-card-name">Suzuran Body Maintenance</div>
            <p class="port-card-desc">Full market entry design and brand execution for a premium Japanese body
              maintenance concept — from licensing to retail experience design in Malaysia.</p>
            <div class="port-card-result">Full licensing &amp; operational setup</div>
          </div>
        </div>

        <!-- Formosa Taiwan -->
        <div class="port-card">
          <div class="port-card-img">
            <img
              src="data:image/png;base64,"
              alt="Formosa Taiwan" />
            <div class="port-card-flag">
              <img src="https://flagcdn.com/w40/tw.png" alt="Taiwan" />
              <span>Taiwan</span>
            </div>
            <div class="port-card-stat">2.5× brand<br />recall</div>
          </div>
          <div class="port-card-body">
            <div class="port-card-cat">Branding Transformation</div>
            <div class="port-card-name">Formosa</div>
            <p class="port-card-desc">Cross-border corporate advisory and brand architecture supporting a Taiwanese
              F&amp;B label's positioning and entry into the ASEAN market.</p>
            <div class="port-card-result">150% sales growth achieved</div>
          </div>
        </div>

        <!-- Chopped Ireland -->
        <div class="port-card">
          <div class="port-card-img">
            <img
              src="data:image/png;base64,"
              alt="Chopped Ireland" />
            <div class="port-card-flag">
              <img src="https://flagcdn.com/w40/ie.png" alt="Ireland" />
              <span>Ireland</span>
            </div>
            <div class="port-card-stat">300% ROI<br />delivered</div>
          </div>
          <div class="port-card-body">
            <div class="port-card-cat">AI Automation Integration</div>
            <div class="port-card-name">Chopped!</div>
            <p class="port-card-desc">Regional brand positioning and franchise expansion for an Irish fresh food concept
              — market analysis, operational design, and corporate structure.</p>
            <div class="port-card-result">60% reduction in operational overhead</div>
          </div>
        </div>

        <!-- H.I Signature Malaysia -->
        <div class="port-card">
          <div class="port-card-img">
            <img
              src="data:image/png;base64,"
              alt="H.I Signature Malaysia" />
            <div class="port-card-flag">
              <img src="https://flagcdn.com/w40/my.png" alt="Malaysia" />
              <span>Malaysia</span>
            </div>
            <div class="port-card-stat">40% faster<br />approvals</div>
          </div>
          <div class="port-card-body">
            <div class="port-card-cat">Complex Licensing Projects</div>
            <div class="port-card-name">H.I Signature</div>
            <p class="port-card-desc">End-to-end design and launch for a professional development academy — curriculum
              architecture, brand identity, and digital systems.</p>
            <div class="port-card-result">Across 3 jurisdictions</div>
          </div>
        </div>

      </div>
    </div>
  </section>

<style>
/* ─────────────────────────────────────
   PORTFOLIO — PHOTO CARDS
───────────────────────────────────── */
    #portfolio {
      background: #fff;
    }

    .port-header {
      max-width: 560px;
      margin-bottom: 4rem;
    }

    .port-header .title {
      font-size: clamp(2rem, 3.2vw, 2.7rem);
      margin-bottom: 1rem;
    }

    /* Header layout for controls */
    .port-header-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 2rem;
    }

    .port-controls {
      display: flex;
      gap: .75rem;
      margin-bottom: 1.5rem;
    }

    .port-btn {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      border: 1px solid var(--border);
      background: #fff;
      color: var(--dark);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all .2s ease;
    }

    .port-btn:hover:not(.disabled) {
      background: var(--dark);
      border-color: var(--dark);
      color: #fff;
    }

    .port-btn.disabled {
      opacity: 0.35;
      cursor: not-allowed;
    }

    .port-btn svg {
      width: 18px;
      height: 18px;
    }

    /* Carousel layout */
    .port-cards-wrapper {
      overflow: hidden;
      width: 100%;
    }

    .port-cards {
      display: flex;
      gap: 1.5rem;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none; /* Firefox */
      padding-bottom: 1.5rem; /* space for card shadows */
    }

    .port-cards::-webkit-scrollbar {
      display: none; /* Safari/Chrome */
    }

    .port-card {
      flex: 0 0 calc(33.333% - 1rem); /* 3 cards visible on desktop */
      scroll-snap-align: start;
      display: flex;
      flex-direction: column;
      background: var(--light);
      border: 1px solid var(--border);
      overflow: hidden;
      transition: transform .3s, box-shadow .3s;
      cursor: default;
    }

    .port-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 20px 48px rgba(0, 0, 0, .1);
    }

    /* Photo area */
    .port-card-img {
      width: 100%;
      aspect-ratio: 4/3;
      overflow: hidden;
      position: relative;
      background: var(--dark);
    }

    .port-card-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform .5s ease;
    }

    .port-card:hover .port-card-img img {
      transform: scale(1.06);
    }

    /* Flag pill over image */
    .port-card-flag {
      position: absolute;
      top: .8rem;
      left: .8rem;
      z-index: 2;
      display: flex;
      align-items: center;
      gap: .4rem;
      background: rgba(8, 8, 8, .75);
      backdrop-filter: blur(6px);
      padding: .3rem .7rem;
      border-radius: 100px;
    }

    .port-card-flag img {
      width: 18px;
      height: 12px;
      object-fit: cover;
      border-radius: 2px;
      flex-shrink: 0;
      transition: none !important;
      transform: none !important;
    }

    .port-card-flag span {
      font-size: .58rem;
      font-weight: 700;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, .8);
    }

    /* Stat badge top-right */
    .port-card-stat {
      position: absolute;
      top: .8rem;
      right: .8rem;
      z-index: 2;
      background: var(--orange);
      padding: .28rem .65rem;
      font-size: .6rem;
      font-weight: 700;
      letter-spacing: .06em;
      color: #fff;
      text-align: center;
      line-height: 1.3;
    }

    /* Text area */
    .port-card-body {
      padding: 1.4rem 1.4rem 1.6rem;
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: .55rem;
    }

    .port-card-cat {
      font-size: .6rem;
      font-weight: 700;
      letter-spacing: .16em;
      text-transform: uppercase;
      color: var(--orange);
    }

    .port-card-name {
      font-family: var(--serif);
      font-size: 1.05rem;
      color: var(--dark);
      line-height: 1.25;
    }

    .port-card-desc {
      font-size: .82rem;
      color: var(--mid);
      line-height: 1.65;
      flex: 1;
    }

    .port-card-result {
      font-size: .78rem;
      font-weight: 600;
      color: var(--dark);
      padding-top: .6rem;
      border-top: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: .4rem;
    }

    .port-card-result::before {
      content: '↑';
      color: var(--orange);
      font-weight: 700;
    }

    @media(max-width:900px) {
      .port-cards {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media(max-width:540px) {
      .port-cards {
        grid-template-columns: 1fr;
      }
    }
</style>

