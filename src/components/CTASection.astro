<section id="cta">
  <div class="cta-wrap">
    <div class="cta-tag reveal">Ready to Scale</div>

    <h2 class="cta-headline reveal">
      Let's Build Your<br /><em>ASEAN</em> Future Together
    </h2>

    <p class="cta-sub reveal">
      Whether you're entering a new market, scaling an existing business, or
      building the systems for exponential growth — OMO is your strategic
      partner.
    </p>

    <div class="reveal cta-btn-container">
      <div class="cta-primary-group">
        <a href="mailto:hello@omomarketingads.com" class="cta-main-btn">
          Book Diagnose Consultation
        </a>
        <p class="cta-support-label">
          Start with a 30-minute complimentary strategy session.
        </p>
      </div>
      <a href="#growth-framework" class="cta-sec-btn">Explore Our Framework</a>
    </div>
  </div><!-- /cta-wrap -->
</section>

<style>
  .cta-btn-container {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 3.5rem;
  }

  .cta-primary-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
  }

  .cta-support-label {
    font-family: var(--sans);
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.55);
    margin: 0;
    text-align: center;
  }

  #cta .cta-main-btn {
    margin-bottom: 0;
    border-radius: 4px;
    box-shadow: 0 4px 15px rgba(237, 72, 35, 0.25);
  }

  #cta .cta-sec-btn {
    margin-left: 0;
    margin-bottom: 0;
    margin-top: 4px;
    border-radius: 4px;
  }

  @media (max-width: 768px) {
    .cta-btn-container {
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
    }
  }
</style>
