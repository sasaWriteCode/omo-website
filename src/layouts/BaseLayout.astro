---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'OMO — Business Growth & Scaling Advisory',
  description = 'Hands-on advisory from Malaysia to ASEAN. Design-led strategy, real execution, and measurable growth — from market entry to full scale.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type"        content="website" />
  <meta name="twitter:card"       content="summary_large_image" />
  <meta name="twitter:title"      content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Favicons -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
  <link rel="apple-touch-icon" href="/favicon-192x192.png" />

  <!-- OG / Twitter image -->
  <meta property="og:image" content="/assets/omo_logo.png" />
  <meta name="twitter:image" content="/assets/omo_logo.png" />

  <title>{title}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300&family=DM+Serif+Display:ital@0;1&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <slot />
  
  <script src="https://cdn.jsdelivr.net/npm/@studio-freight/lenis@1.0.42/dist/lenis.min.js" is:inline></script>
  <script is:inline>
    // Initialize Lenis smooth scrolling
    const lenis = new Lenis({
      duration: 1.8, // Slightly slower scroll duration for a premium, heavy, smooth feel
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), // Custom premium easing curve
      direction: 'vertical',
      gestureDirection: 'vertical',
      smooth: true,
      mouseMultiplier: 0.95, // Make wheel scrolling slightly slower/softer
      smoothTouch: false, // Let mobile touch scroll remain native
      infinite: false,
    });

    window.lenis = lenis;

    // Smooth scroll for all hash links via Lenis
    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener('click', function (e) {
        const targetId = this.getAttribute('href');
        if (targetId === '#' || targetId === '') return;

        const target = document.querySelector(targetId);
        if (target) {
          e.preventDefault();
          lenis.scrollTo(target, {
            offset: 0,
            duration: 1.5,
            easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          });
        }
      });
    });

    function raf(time) {
      lenis.raf(time);
      requestAnimationFrame(raf);
    }

    requestAnimationFrame(raf);
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
